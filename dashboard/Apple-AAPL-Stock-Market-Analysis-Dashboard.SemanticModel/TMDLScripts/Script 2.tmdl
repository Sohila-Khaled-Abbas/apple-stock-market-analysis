createOrReplace

	model Model
		culture: en-US
		defaultPowerBIDataSourceVersion: powerBI_V3
		sourceQueryCulture: en-US
		dataAccessOptions
			legacyRedirects
			returnErrorValuesAsNull

		table aapl_daily
			lineageTag: fcaea2a8-d740-4e49-9b25-27d9f558ae23

			column Trade_Date
				dataType: dateTime
				isKey
				formatString: Short Date
				lineageTag: ae24425f-4baa-4b5e-b857-0cef7401e2e9
				isDefaultLabel
