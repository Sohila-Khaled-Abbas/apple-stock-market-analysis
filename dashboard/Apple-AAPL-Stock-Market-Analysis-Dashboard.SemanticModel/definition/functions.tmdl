/// Select theme color, wrapping around to the start if variant exceeds available options
/// @param {string} themeName – The theme name e.g. "Office", "Power BI"
/// @param {int} variant – The variant index (1-N, wraps around if exceeds available variants)
/// @returns {string} hex color code
function 'DaxLib.SVG.Color.Theme' =
		(
			themeName: STRING,
			variant: INT64
		) =>
		
			VAR Themes =
				DATATABLE(
				"ThemeName", STRING,
				"Variant", INTEGER,
				"Color", STRING,
				{
					// Power BI Default
					{"Power BI", 1, "#118DFF"},
					{"Power BI", 2, "#12239E"},
					{"Power BI", 3, "#E66C37"},
					{"Power BI", 4, "#6B007B"},
