	annotation DAXLIB_PackageVersion = 1.0.1

/// Builds a shared axis/value data table for compound visuals
/// @param {anyref expr} axisRef – Axis reference column evaluated in current filter context
/// @param {numeric expr} measureRef – Measure expression evaluated per axis value
/// @param {string} axisMode – "Auto", "Numeric", or "Categorical"
/// @returns {table} Standardized table with `@AxisValue`, `@AxisIndex`, and `@Value`
function 'DaxLib.SVG.Data.AxisMeasure' =
		(
			axisRef: ANYREF EXPR,
			measureRef: NUMERIC EXPR,
			axisMode: STRING
		) =>
		
			VAR _AxisMode =
				IF(
					axisMode = "Numeric" || axisMode = "Categorical",
					axisMode,
					"Auto"
				)
		
			VAR _AxisSample = MAX( axisRef )
			VAR _AxisIsNumeric = ISNUMBER( _AxisSample ) || ISDATETIME( _AxisSample )
			VAR _UseNumericAxis =
				IF(
					_AxisMode = "Numeric",
					TRUE(),
					IF( _AxisMode = "Categorical", FALSE(), _AxisIsNumeric )
				)
		
			VAR _WithValues =
				ADDCOLUMNS(
					VALUES( axisRef ),
					"@AxisValue", axisRef,
					"@Value", measureRef
				)
		
			VAR _Indexed =
				ADDCOLUMNS(
					_WithValues,
					"@AxisIndex",
						IF(
							_UseNumericAxis,
							[@AxisValue],
							RANK( DENSE, CALCULATETABLE( VALUES( axisRef ), ALLSELECTED() ) )
						)
				)
		
			RETURN
				TOPN(
					COUNTROWS( _Indexed ),
					_Indexed,
					[@AxisIndex], ASC,
					[@AxisValue], ASC
				)
	lineageTag: 137611a6-1b05-4595-9d90-4e03a3869e73

	annotation DAXLIB_PackageId = DaxLib.SVG

	annotation DAXLIB_PackageVersion = 1.0.1

/// Computes min/max/baseline values from shaped scalar range inputs
/// @param {numeric val} dataMin – Minimum value from source data
/// @param {numeric val} dataMax – Maximum value from source data
/// @param {boolean} [includeZero] – Use zero baseline when range is fully positive. Defaults to FALSE
/// @returns {table} Single-row table with `@Min`, `@Max`, and `@Baseline`
function 'DaxLib.SVG.Data.Range' =
		(
			dataMin: NUMERIC VAL,
			dataMax: NUMERIC VAL,
			includeZero: BOOLEAN
		) =>
		
			VAR _IncludeZero = IF( ISBLANK( includeZero ), FALSE(), includeZero )
			VAR _Min = dataMin
			VAR _Max = dataMax
			VAR _Baseline = IF( _IncludeZero && _Min > 0, 0, _Min )
		
			RETURN
				ROW(
					"@Min", _Min,
					"@Max", _Max,
					"@Baseline", _Baseline
				)
	lineageTag: acdd0e38-3afa-4232-9ecf-ca3455158c12

