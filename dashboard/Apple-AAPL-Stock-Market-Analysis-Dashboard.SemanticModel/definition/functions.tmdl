/// Generates a STRING of common shape attributes that can be passed to `DaxLib.SVG.Element.*` or `DaxLib.SVG.Def.*` functions
/// @param {string} [fill] – Fill color or gradient reference. Omitted if not specified
/// @param {decimal} [fillOpacity] – Fill opacity (0-1). Omitted if not specified
/// @param {string} [fillRule] – Fill rule ("nonzero" or "evenodd"). Omitted if not specified
/// @param {string} [stroke] – Stroke color. Omitted if not specified
/// @param {int} [strokeWidth] – Stroke width. Omitted if not specified
/// @param {decimal} [strokeOpacity] – Stroke opacity (0-1). Omitted if not specified
/// @param {decimal} [opacity] – Overall opacity (0-1). Omitted if not specified
/// @returns {string} An attribute string that can be used directly in SVG elements
function 'DaxLib.SVG.Attr.Shapes' =
		(
			fill: STRING,
			fillOpacity: DOUBLE,
			fillRule: STRING,
			stroke: STRING,
			strokeWidth: INT64,
			strokeOpacity: DOUBLE,
			opacity: DOUBLE
		) =>
		
			IF( NOT ISBLANK( fill ),          "fill='" & fill & "' ") &
			IF( NOT ISBLANK( fillOpacity ),   "fill-opacity='" & fillOpacity & "' ") &
			IF( NOT ISBLANK( fillRule ),      "fill-rule='" & fillRule & "' ") &
			IF( NOT ISBLANK( stroke ),        "stroke='" & stroke & "' ") &
			IF( NOT ISBLANK( strokeWidth ),   "stroke-width='" & strokeWidth & "' ") &
			IF( NOT ISBLANK( strokeOpacity ), "stroke-opacity='" & strokeOpacity & "' ") &
			IF( NOT ISBLANK( opacity ),       "opacity='" & opacity & "' ")
	lineageTag: 21be878d-9d9d-462d-811d-17055d84ad5f

