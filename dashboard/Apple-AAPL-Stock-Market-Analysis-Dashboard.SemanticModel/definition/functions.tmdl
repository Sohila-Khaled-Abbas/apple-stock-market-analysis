/// Creates a bar chart (SVG-image) that compares absolute values (actual value vs base value)
/// @param {anyref} dimensionColumn - dimension in the rows: 'Payment Mode'[Payment Mode]
/// @param {scalar} mainValueExpr - main value (actuals): [AC]
/// @param {scalar} secondValueExpr - secondary value (forecast), can be BLANK() if not used: [FC] or BLANK()
/// @param {scalar} baseValueExpr - base value (previous year, budget) for comparison: [PY] or [BU]
/// @param {string} baseType - base bar styling: "grey" (for [PY]) or "outlined" (for [BU])
/// @param {string} dataLabel - formatted data label: FORMAT ( [AC] + [FC], "#,0" )
/// @param {int64} imageWidth - image width, same as on the Format pane: 350
/// @param {int64} imageHeight - image height, same as on the Format pane: 35
/// @param {boolean} syncWithAbsVariance - will be used together with Absolute Variance chart: TRUE() or FALSE()
/// @returns SVG image (data:image/svg+xml URI for embedding in table cells)
function 'PowerofBI.IBCS.BarChart.AbsoluteValues' =
		
		(
		    // dimension in the rows: 'Payment Mode'[Payment Mode]
		    dimensionColumn: ANYREF EXPR,
		    // main value (actuals): [AC]
		    mainValueExpr: SCALAR EXPR,
		    // secondary value (forecast), can be BLANK() if not used: [FC] or BLANK()
		    secondValueExpr: SCALAR EXPR,
		    // base value (previous year, budget) for comparison: [PY] or [BU]
		    baseValueExpr: SCALAR EXPR,
		    // base bar styling: "grey" (for [PY]) or "outlined" (for [BU])
		    baseType: STRING VAL,
		    // formatted data label: FORMAT ( [AC] + [FC], "#,0" )
		    dataLabel: STRING VAL,
		    // image width, same as on the Format pane: 350
		    imageWidth: INT64 VAL,
		    // image height, same as on the Format pane: 35
		    imageHeight: INT64 VAL,
		    // will be used together with Absolute Variance chart: TRUE() or FALSE()
		    syncWithAbsVariance: BOOLEAN VAL
		) =>
		//=================================================================================================
		// Project: PowerofBI.IBCS: IBCS-guided data visualizations in your Power BI reports
		// Project Description: https://www.powerofbi.org/ibcs
		// DAX Lib package: https://daxlib.org/package/PowerofBI.IBCS/
		// PowerofBI.IBCS support: https://github.com/avatorl/dax-udf-svg-ibcs/issues
		// Author: Andrzej Leszkiewicz — IBCS® Certified Analyst
		// LinkedIn: https://www.linkedin.com/in/avatorl/
		// The visualization design adheres to IBCS recommendations: https://www.ibcs.com/ibcs-standards-1-2/
		//      but is NOT produced, certified, authorized, or endorsed by IBCS®
		//=================================================================================================
		// License: MIT License (free and permissive)
		// https://en.wikipedia.org/wiki/MIT_License
		//=================================================================================================
		//
		//=================================================================================================
		// CONFIGURATION and CALCULATIONS
		//=================================================================================================
		// When = 1, draws a rectangle showing the SVG boundaries (useful during layout tuning)
		VAR _DEBUG = 0
		
		// Axis line color
		VAR _ColorAxis = "#000000"
		
		// AC (actuals): solid dark fill
		VAR _ColorBlack = "#404040"
		
		// PY (previous year): neutral grey reference fill
		VAR _ColorGrey = "#C6C6C6"
		
		// Outline color for main bar
		VAR _ColorOutline = "#FFFFFF"
		
		// Outline color for base bar
		VAR _ColorOutlineBase = "#c0c0c0"
		
		// Outline width applied to bar borders
		VAR _OutlineWidth = 0.5
		
		// Font size in px (also determines size and positioning of other chart elements)
		VAR _Em = imageHeight * 0.6
		
		// Horizontal offset between the bar end and the data label
		VAR _LabelOffset = _Em * 0.15
		
		// Scaled width for Y-axis line stroke
		VAR _AxisLineWidth = _Em * 0.1
		
		// Vertical placement of the main bar
		VAR _mainBarYPosition = ( imageHeight - _Em ) / 2
		
		// White space to the right of the chart
		VAR _RighPad =
		    imageWidth * IF ( syncWithAbsVariance, 0.5 + 0.15, 0.15 )
		
		// Is it a total row?
		VAR _IsTotalRow = NOT ( ISINSCOPE ( dimensionColumn ) )
		
		// Total rows are emphasized with bold text
		VAR _FontWeight = IF ( _IsTotalRow, "bold", "normal" )
		
		// Maximum value (longest bar) across the entire dimension (ALLSELECTED)
		VAR _ValueMax =
		    MAXX (
		        ALLSELECTED ( dimensionColumn ),
		        MAX (
		            CALCULATE ( mainValueExpr ),
		            CALCULATE ( baseValueExpr )
		        )
		    )
		
		// Enables sorting in Power BI by embedding a sortable rank inside the SVG code
		VAR _Rank =
		    1000000000000
		        + ROUND (
		            mainValueExpr + secondValueExpr,
		            0
		        )
		
		// Base bar fill: grey for [PY], white for [BU]
		VAR _ColorBase =
		    SWITCH (
		        baseType,
		        "grey", _ColorGrey,
		        "outlined", "#FFFFFF"
		    )
		
		// Base bar outline
		VAR _ColorBaseOutline =
		    SWITCH (
		        baseType,
		        "grey", _ColorOutlineBase,
		        "outlined", _ColorBlack
		    )
		
		// Space available for the horizontal bar(s)
		VAR _MaxRectWidth = imageWidth - _RighPad
		
		// Scaling factor: pixels per data unit, using max from ALLSELECTED scope
		VAR _Scale = DIVIDE ( _MaxRectWidth, _ValueMax )
		
		// Width of the main bar (Actuals)
		VAR _WidthMain =
		    ROUND ( mainValueExpr * _Scale, 0 )
		
		// Width of the stacked secondary bar (Forecast)
		VAR _WidthSecond =
		    ROUND ( secondValueExpr * _Scale, 0 )
		
		// Width of the base comparison bar (Previous Year or Budget)
		VAR _WidthBase =
		    ROUND ( baseValueExpr * _Scale, 0 )
		
		//=================================================================================================
		// SVG GENERATION: Build all SVG components
		//=================================================================================================
		//=================================================================================================
		// PowerofBI.IBCS.BarChart.AbsoluteValues function generates the following visual elements:
		//     - Y-axis line (vertical black line at left edge)
		//     - Base bar: grey (Previous Year) or outlined (Budget)
		//     - Stacked bars for main and secondary values:
		//           - Main value (AC, actuals): solid black bar
		//           - Secondary value (FC, forecast): hatched diagonal pattern
		//     - Data label placed to the right of the bar
		//=================================================================================================
		// MIME type prefix for inline SVG data URI
		VAR _SVG_Header = "data:image/svg+xml;utf8,"
		
		// SVG root element with width and height attributes
		VAR _SVG_Open =
		    "<svg xmlns='http://www.w3.org/2000/svg' width='"
		        & imageWidth
		        & "' height='"
		        & imageHeight
		        & "'"
		        & " >"
		
		// SVG closing tag
		VAR _SVG_Close = "</svg>"
		
		// CSS style for text elements
		VAR _SVG_Style =
		    ( "<style>
		        text{
		        font-family: 'Segoe UI', sans-serif;
		        font-size: "
		        & _Em
		        & "px;
		        font-weight: "
		        & _FontWeight
		        & ";
		        dominant-baseline: central;
		        </style>" )
		// Hatched pattern definition for secondary bar (forecast, optional)
		VAR SVG_HatchedPattern =
		    ( "/*hatched pattern*/
		        <defs>
		            <pattern id='diagonal-stripe' patternUnits='userSpaceOnUse' width='8' height='8'>
		                <!-- white background -->
		                <rect x='0' y='0' width='8' height='8' fill='#FFFFFF' stroke-width='0' />
		                <!-- black diagonal stripes -->
		                <path d='
		                    M-2,2 l4,-4
		                    M0,8 l8,-8
		                    M6,10 l4,-4'
		                    style='stroke:black; stroke-width:2' />
		            </pattern>
		        </defs>" )
		//
		// Comment-based sort key injected into SVG for sorting by a column with embedded SVG
		VAR _SVG_SortBy = "/*SortBy:" & _Rank & "*/"
		
		// Debug overlay to visualize available drawing area
		VAR _SVG_DebugBox =
		    IF (
		        _DEBUG,
		        "<rect id='rect-debug-box' x='0%' y='0%' width='"
		            & imageWidth
		            & "' height='100%' fill='#FFFFAA' stroke-width='1' stroke='#FF0000' />
		                            <rect id='rect-debug-box' x='0%' y='0%' width='"
		            & imageWidth / 2
		            & "' height='100%' fill='#FFFFAA' stroke-width='1' stroke='#FF0000' />",
		        ""
		    )
		
		// Y-axis vertical line at left edge
		VAR _SVG_LineAxisY =
		    "<line id='line-axis-y' x1='0px' x2='0px' y1='0%' y2='100%' stroke='"
		        & _ColorAxis
		        & "' stroke-width='"
		        & _AxisLineWidth
		        & "'></line>"
		
		// PY/BU reference bar (grey or outlined)
		VAR _SVG_BarBase =
		    "<rect id='rect-base-value' x='0px' width='" & _WidthBase
		        & "' y='"
		        & _OutlineWidth
		        & "' height='"
		        & _Em
		        & "' fill='"
		        & _ColorBase
		        & "' stroke='"
		        & _ColorBaseOutline
		        & "' stroke-width='"
		        & _OutlineWidth
		        & "'></rect>"
		
		// AC (Actuals) bar - solid black
		VAR _SVG_BarMain =
		    "<rect id='rect-main-value' x='0px' width='" & _WidthMain
		        & "' y='"
		        & _mainBarYPosition
		        & "' height='"
		        & _Em
		        & "' fill='"
		        & _ColorBlack
		        & "' stroke='"
		        & _ColorOutline
		        & "' stroke-width='"
		        & _OutlineWidth
		        & "'></rect>"
		
		// FC (Forecast) bar - hatched pattern
		VAR _SVG_BarSecond =
		    "<rect id='rect-second-value' x='" & _WidthMain
		        & "px' width='"
		        & _WidthSecond
		        & "' y='"
		        & _mainBarYPosition + _OutlineWidth
		        & "' height='"
		        & _Em - _OutlineWidth * 2
		        & "' fill='url(#diagonal-stripe)' stroke='"
		        & _ColorBlack
		        & "' stroke-width='"
		        & _OutlineWidth
		        & "'></rect>"
		
		// Data label positioned to the right of bars
		VAR _SVG_TextACFCLabel =
		    "<text x='" & ( _WidthMain + _WidthSecond ) & "' dx='"
		        & _LabelOffset
		        & "' y='"
		        & ( imageHeight / 2 - _Em * 0.05 )
		        & "'>"
		        & dataLabel
		        & "</text>"
		
		// Label for total rows
		VAR _SVG_TextACFCLabelTotal =
		    "<text x='0' dx='0' y='50%'>" & dataLabel & "</text>"
		
		// SVG markup for total rows (label only, no chart)
		VAR _SVG_Total =
		    _SVG_Header & _SVG_Open & _SVG_DebugBox & _SVG_Style
		        & _SVG_TextACFCLabelTotal
		        & _SVG_Close
		
		// SVG markup for detail rows (with all chart elements)
		VAR _SVG_Row =
		    _SVG_Header & _SVG_Open & _SVG_Style & _SVG_SortBy
		        & _SVG_DebugBox
		        & SVG_HatchedPattern
		        & _SVG_BarBase
		        & _SVG_BarMain
		        & _SVG_BarSecond
		        & _SVG_LineAxisY
		        & _SVG_TextACFCLabel
		        & _SVG_Close
		VAR _Result = IF ( _IsTotalRow, _SVG_Total, _SVG_Row )
		RETURN
		    _Result
	lineageTag: b214ce32-0ca7-41eb-948a-c4637caaba85

	annotation DAXLIB_PackageId = PowerofBI.IBCS

	annotation DAXLIB_PackageVersion = 0.11.0

/// Creates a diverging bar chart that compares absolute variance between two values (e.g., actual vs previous year)
/// @param {anyref} dimensionColumn - dimension in the rows: 'Payment Mode'[Payment Mode]
/// @param {scalar} mainValueExpr - main value (actuals): [AC]
/// @param {scalar} secondValueExpr - secondary value (forecast), can be BLANK() if not used: [FC] or BLANK()
/// @param {scalar} baseValueExpr - base value (previous year, budget) for comparison: [PY] or [BU]
/// @param {scalar} scaleValueExpr - measure for scaling: [AC]
/// @param {string} baseType - axis Y line styling: "grey" (single thick grey line) or "outlined" (two thin black lines)
/// @param {boolean} totalRow - is it a Total row: NOT ( ISINSCOPE ( 'Payment Mode'[Payment Mode] ) )
/// @param {string} dataLabel - formatted data label: FORMAT ( [AC] + [FC] - [PY], "+#,0;-#,0;=" )
/// @param {int64} imageWidth - image width, same as on the Format pane: 350
/// @param {int64} imageHeight - image height, same as on the Format pane: 35
/// @param {int64} businessImpact - business impact of variance > 0: 1 (positive, sales) or -1 (negative, cost)
/// @returns SVG image (data:image/svg+xml URI for embedding in table cells)
function 'PowerofBI.IBCS.BarChart.AbsoluteVariance' =
		
		(
		    // dimension in the rows: 'Payment Mode'[Payment Mode]
		    dimensionColumn: ANYREF EXPR,
		    // main value (actuals): [AC]
		    mainValueExpr: SCALAR EXPR,
		    // secondary value (forecast), can be BLANK() if not used: [FC] or BLANK()
		    secondValueExpr: SCALAR EXPR,
		    // base value (previous year, budget) for comparison: [PY] or [BU]
		    baseValueExpr: SCALAR EXPR,
		    // measure for scaling:
		    scaleValueExpr: SCALAR EXPR,
		    // axis Y line styling: "grey" (single thick grey line) or "outlined" (two thin black lines)
		    baseType: STRING VAL,
		    // is it a Total row: NOT ( ISINSCOPE ( 'Payment Mode'[Payment Mode] ) )
		    totalRow: BOOLEAN VAL,
		    // formatted data label: FORMAT ( [AC] + [FC] - [PY], "+#,0;-#,0;=" )
		    dataLabel: STRING VAL,
		    // image width, same as on the Format pane: 350
		    imageWidth: INT64 VAL,
		    // image height, same as on the Format pane: 35
		    imageHeight: INT64 VAL,
		    // business impact of variance > 0: 1 (positive, sales) or -1 (negative, cost)
		    businessImpact: INT64 VAL
		) =>
		//=================================================================================================
		// Project: PowerofBI.IBCS: IBCS-guided data visualizations in your Power BI reports
		// Project Description: https://www.powerofbi.org/ibcs
		// DAX Lib package: https://daxlib.org/package/PowerofBI.IBCS/
		// PowerofBI.IBCS support: https://github.com/avatorl/dax-udf-svg-ibcs/issues
		// Author: Andrzej Leszkiewicz — IBCS® Certified Analyst
		// LinkedIn: https://www.linkedin.com/in/avatorl/
		// The visualization design adheres to IBCS recommendations: https://www.ibcs.com/ibcs-standards-1-2/
		//      but is NOT produced, certified, authorized, or endorsed by IBCS®
		//=================================================================================================
		// License: MIT License (free and permissive)
		// https://en.wikipedia.org/wiki/MIT_License
		//=================================================================================================
		//
		//=================================================================================================
		// CONFIGURATION and CALCULATIONS
		//=================================================================================================
		// When = 1, draws a rectangle showing the SVG boundaries (useful during layout tuning)
		VAR _DEBUG = 0
		
		// PY (previous year): neutral grey reference fill
		VAR _ColorGrey = "#C6C6C6"
		
		// Unfavorable business impact
		VAR _ColorRed = "#E24B20"
		
		// Favorable business impact
		VAR _ColorGreen = "#08787D"
		
		// Outline width applied to bar borders
		VAR _OutlineWidth = 0.5
		
		// Combined value (actuals + forecast); BLANK() is treated as 0
		VAR _ValueCombined =
		    mainValueExpr + secondValueExpr
		
		// Variance between combined value and base ([AC] + [FC] - [PY])
		VAR _Variance = _ValueCombined - baseValueExpr
		
		// Whether the bar should be hatched (secondary value is not blank)
		VAR _IsHatched = NOT ( ISBLANK ( secondValueExpr ) )
		
		// Font size in px (also determines size and positioning of other chart elements)
		VAR _Em = imageHeight * 0.6
		
		// Vertical placement of the variance bar
		VAR _mainBarYPosition = ( imageHeight - _Em ) / 2
		
		// Horizontal offset between the bar end and the data label
		VAR _LabelOffset = _Em * 0.15
		
		// Is it a total row?
		VAR _IsTotalRow = totalRow
		
		// Total rows are emphasized with bold text
		VAR _FontWeight = IF ( _IsTotalRow, "bold", "normal" )
		
		// Minimum variance across the entire dimension (ALLSELECTED)
		VAR _ValueMin =
		    MINX (
		        ALLSELECTED ( dimensionColumn ),
		        CALCULATE (
		            mainValueExpr + secondValueExpr
		        )
		            - CALCULATE ( baseValueExpr )
		    )
		
		// Maximum variance across the entire dimension (ALLSELECTED)
		VAR _ValueMax =
		    MAXX (
		        ALLSELECTED ( dimensionColumn ),
		        CALCULATE ( scaleValueExpr )
		    )
		
		// Enables sorting in Power BI by embedding a sortable rank inside the SVG code
		VAR _Rank =
		    1000000000000 + ROUND ( _Variance + ABS ( _ValueMin ), 0 )
		
		// Space available for the horizontal variance bar (35% of image width)
		VAR _MaxRectWidth = imageWidth * 0.35
		
		// Scaling factor: pixels per data unit, using max from ALLSELECTED scope
		VAR _Scale = DIVIDE ( _MaxRectWidth, _ValueMax )
		
		//=================================================================================================
		// SCALING: Calculate bar dimensions and baseline position
		//=================================================================================================
		// X-position of the zero baseline in the diverging bar chart
		VAR _AxisYPosition = imageWidth / 2
		
		// Width of the bar representing the variance
		VAR _WidthValue = ROUND ( ABS ( _Variance ) * _Scale, 0 )
		
		// Green for favorable, red for unfavorable (flipped by businessImpact)
		VAR _BarColor =
		    IF ( _Variance * businessImpact > 0, _ColorGreen, _ColorRed )
		
		// Bar fill: hatched pattern when secondary value present, solid otherwise
		VAR _BarFill =
		    IF (
		        _IsHatched,
		        IF (
		            _Variance * businessImpact > 0,
		            "url(#hatch-green)",
		            "url(#hatch-red)"
		        ),
		        _BarColor
		    )
		
		// Bar stroke: solid color when hatched (visible outline), white when solid
		VAR _BarStroke = IF ( _IsHatched, _BarColor, "white" )
		
		// X-position of the bar start (left edge)
		VAR _X =
		    SWITCH (
		        TRUE ( ),
		        _Variance >= 0, _AxisYPosition,
		        _Variance < 0, _AxisYPosition - _WidthValue
		    )
		
		// X-position of the data label
		VAR _XText =
		    SWITCH (
		        TRUE ( ),
		        _Variance >= 0, _AxisYPosition + _WidthValue,
		        _Variance < 0, _X
		    )
		
		// Text anchor: determines horizontal alignment of the data label
		VAR _Anchor = IF ( _Variance >= 0, "start", "end" )
		
		// Horizontal offset of the data label relative to the anchor
		VAR _DX =
		    SWITCH (
		        TRUE ( ),
		        _Variance >= 0, _LabelOffset,
		        _Variance < 0, -_LabelOffset
		    )
		
		//=================================================================================================
		// SVG GENERATION: Build all SVG components
		//=================================================================================================
		//=================================================================================================
		// PowerofBI.IBCS.BarChart.AbsoluteVariance function generates the following visual elements:
		//     - Zero baseline: grey line (baseType="grey") or two thin black outlined lines (baseType="outlined")
		//     - Diverging bar: green (favorable) or red (unfavorable) variance
		//       - solid fill when only mainValueExpr is used
		//       - hatched fill with colored outline when secondValueExpr is not blank
		//     - Data label positioned to the right (positive) or left (negative) of the bar
		//=================================================================================================
		// MIME type prefix for inline SVG data URI
		VAR _SVG_Header = "data:image/svg+xml;utf8,"
		
		// SVG root element with width and height attributes
		VAR _SVG_Open =
		    "<svg xmlns='http://www.w3.org/2000/svg' width='"
		        & imageWidth
		        & "' height='"
		        & imageHeight
		        & "'"
		        & " >"
		
		// SVG closing tag
		VAR _SVG_Close = "</svg>"
		
		// CSS style for text elements
		VAR _SVG_Style =
		    ( "<style>
		                text {
		                    font-family: 'Segoe UI', sans-serif;
		                    font-size: "
		        & _Em
		        & "px;
		                    font-weight: "
		        & _FontWeight
		        & ";
		                    dominant-baseline: central;
		                }
		            </style>" )
		
		// Hatched pattern definitions for green and red variance bars
		VAR _SVG_HatchedPatterns =
		    IF (
		        _IsHatched,
		        "/*hatched pattern*/
		                        <defs>
		                            <pattern id='hatch-green' patternUnits='userSpaceOnUse' width='8' height='8'>
		                                <rect x='0' y='0' width='8' height='8' fill='#FFFFFF' stroke-width='0' />
		                                <path d='M-2,2 l4,-4 M0,8 l8,-8 M6,10 l4,-4' style='stroke:"
		            & _ColorGreen
		            & "; stroke-width:2' />
		                            </pattern>
		                            <pattern id='hatch-red' patternUnits='userSpaceOnUse' width='8' height='8'>
		                                <rect x='0' y='0' width='8' height='8' fill='#FFFFFF' stroke-width='0' />
		                                <path d='M-2,2 l4,-4 M0,8 l8,-8 M6,10 l4,-4' style='stroke:"
		            & _ColorRed
		            & "; stroke-width:2' />
		                            </pattern>
		                        </defs>",
		        ""
		    )
		
		// Comment-based sort key injected into SVG for sorting by a column with embedded SVG
		VAR _SVG_SortBy = "/*SortBy:" & _Rank & "*/"
		
		// Debug overlay to visualize available drawing area
		VAR _SVG_DebugBox =
		    IF (
		        _DEBUG,
		        "<rect id='rect-debug-box' x='0%' y='0%' width='100%' height='100%' fill='#FFFFAA' stroke-width='1' stroke='#FF0000' />
		                    <rect id='rect-debug-box' x='0%' y='0%' width='50%' height='100%' fill='#FFFFAA' stroke-width='1' stroke='#FF0000' />",
		        ""
		    )
		
		// Axis Y line width (used for both grey and outlined variants)
		VAR _AxisWidth = _Em * 0.3
		
		// Zero baseline vertical line(s) at calculated position
		VAR _SVG_AxisY =
		    SWITCH (
		        baseType,
		        "outlined",
		            "<line id='line-axis-y-left' x1='"
		                & ( _AxisYPosition - _AxisWidth / 2 )
		                & "' x2='"
		                & ( _AxisYPosition - _AxisWidth / 2 )
		                & "' y1='0%' y2='100%' stroke='#000000' stroke-width='"
		                & _OutlineWidth
		                & "'></line>"
		                & "<line id='line-axis-y-right' x1='"
		                & ( _AxisYPosition + _AxisWidth / 2 )
		                & "' x2='"
		                & ( _AxisYPosition + _AxisWidth / 2 )
		                & "' y1='0%' y2='100%' stroke='#000000' stroke-width='"
		                & _OutlineWidth
		                & "'></line>",
		        -- default: grey
		        "<line id='line-axis-y' x1='" & _AxisYPosition & "' x2='"
		            & _AxisYPosition
		            & "' y1='0%' y2='100%' stroke='"
		            & _ColorGrey
		            & "' stroke-width='"
		            & _AxisWidth
		            & "'></line>"
		    )
		
		// Variance bar: extends right for positive, left for negative variance
		VAR _SVG_BarDeltaPY =
		    "<rect id='rect-bar-delta-py' x='" & _X & "' width='"
		        & _WidthValue
		        & "' y='"
		        & _mainBarYPosition
		        & "' height='"
		        & _Em
		        & "' fill='"
		        & _BarFill
		        & "' stroke='"
		        & _BarStroke
		        & "' stroke-width='"
		        & _OutlineWidth
		        & "'></rect>"
		
		// Data label positioned based on bar direction, with text-anchor for alignment
		VAR _SVG_TextDeltaPYLabel =
		    "<text id='text-delta-py-label' text-anchor='" & _Anchor
		        & "' x='"
		        & _XText
		        & "' dx='"
		        & _DX
		        & "' y='"
		        & ( imageHeight / 2 - _Em * 0.05 )
		        & "'>"
		        & dataLabel
		        & "</text>"
		
		// Data label for total rows (centered at the baseline)
		VAR _SVG_TextDeltaPYLabelTotal =
		    "<text id='text-delta-py-total-label' text-anchor='middle' x='"
		        & _AxisYPosition
		        & "' dx='0' y='50%'>"
		        & dataLabel
		        & "</text>"
		
		// SVG markup for total rows (label only, no chart)
		VAR _SVG_Total =
		    _SVG_Header & _SVG_Open & _SVG_DebugBox & _SVG_Style
		        & _SVG_TextDeltaPYLabelTotal
		        & _SVG_Close
		
		// SVG markup for detail rows (with all chart elements)
		VAR _SVG_Row =
		    _SVG_Header & _SVG_Open & _SVG_Style & _SVG_SortBy
		        & _SVG_DebugBox
		        & _SVG_HatchedPatterns
		        & _SVG_AxisY
		        & _SVG_BarDeltaPY
		        & _SVG_TextDeltaPYLabel
		        & _SVG_Close
		VAR _Result = IF ( _IsTotalRow, _SVG_Total, _SVG_Row )
		RETURN
		    _Result
	lineageTag: 05e209cb-e22b-42d4-849b-496833bce29f

	annotation DAXLIB_PackageId = PowerofBI.IBCS

	annotation DAXLIB_PackageVersion = 0.11.0

/// Creates a bar chart that shows the relative (%) variance between two values
/// @param {anyref} dimensionColumn - dimension in the rows: 'Payment Mode'[Payment Mode]
/// @param {scalar} mainValueExpr - main value (actuals): [AC]
/// @param {scalar} secondValueExpr - secondary value (forecast), can be BLANK() if not used: [FC] or BLANK()
/// @param {scalar} baseValueExpr - base value (previous year, budget) for comparison: [PY] or [BU]
/// @param {string} baseType - axis Y line styling: "grey" (single thick grey line) or "outlined" (two thin black lines)
/// @param {boolean} totalRow - is it a Total row: NOT ( ISINSCOPE ( 'Payment Mode'[Payment Mode] ) )
/// @param {string} dataLabel - formatted data label: FORMAT ( DIVIDE ( [AC] + [FC] - [PY], [PY] ) * 100, "+#,0;-#,0;=" )
/// @param {int64} imageWidth - image width, same as on the Format pane: 350
/// @param {int64} imageHeight - image height, same as on the Format pane: 35
/// @param {int64} businessImpact - business impact of variance > 0: 1 (positive, sales) or -1 (negative, cost)
/// @returns SVG image (data:image/svg+xml URI for embedding in table cells)
function 'PowerofBI.IBCS.BarChart.RelativeVariance' =
		
		(
		    // dimension in the rows: 'Payment Mode'[Payment Mode]
		    dimensionColumn: ANYREF EXPR,
		    // main value (actuals): [AC]
		    mainValueExpr: SCALAR EXPR,
		    // secondary value (forecast), can be BLANK() if not used: [FC] or BLANK()
		    secondValueExpr: SCALAR EXPR,
		    // base value (previous year, budget) for comparison: [PY] or [BU]
		    baseValueExpr: SCALAR EXPR,
		    // axis Y line styling: "grey" (single thick grey line) or "outlined" (two thin black lines)
		    baseType: STRING VAL,
		    // is it a Total row: NOT ( ISINSCOPE ( 'Payment Mode'[Payment Mode] ) )
		    totalRow: BOOLEAN VAL,
		    // formatted data label: FORMAT ( DIVIDE ( [AC] + [FC] - [PY], [PY] ) * 100, "+#,0;-#,0;=" )
		    dataLabel: STRING VAL,
		    // image width, same as on the Format pane: 350
		    imageWidth: INT64 VAL,
		    // image height, same as on the Format pane: 35
		    imageHeight: INT64 VAL,
		    // business impact of variance > 0: 1 (positive, sales) or -1 (negative, cost)
		    businessImpact: INT64 VAL
		) =>
		//=================================================================================================
		// Project: PowerofBI.IBCS: IBCS-guided data visualizations in your Power BI reports
		// Project Description: https://www.powerofbi.org/ibcs
		// DAX Lib package: https://daxlib.org/package/PowerofBI.IBCS/
		// PowerofBI.IBCS support: https://github.com/avatorl/dax-udf-svg-ibcs/issues
		// Author: Andrzej Leszkiewicz — IBCS® Certified Analyst
		// LinkedIn: https://www.linkedin.com/in/avatorl/
		// The visualization design adheres to IBCS recommendations: https://www.ibcs.com/ibcs-standards-1-2/
		//      but is NOT produced, certified, authorized, or endorsed by IBCS®
		//=================================================================================================
		// License: MIT License (free and permissive)
		// https://en.wikipedia.org/wiki/MIT_License
		//=================================================================================================
		//
		//=================================================================================================
		// CONFIGURATION and CALCULATIONS
		//=================================================================================================
		// When = 1, draws a rectangle showing the SVG boundaries (useful during layout tuning)
		VAR _DEBUG = 0
		
		// PY (previous year): neutral grey reference fill
		VAR _ColorGrey = "#C6C6C6"
		
		// Unfavorable business impact
		VAR _ColorRed = "#E24B20"
		
		// Favorable business impact
		VAR _ColorGreen = "#08787D"
		
		// Outline width applied to bar borders
		VAR _OutlineWidth = 0.5
		
		// Combined value (actuals + forecast); BLANK() is treated as 0
		VAR _ValueCombined =
		    mainValueExpr + secondValueExpr
		
		// Special case: NEW item (positive combined value with no base for comparison)
		VAR _IsNew =
		    _ValueCombined > 0
		        && ( baseValueExpr = 0
		        || ISBLANK ( baseValueExpr ) )
		
		// Variance between combined value and base ([AC] + [FC] - [PY])
		VAR _Variance = _ValueCombined - baseValueExpr
		
		// Whether the pinhead should be hatched (secondary value is present)
		VAR _IsHatched = NOT ISBLANK ( secondValueExpr )
		
		// Variance between combined value and base in %
		VAR _VariancePct =
		    ROUND (
		        DIVIDE ( _Variance, baseValueExpr ) * 100,
		        0
		    )
		
		// Minimum variance across the entire dimension (ALLSELECTED)
		VAR _ValueMin =
		    MINX (
		        ALLSELECTED ( dimensionColumn ),
		        CALCULATE (
		            mainValueExpr + secondValueExpr
		        )
		            - CALCULATE ( baseValueExpr )
		    )
		
		// Maximum variance across the entire dimension (ALLSELECTED)
		VAR _ValueMax = 100
		
		
		// Enables sorting in Power BI by embedding a sortable rank inside the SVG code
		VAR _Rank =
		    1000000000000 + ROUND ( _Variance + ABS ( _ValueMin ), 0 )
		
		// Caps extremely large variances at ±100% for visual consistency
		VAR _ValueFix =
		    SIGN ( _VariancePct ) * MIN ( 100, ABS ( _VariancePct ) )
		
		// Whether the variance exceeds ±100% (outlier)
		VAR _IsOutlier = ABS ( _VariancePct ) > 100
		
		// Font size in px (also determines size and positioning of other chart elements)
		VAR _Em = imageHeight * 0.6
		
		// Is it a total row?
		VAR _IsTotalRow = totalRow
		
		// Total rows are emphasized with bold text
		VAR _FontWeight = IF ( _IsTotalRow, "bold", "normal" )
		
		// Horizontal space available for rendering the pin
		VAR _SVG_ColumnWidth = imageWidth - _Em * 3
		
		// X-position of the zero baseline in the diverging bar chart
		VAR _AxisYPosition = imageWidth / 2
		
		// Pin length representing variance magnitude (capped at 100%)
		VAR _WidthValue =
		    ROUND (
		        DIVIDE ( ABS ( _ValueFix ), _ValueMax ) * _SVG_ColumnWidth
		            * 0.28,
		        0
		    )
		
		// Green for favorable, red for unfavorable (flipped by businessImpact)
		VAR _BarColor =
		    IF ( _Variance * businessImpact > 0, _ColorGreen, _ColorRed )
		
		// Starting X-coordinate for the pin bar
		VAR _X =
		    SWITCH (
		        TRUE ( ),
		        _Variance >= 0, _AxisYPosition,
		        _Variance < 0, _AxisYPosition - _WidthValue
		    )
		
		// X-position of the rectangular pin head
		VAR _XPinhead =
		    SWITCH (
		        TRUE ( ),
		        _Variance >= 0, _AxisYPosition + _WidthValue - _Em * 0.4,
		        _Variance < 0, _AxisYPosition - _WidthValue - _Em * 0.3
		    )
		
		// Text anchor: determines horizontal alignment of the data label
		VAR _Anchor =
		    IF (
		        _IsTotalRow,
		        "middle",
		        IF ( _Variance >= 0 || _IsNew, "start", "end" )
		    )
		
		// X-position for the data label: at triangle edge for outliers, at pinhead for normal
		VAR _LabelX =
		    SWITCH (
		        TRUE ( ),
		        _IsNew, _AxisYPosition,
		        _IsOutlier && _Variance >= 0, _AxisYPosition + _WidthValue,
		        _IsOutlier && _Variance < 0, _AxisYPosition - _WidthValue,
		        _XPinhead
		    )
		
		// Horizontal offset of the data label relative to the anchor
		VAR _DX =
		    SWITCH (
		        TRUE ( ),
		        _IsNew, _Em * 0.3,
		        _IsOutlier && _Variance >= 0, _Em * 0.65,
		        _IsOutlier && _Variance < 0, -_Em * 0.65,
		        _Variance >= 0, _Em * 0.7 + 5,
		        -5
		    )
		
		// Actual text to display: "NEW" for new items, dataLabel otherwise
		VAR _LabelText = IF ( _IsNew, "NEW", dataLabel )
		
		//=================================================================================================
		// SVG GENERATION: Build all SVG components
		//=================================================================================================
		VAR _SVG_Header = "data:image/svg+xml;utf8,"
		VAR _SVG_Open =
		    "<svg xmlns='http://www.w3.org/2000/svg' width='"
		        & imageWidth
		        & "' height='"
		        & imageHeight
		        & "'"
		        & " >"
		VAR _SVG_Close = "</svg>"
		VAR _SVG_Style =
		    ( "<style>
		            text {
		                font-family: 'Segoe UI', sans-serif;
		                font-size: "
		        & _Em
		        & "px;
		                font-weight: "
		        & _FontWeight
		        & ";
		                dominant-baseline: central;
		            }
		        </style>" )
		
		
		// Hatched pattern definition for pinhead
		VAR _SVG_HatchedPattern =
		    IF (
		        _IsHatched,
		        "/*hatched pattern*/
		                    <defs>
		                        <pattern id='diagonal-stripe' patternUnits='userSpaceOnUse' width='8' height='8'>
		                            <rect x='0' y='0' width='8' height='8' fill='#FFFFFF' stroke-width='0' />
		                            <path d='M-2,2 l4,-4 M0,8 l8,-8 M6,10 l4,-4' style='stroke:black; stroke-width:2' />
		                        </pattern>
		                    </defs>",
		        ""
		    )
		
		// Comment-based sort key
		VAR _SVG_SortBy = "/*SortBy:" & _Rank & "*/"
		
		// Debug overlay
		VAR _SVG_DebugBox =
		    IF (
		        _DEBUG,
		        "<rect id='rect-debug-box' x='0%' y='0%' width='100%' height='100%' fill='#FFFFAA' stroke-width='1' stroke='#FF0000' />
		         <rect id='rect-debug-box' x='0%' y='0%' width='"
		            & imageWidth
		            & "' height='100%' fill='#FFFFAA' stroke-width='1' stroke='#FF0000' />
		         <rect id='rect-debug-box' x='0%' y='0%' width='"
		            & imageWidth / 2
		            & "' height='100%' fill='#FFFFAA' stroke-width='1' stroke='#FF0000' />",
		        ""
		    )
		
		// Axis Y line width
		VAR _AxisWidth = _Em * 0.3
		
		// Zero baseline vertical line(s)
		VAR _SVG_AxisY =
		    SWITCH (
		        baseType,
		        "outlined",
		            "<line id='line-axis-y-left' x1='"
		                & ( _AxisYPosition - _AxisWidth / 2 )
		                & "' x2='"
		                & ( _AxisYPosition - _AxisWidth / 2 )
		                & "' y1='0%' y2='100%' stroke='#000000' stroke-width='"
		                & _OutlineWidth
		                & "'></line>"
		                & "<line id='line-axis-y-right' x1='"
		                & ( _AxisYPosition + _AxisWidth / 2 )
		                & "' x2='"
		                & ( _AxisYPosition + _AxisWidth / 2 )
		                & "' y1='0%' y2='100%' stroke='#000000' stroke-width='"
		                & _OutlineWidth
		                & "'></line>",
		        -- default: grey
		        "<line id='line-axis-y' x1='" & _AxisYPosition & "' x2='"
		            & _AxisYPosition
		            & "' y1='0%' y2='100%' stroke='"
		            & _ColorGrey
		            & "' stroke-width='"
		            & _AxisWidth
		            & "'></line>"
		    )
		
		// Pin bar: thin colored bar representing variance magnitude
		VAR _SVG_BarDeltaPY =
		    "<rect id='rect-variance-pin' x='" & _X & "' width='"
		        & _WidthValue
		        & "' y='"
		        & ( _Em * 0.6 + 2 )
		        & "' height='"
		        & _Em * 0.3
		        & "' fill='"
		        & _BarColor
		        & "' stroke='white' stroke-width='0.5'></rect>"
		
		// Pinhead fill: hatched when secondary value is present, solid black otherwise
		VAR _PinheadFill =
		    IF ( _IsHatched, "url(#diagonal-stripe)", "#404040" )
		
		// Pinhead stroke
		VAR _PinheadStroke = IF ( _IsHatched, "#404040", "none" )
		
		// Pin head marker (solid or hatched rectangle)
		VAR _SVG_PinHead =
		    "<rect id='rect-pinhead' x='" & _XPinhead & "' width='"
		        & _Em * 0.7
		        & "' y='"
		        & ( _Em * 0.3 + 2 )
		        & "' height='"
		        & _Em * 0.9
		        & "' fill='"
		        & _PinheadFill
		        & "' stroke='"
		        & _PinheadStroke
		        & "' stroke-width='"
		        & _OutlineWidth
		        & "'></rect>"
		
		// Data label positioned next to pin or outlier triangle
		VAR _SVG_TextDeltaPYLabel =
		    "<text id='text-label' text-anchor='" & _Anchor & "' x='"
		        & _LabelX
		        & "' dx='"
		        & _DX
		        & "' y='"
		        & ( imageHeight / 2 - _Em * 0.05 )
		        & "'>"
		        & _LabelText
		        & "</text>"
		
		// Outlier triangle marker for variances exceeding ±100%
		VAR _SVG_Outlier =
		    IF (
		        _Variance >= 0,
		        "<text id='markoutlier' dominant-baseline='central' text-anchor='start' x='"
		            & ( _AxisYPosition + _WidthValue )
		            & "' fill='"
		            & _BarColor
		            & "' y='"
		            & ( imageHeight / 2 - _Em * 0.05 )
		            & "'>"
		            & UNICHAR ( 9656 )
		            & "</text>",
		        "<text id='markoutlier' dominant-baseline='central' text-anchor='end' x='"
		            & ( _AxisYPosition - _WidthValue )
		            & "' fill='"
		            & _BarColor
		            & "' y='"
		            & ( imageHeight / 2 - _Em * 0.05 )
		            & "'>"
		            & UNICHAR ( 9666 )
		            & "</text>"
		    )
		
		// Choose between pin head or outlier marker
		VAR _SVG_PinHeadX =
		    IF (
		        _IsNew,
		        "",
		        IF (
		            ISBLANK ( _VariancePct ),
		            "",
		            IF ( _IsOutlier, _SVG_Outlier, _SVG_PinHead )
		        )
		    )
		
		// Data label for total rows (centered at the baseline)
		VAR _SVG_TextDeltaPYLabelTotal =
		    "<text id='text-label-total' text-anchor='middle' x='"
		        & _AxisYPosition
		        & "' y='50%'>"
		        & _LabelText
		        & "</text>"
		
		// SVG markup for total rows (label only, no chart)
		VAR _SVG_Total =
		    _SVG_Header & _SVG_Open & _SVG_Style & _SVG_DebugBox
		        & _SVG_TextDeltaPYLabelTotal
		        & _SVG_Close
		
		// SVG markup for detail rows (with all chart elements)
		VAR _SVG_Row =
		    _SVG_Header & _SVG_Open & _SVG_Style & _SVG_SortBy
		        & _SVG_DebugBox
		        & _SVG_HatchedPattern
		        & _SVG_AxisY
		        & _SVG_PinHeadX
		        & _SVG_BarDeltaPY
		        & _SVG_TextDeltaPYLabel
		        & _SVG_Close
		VAR _Result = IF ( _IsTotalRow, _SVG_Total, _SVG_Row )
		RETURN
		    _Result
	lineageTag: 395372c2-d9ca-4b07-aae5-3903fce99b07

	annotation DAXLIB_PackageId = PowerofBI.IBCS

	annotation DAXLIB_PackageVersion = 0.11.0

/// Creates a column chart that shows actual values, previous period values, plan, forecast and variance bars
/// @param {scalar} actualValueExpr
/// usage example: [AC] (actual value, e.g., 5000)
/// @param {scalar} previousYearValueExpr
/// usage example: [PY] (previous year value, e.g., 4500)
/// @param {scalar} planValueExpr
/// usage example: [PL] (plan/budget value, e.g., 4800)
/// @param {scalar} forecastValueExpr
/// usage example: [FC] (forecast value, e.g., 5200)
/// @param {anyref} periodColumn
/// usage example: 'Date'[Month] (column that holds period for X-axis)
/// @param {int64} businessImpact
/// usage example: 1 (business impact of variance > 0: 1 = positive e.g. sales, -1 = negative e.g. cost; inverts color only, not bar position)
/// @returns SVG image (data:image/svg+xml URI for embedding in table cells)
function 'PowerofBI.IBCS.ColumnChart.WithAbsoluteVariance' =
		
		(
		    // Actual Value
		    actualValueExpr: SCALAR EXPR,
		    // Previous Year Value
		    previousYearValueExpr: SCALAR EXPR,
		    // Plan (Budget) Value
		    planValueExpr: SCALAR EXPR,
		    // Forecast Value
		    forecastValueExpr: SCALAR EXPR,
		    // Column that holds period (Month)
		    periodColumn: ANYREF EXPR,
		    // business impact of variance > 0: 1 (positive, sales) or -1 (negative, cost)
		    businessImpact: INT64 VAL
		) =>
		//=================================================================================================
		// Project: PowerofBI.IBCS: IBCS-guided data visualizations in your Power BI reports
		// Project Description: https://www.powerofbi.org/ibcs
		// DAX Lib package: https://daxlib.org/package/PowerofBI.IBCS/
		// PowerofBI.IBCS support: https://github.com/avatorl/dax-udf-svg-ibcs/issues
		// Author: Andrzej Leszkiewicz \u2014 IBCS\u00ae Certified Analyst
		// LinkedIn: https://www.linkedin.com/in/avatorl/
		// The visualization design adheres to IBCS recommendations: https://www.ibcs.com/ibcs-standards-1-2/
		//      but is NOT produced, certified, authorized, or endorsed by IBCS\u00ae
		//=================================================================================================
		// License: MIT License (free and permissive)
		// https://en.wikipedia.org/wiki/MIT_License
		//=================================================================================================
		//=================================================================================================
		// PowerofBI.IBCS.ColumnChart.WithAbsoluteVariance function:
		//   This UDF renders an IBCS-styled vertical column chart for monthly values with variance markers.
		//
		//   Features include:
		//     \u2022 Actuals as solid black columns; forecasts as hatched columns when actuals are blank
		//     \u2022 Plan (budget) as outlined white columns and previous year as grey triangles
		//     \u2022 Red/green variance bar comparing AC/FC against plan
		//     \u2022 Data labels above bars and period labels beneath the plot, scaled across ALLSELECTED periods
		//     \u2022 businessImpact parameter: -1 inverts color semantics (cost KPIs)
		//=================================================================================================
		//===============================================
		// 1. INPUT CALCULATIONS AND CONTEXT
		//===============================================
		
		VAR valueACFC =
		    // Use Actual if available, otherwise Forecast
		    COALESCE (
		        actualValueExpr,
		        forecastValueExpr
		    )
		VAR _AllPeriods =
		// Get all selected months (for max scaling)
		ALLSELECTED ( periodColumn )
		VAR _Period =
		// Current period (Month)
		SELECTEDVALUE ( periodColumn )
		VAR _MaxValue =
		    // Find maximum value among AC, FC, PL, PY across all selected periods (for chart scaling)
		    MAXX (
		        _AllPeriods,
		        MAXX (
		            {
		                CALCULATE ( previousYearValueExpr ),
		                CALCULATE ( planValueExpr ),
		                CALCULATE ( actualValueExpr ),
		                CALCULATE ( forecastValueExpr )
		            },
		            [Value]
		        )
		    )
		VAR _MainScenario =
		    // Define whether we're in Actuals or Forecast mode
		    IF ( ISBLANK ( actualValueExpr ), "FC", "AC" )
		
		//===============================================
		// 2. FORMATTING CONFIGURATION
		//===============================================
		// When = 1, draws a debug rectangle showing the SVG boundaries (useful during layout tuning)
		VAR _DEBUG = 0
		
		// AC (actuals): solid dark fill
		VAR _ColorBlack = "#404040"
		// PY (previous year): neutral grey reference fill
		VAR _ColorGrey = "#C6C6C6"
		// Unfavorable business impact
		VAR _ColorRed = "#E24B20"
		// Favorable business impact
		VAR _ColorGreen = "#08787D"
		VAR _FontSizePt = 16
		VAR _Em = _FontSizePt * 4 / 3
		VAR _SVGHeight = 300
		VAR _SVGWidth = 46
		VAR _Margin = 10
		VAR _CategoryWidth = _SVGWidth + _Margin
		VAR _HeaderHeight = _Em * 1.5
		VAR _FooterHeight = _Em * 1.5
		VAR _ColumnWidth = _CategoryWidth * 2 / 3
		VAR _ColumnShift = _CategoryWidth * 1 / 9
		VAR _SVG_Body = _SVGHeight - _HeaderHeight - _FooterHeight
		
		//===============================================
		// 3. VALUE-TO-PIXEL CONVERSIONS
		//===============================================
		
		VAR _HeightACFC = ( valueACFC / _MaxValue ) * _SVG_Body
		VAR _YACFC = _SVG_Body - _HeightACFC + _HeaderHeight
		VAR _HeightPL =
		    ( planValueExpr / _MaxValue ) * _SVG_Body
		VAR _YPL = _SVG_Body - _HeightPL + _HeaderHeight
		VAR _HeightPY =
		    ( previousYearValueExpr / _MaxValue ) * _SVG_Body
		VAR _YPY = _SVG_Body - _HeightPY + _HeaderHeight
		
		//===============================================
		// 4. SVG LAYOUT & DEFINITIONS
		//===============================================
		
		VAR _SVG_Header = "data:image/svg+xml;utf8,"
		VAR _SVG_Open =
		    "<svg xmlns='http://www.w3.org/2000/svg' height='300'>"
		VAR _SVG_Close = "</svg>"
		VAR _SVG_Style =
		    "
					    <style>
					      <![CDATA[
					        text {
					          font-family: 'Segoe UI', sans-serif;
					          font-size: "
		        & _FontSizePt
		        & "pt;
					          dominant-baseline: central;
					        }
					      ]]>
					    </style>"
		VAR SVG_HatchedPattern =
		    "
					    <defs>
					      <pattern id='diagonal-stripe' patternUnits='userSpaceOnUse' width='4' height='4'>
					        <rect x='0' y='0' width='4' height='4' fill='#FFFFFF' stroke-width='0'/>
					        <path d='M-1,1 l2,-2 M0,4 l4,-4 M3,5 l2,-2' style='stroke:black; stroke-width:1' />
					      </pattern>
					    </defs>"
		
		
		
		
		
		
		
		
		
		
		
		
		
		//===============================================
		// 5. CHART ELEMENTS (SVG PRIMITIVES)
		//===============================================
		
		VAR _SVGvaluePL =
		    "<rect x='1' width='" & _ColumnWidth & "' y='" & _YPL
		        & "' height='"
		        & _HeightPL
		        & "' stroke-width='1' stroke='#000000' fill='#FFFFFF'></rect>"
		VAR _SVGvalueACFC =
		    "<rect x='" & 1 + _ColumnShift & "' width='" & _ColumnWidth
		        & "' y='"
		        & _YACFC
		        & "' height='"
		        & _HeightACFC
		        & "' stroke-width='1' stroke='#000000' fill='"
		        & IF (
		            _MainScenario = "AC",
		            _ColorBlack,
		            "url(#diagonal-stripe)"
		        )
		        & "'></rect>"
		
		// Variance color (flipped by businessImpact)
		VAR _VarianceColor =
		    IF (
		        ( valueACFC - planValueExpr ) * businessImpact >= 0,
		        _ColorGreen,
		        _ColorRed
		    )
		VAR _SVG_Variance =
		    "<rect x='"
		        & IF (
		            valueACFC >= planValueExpr,
		            1,
		            1 + _ColumnWidth
		        )
		        & "' width='"
		        & _ColumnShift
		        & "' y='"
		        & MIN ( _YACFC, _YPL )
		        & "' height='"
		        & ABS ( _YACFC - _YPL )
		        & "' stroke-width='1' stroke='"
		        & _VarianceColor
		        & "' fill='"
		        & _VarianceColor
		        & "'></rect>"
		VAR _SVGvaluePY =
		    "<defs><polygon id='Triangle' stroke-width='1.5' stroke='#FFFFFF' fill='"
		        & _ColorGrey
		        & "' points='0 0, 14 7, 0 14' /></defs>
					        <use x='0' y='"
		        & _YPY - 8
		        & "' href='#Triangle'/>"
		VAR _SVG_DataLabel =
		    "<text text-anchor='middle' x='"
		        & 1 + _ColumnShift + _ColumnWidth / 2
		        & "' y='"
		        & _YACFC - _Em * 0.8
		        & "' paint-order='stroke' stroke='#FFFFFF' stroke-width='3'>"
		        & valueACFC
		        & "</text>"
		VAR _SVG_PeriodLabel =
		    "<text text-anchor='middle' x='"
		        & 1 + _ColumnShift + _ColumnWidth / 2
		        & "' y='"
		        & _HeaderHeight + _SVG_Body + _Em * 0.8
		        & "' paint-order='stroke' stroke='#FFFFFF' stroke-width='1'>"
		        & _Period
		        & "</text>"
		
		//===============================================
		// 6. CONCATENATE SVG COMPONENTS
		//===============================================
		
		VAR _SVG_DebugBox =
		    IF (
		        _DEBUG,
		        "<rect id='rect-debug-box' x='0%' y='0%' width='100%' height='100%' fill='#FFFFAA' stroke-width='1' stroke='#FF0000' />",
		        ""
		    )
		VAR _SVG =
		    _SVG_Header & _SVG_Open & _SVG_DebugBox & _SVGvaluePL
		        & _SVGvalueACFC
		        & _SVG_Variance
		        & _SVGvaluePY
		        & _SVG_DataLabel
		        & _SVG_PeriodLabel
		        & _SVG_Style
		        & SVG_HatchedPattern
		        & _SVG_Close
		RETURN
		    _SVG
	lineageTag: 9e015d79-632a-4e4c-ba44-6f2c57bfa2b4

	annotation DAXLIB_PackageId = PowerofBI.IBCS

	annotation DAXLIB_PackageVersion = 0.11.0

/// Creates a pie chart (SVG image) showing percentage of total (e.g., "21%")
/// @param {double} valueMain
/// usage example: DIVIDE ( [AC], CALCULATE ( [AC], ALLSELECTED ( 'Payment Mode'[Payment Mode] ) ) ) (percentage as decimal, e.g., 0.25 for 25%)
/// @param {string} dataLabel
/// usage example: FORMAT ( valueMain, "#,0%" ) (formatted percentage label, e.g., "25%")
/// @param {boolean} isTotalRow
/// usage example: NOT ( ISINSCOPE ( 'Payment Mode'[Payment Mode] ) ) (indicates if row is a total row)
/// @param {boolean} showPieChart
/// usage example: TRUE () (toggle to display the pie chart or not)
/// @param {int64} fontSize
/// usage example: 0 (font size in points for data label; 0 = default 14pt)
/// @param {int64} imageWidth
/// usage example: 0 (default width 350px; use >0 for custom width in px)
/// @returns SVG image (data:image/svg+xml URI for embedding in table cells)
function 'PowerofBI.IBCS.Extras.PieChart.PctOfTotal' =
		
		(
		    // Main value as a decimal fraction (e.g., 0.21 for 21%)
		    valueMain: DOUBLE VAL,
		    // Text label to show, formatted value (e.g., "21%")
		    dataLabel: STRING VAL,
		    // Indicates whether the current row is a total row
		    isTotalRow: BOOLEAN VAL,
		    // Toggle to display the pie chart or not
		    showPieChart: BOOLEAN VAL,
		    // Font size in points (pt) for the data label and pie size
		    fontSize: INT64 VAL,
		    // Width of the image (0 = default)
		    imageWidth: INT64 VAL
		) =>
		//=================================================================================================
		// Project: PowerofBI.IBCS: IBCS-guided data visualizations in your Power BI reports
		// Project Description: https://www.powerofbi.org/ibcs
		// DAX Lib package: https://daxlib.org/package/PowerofBI.IBCS/
		// PowerofBI.IBCS support: https://github.com/avatorl/dax-udf-svg-ibcs/issues
		// Author: Andrzej Leszkiewicz \u2014 IBCS\u00ae Certified Analyst
		// LinkedIn: https://www.linkedin.com/in/avatorl/
		// The visualization design adheres to IBCS recommendations: https://www.ibcs.com/ibcs-standards-1-2/
		//      but is NOT produced, certified, authorized, or endorsed by IBCS\u00ae
		//=================================================================================================
		// License: MIT License (free and permissive)
		// https://en.wikipedia.org/wiki/MIT_License
		//=================================================================================================
		//=================================================================================================
		// PowerofBI.IBCS.Extras.PieChart.PctOfTotal function:
		//   This UDF generates a pie chart with a data label showing percentage of total.
		//
		//   Features include:
		//     \u2022 Optional pie chart rendering (toggle via showPieChart parameter)
		//     \u2022 Pie chart with grey background segment and dark fill for the selected share
		//     \u2022 Full circle rendering when percentage equals 100%
		//     \u2022 Data label in italic style, positioned to the left of the pie
		//     \u2022 Adjustable font size controls both label sizing and pie radius
		//     \u2022 Embedded sort key for stable ordering in Power BI visuals
		//=================================================================================================
		// When = 1, draws a debug rectangle showing the SVG boundaries (useful during layout tuning)
		VAR _DEBUG = 0
		
		// Default image width
		VAR _SVG_Width_Default = 350
		
		// Use specified image width or default
		VAR _SVG_Width =
		    IF ( imageWidth > 0, imageWidth, _SVG_Width_Default )
		
		// Font size (fallback to 14pt if not specified)
		VAR _FontSize = IF ( fontSize > 0, fontSize, 14 )
		
		// Font weight: bold for total rows, normal for others
		VAR _FontWeight = IF ( isTotalRow, "bold", "normal" )
		
		//===============================================
		// Color settings
		//===============================================
		// AC (actuals): solid dark fill (also used for pie segment and font)
		VAR _ColorBlack = "#404040"
		// Background color for unfilled pie segment
		VAR _PieBackgroudFillColor = "#E0E0E0"
		
		// Ranking value used for sorting in visuals (ensures consistent sort order)
		VAR _Rank = 1000000000000 + ROUND ( valueMain * 10000, 0 )
		
		//===============================================
		// SVG scaffolding
		//===============================================
		VAR _SVG_Header = "data:image/svg+xml;utf8,"
		VAR _SVG_Open =
		    "<svg xmlns='http://www.w3.org/2000/svg' width='"
		        & _SVG_Width
		        & "' >"
		VAR _SVG_Close = "</svg>"
		
		// Convert font size from pt to px (approximate conversion)
		VAR _Em = _FontSize * 4 / 3
		
		// Padding before the text
		VAR _LeftPadding = _Em * 2.5
		
		// Embedded CSS for SVG
		VAR _SVG_Style =
		    "<style>text{font-family:'Segoe UI', sans-serif;font-size:"
		        & _Em
		        & "px;font-weight:"
		        & _FontWeight
		        & ";font-style:italic;dominant-baseline:central;}</style>"
		
		// Hidden comment to support custom sort order in visuals
		VAR _SVG_SortBy = "/*SortBy:" & _Rank & "*/"
		
		// Debug overlay to visualize available drawing area
		VAR _SVG_DebugBox =
		    IF (
		        _DEBUG,
		        "<rect id='rect-debug-box' x='0' y='0' width='100%' height='100%' fill='#FFFFAA' stroke-width='1' stroke='#FF0000' />",
		        ""
		    )
		
		// SVG text element for the percentage label
		VAR _SVG_Text =
		    "<text x='" & _LeftPadding & "' y='50%' dy='2' fill='"
		        & _ColorBlack
		        & "' alignment-baseline='middle' text-anchor='end'>"
		        & dataLabel
		        & "</text>"
		
		// Pie chart rendering logic
		VAR _SVG_pie =
		    VAR Percentage = valueMain * 100
		
		    // Radius of the pie chart
		    VAR _R = _Em * 0.75
		
		    // Center X and Y coordinates for the pie chart
		    VAR CX = _R + _Em * 3
		    VAR CY = _R + 4
		
		    // Render full circle if 100%
		    VAR FullCircle =
		        "<circle cx='" & CX & "' cy='" & CY & "' r='" & _R
		            & "' fill='"
		            & _ColorBlack
		            & "'/>"
		
		    // Calculate angles for partial arc
		    VAR Angle = DIVIDE ( Percentage, 100 ) * 2 * PI ( )
		    VAR StartAngle = -PI ( ) / 2
		    VAR EndAngle = StartAngle + Angle
		
		    // Calculate arc endpoint coordinates
		    VAR X = CX + _R * COS ( EndAngle )
		    VAR Y = CY + _R * SIN ( EndAngle )
		
		    // SVG Arc flag: 1 if arc is greater than 180 degrees
		    VAR LargeArcFlag = IF ( Percentage > 50, 1, 0 )
		
		    // SVG path for pie chart segment (background + filled arc)
		    VAR Segment =
		        "<circle cx='" & CX & "' cy='" & CY & "' r='" & _R
		            & "' fill='"
		            & _PieBackgroudFillColor
		            & "' stroke='white' stroke-width='0.5'/>"
		            & "<path d='M"
		            & CX
		            & ","
		            & CY
		            & " L"
		            & CX
		            & ","
		            & CY - _R
		            & " A"
		            & _R
		            & ","
		            & _R
		            & " 0 "
		            & LargeArcFlag
		            & ",1 "
		            & X
		            & ","
		            & Y
		            & " Z' fill='"
		            & _ColorBlack
		            & "' stroke='white' stroke-width='0.5' />"
		
		    // Return full or partial pie chart if enabled
		    RETURN
		        IF (
		            showPieChart,
		            IF ( Percentage = 100, FullCircle, Segment ),
		            ""
		        )
		
		// Final SVG string (data URI)
		VAR _SVG =
		    _SVG_Header & _SVG_Open & _SVG_DebugBox & _SVG_Style
		        & _SVG_SortBy
		        & _SVG_Text
		        & _SVG_pie
		        & _SVG_Close
		
		// Output SVG
		RETURN
		    _SVG
	lineageTag: 2d81881e-4724-47b9-83f7-43deb32399d8

	annotation DAXLIB_PackageId = PowerofBI.IBCS

	annotation DAXLIB_PackageVersion = 0.11.0

/// Creates a stacked column SVG showing product-group contributions inside a single category column
/// @param {anyref} salesByProductGroupMeasure
/// usage example: [Sales by Product Group] (measure that returns sales for product group)
/// @param {anyref} productGroupColumn
/// usage example: 'Product Group'[Product Group] (column containing product group values)
/// @param {anyref} productGroupDisconnectedColumn
/// usage example: 'Product Group (disconnected)'[Product Group] (disconnected slicer column)
/// @param {anyref} periodColumn
/// usage example: 'Date'[Start of Month] (period column used for axis/label)
/// @param {int64} imageWidth
/// usage example: 0 (default width 60px; use >0 for custom width in px)
/// @param {int64} imageHeight
/// usage example: 0 (default height 320px; use >0 for custom height in px)
/// @returns SVG image (data:image/svg+xml URI for embedding in table cells)
function 'PowerofBI.IBCS.ColumnChart.Stacked' =
		
		(
		    // measure that returns sales for product group: [Sales by Product Group]
		    salesByProductGroupMeasure: ANYREF EXPR,
		    // column containing product group values: 'Product Group'[Product Group]
		    productGroupColumn: ANYREF EXPR,
		    // disconnected slicer column: 'Product Group (disconnected)'[Product Group]
		    productGroupDisconnectedColumn: ANYREF EXPR,
		    // period column used for axis/label: 'Date'[Start of Month]
		    periodColumn: ANYREF EXPR,
		    // image width, 0 = default 60px: 0
		    imageWidth: INT64 VAL,
		    // image height, 0 = default 320px: 0
		    imageHeight: INT64 VAL
		) =>
		//=================================================================================================
		// Project: PowerofBI.IBCS: IBCS-guided data visualizations in your Power BI reports
		// Project Description: https://www.powerofbi.org/ibcs
		// DAX Lib package: https://daxlib.org/package/PowerofBI.IBCS/
		// PowerofBI.IBCS support: https://github.com/avatorl/dax-udf-svg-ibcs/issues
		// Author: Andrzej Leszkiewicz — IBCS® Certified Analyst
		// LinkedIn: https://www.linkedin.com/in/avatorl/
		// The visualization design adheres to IBCS recommendations: https://www.ibcs.com/ibcs-standards-1-2/
		//      but is NOT produced, certified, authorized, or endorsed by IBCS®
		//=================================================================================================
		// License: MIT License (free and permissive)
		// https://en.wikipedia.org/wiki/MIT_License
		//=================================================================================================
		//=================================================================================================
		// PowerofBI.IBCS.ColumnChart.Stacked function:
		//   This UDF generates a compact stacked column SVG that visualizes contributions
		//   of product groups (top N + Other) inside a single period column.
		//
		//   Features include:
		//     • Stacked column segments with 5-shade grey color palette
		//     • Top-N ranking (default 3) with an “Other” bucket for remaining groups
		//     • Highlight of selected disconnected product group (uses distinct blue-grey color)
		//     • Value labels inside segments (adaptive font size based on segment height)
		//     • Group name labels on first period column only
		//     • Total value label (bold) positioned above the column
		//     • Period label (month abbreviation) below the column
		//     • Scales heights using ALLSELECTED across periods for consistent sizing
		//=================================================================================================
		// When = 1, draws a debug rectangle showing the SVG boundaries (useful during layout tuning)
		VAR _DEBUG = 0
		
		// Color palette for ranked segments (Idx 0 is the highlighted group)
		VAR _GreyTable =
		    DATATABLE (
		        "@Idx", INTEGER,
		        "@Color", STRING,
		        "@ColorText", STRING,
		        {
		            { 0, "#666688", "#FFFFFF" },
		            { 1, "#606060", "#FFFFFF" },
		            { 2, "#808080", "#FFFFFF" },
		            { 3, "#A0A0A0", "#FFFFFF" },
		            { 4, "#C0C0C0", "#333333" }
		        }
		    )
		
		//===============================================
		// Context & period helpers
		//===============================================
		// Disconnected slicer selection used to force a highlight color
		VAR _SelectedGroup =
		    SELECTEDVALUE ( productGroupDisconnectedColumn )
		
		// Flag: is there a selected group in the disconnected slicer
		VAR _HasSelectedGroup = NOT ISBLANK ( _SelectedGroup )
		
		// First period in the current selection (used for group labels)
		VAR _FirstPeriod =
		    MINX (
		        ALLSELECTED ( periodColumn ),
		        periodColumn
		    )
		
		// Only show group labels for the first period to reduce clutter
		VAR _IsFirstPeriod =
		    ISINSCOPE ( periodColumn )
		        && SELECTEDVALUE ( periodColumn ) = _FirstPeriod
		
		// Period label (short month) placed under the column
		VAR _PeriodLabel =
		    FORMAT ( SELECTEDVALUE ( periodColumn ), "mmm" )
		
		//===============================================
		// Product group totals
		//===============================================
		// Base table: totals for ranking + current period values for stacking
		VAR _ProductGroupTotals =
		    SUMMARIZECOLUMNS (
		        productGroupColumn,
		        "@TotalSales",
		            CALCULATE (
		                salesByProductGroupMeasure,
		                REMOVEFILTERS ( periodColumn )
		            ),
		        "@ThisPeriodSales", salesByProductGroupMeasure
		    )
		
		// Max period total used for scaling bar height across ALLSELECTED periods
		VAR _MaxValue =
		    VAR Months = ALLSELECTED ( periodColumn )
		    RETURN
		        MAXX (
		            Months,
		            CALCULATE ( salesByProductGroupMeasure )
		        )
		
		// Total for the current period (sum of all product groups)
		VAR _TotalValue =
		    SUMX ( _ProductGroupTotals, [@ThisPeriodSales] )
		
		//===============================================
		// SVG layout constants
		//===============================================
		// Typography
		VAR _FontSizePt = 12
		VAR _Em = _FontSizePt * 4 / 3
		
		// SVG dimensions (defaults for compact matrix cells)
		VAR _SVGHeight = IF ( imageHeight > 0, imageHeight, 320 )
		VAR _SVGWidth = IF ( imageWidth > 0, imageWidth, 60 )
		
		// Layout bands: header (value), body (bar), footer (period)
		VAR _HeaderHeight = _Em * 1.2
		VAR _FooterHeight = _Em * 1.2
		VAR _SVG_Body = _SVGHeight - _HeaderHeight - _FooterHeight
		
		// Column geometry
		VAR _ColumnWidth = ROUND ( _SVGWidth * 2 / 3, 0 )
		VAR _X = 1
		
		// Total bar height for the period (scaled by max period total)
		VAR _BarHeight =
		    MAX (
		        0,
		        MIN (
		            _SVG_Body,
		            INT ( DIVIDE ( _TotalValue, _MaxValue ) * _SVG_Body )
		        )
		    )
		
		// Vertical positions for the full stacked bar
		VAR _BarBottom = _HeaderHeight + _SVG_Body
		VAR _BarTop = _BarBottom - _BarHeight
		
		// Flag to suppress rendering when there is no usable data
		VAR _HasData = _TotalValue <> 0 && _MaxValue <> 0 && _BarHeight > 0
		
		//===============================================
		// Ranking and “Other” bucket
		//===============================================
		// Rank product groups by total sales (used for Top-N + Other)
		VAR RankedBase = ADDCOLUMNS ( _ProductGroupTotals, "@Rank", RANKX ( _ProductGroupTotals, [@TotalSales], , DESC, DENSE ) )
		
		// Number of product groups to show explicitly (others aggregated)
		VAR Limit = 3
		
		// Top-N groups + an “Other” row for the remainder
		VAR _RankedWithOther =
		    UNION (
		        SELECTCOLUMNS (
		            FILTER ( RankedBase, [@Rank] <= Limit ),
		            "@ProductGroup", productGroupColumn,
		            "@Sales", [@ThisPeriodSales],
		            "@Rank", [@Rank]
		        ),
		        SELECTCOLUMNS (
		            ROW (
		                "@ProductGroup", "Other",
		                "@Sales",
		                    SUMX (
		                        FILTER ( RankedBase, [@Rank] > Limit ),
		                        [@ThisPeriodSales]
		                    )
		            ),
		            "@ProductGroup", [@ProductGroup],
		            "@Sales", [@Sales],
		            "@Rank", Limit + 1
		        )
		    )
		
		// Default highlight is the largest group (lowest rank)
		VAR _LargestGroup =
		    MAXX (
		        TOPN ( 1, _RankedWithOther, [@Rank], ASC ),
		        [@ProductGroup]
		    )
		
		// Highlight selected group when present, otherwise use largest group
		VAR _HighlightGroup =
		    IF (
		        _HasSelectedGroup
		            && CONTAINS (
		                _RankedWithOther,
		                [@ProductGroup],
		                _SelectedGroup
		            ),
		        _SelectedGroup,
		        _LargestGroup
		    )
		
		// Assign index 0 to highlighted group for consistent color emphasis
		VAR _RankedWithOther_Indexed =
		    ADDCOLUMNS (
		        _RankedWithOther,
		        "@Idx", IF ( [@ProductGroup] = _HighlightGroup, 0, [@Rank] )
		    )
		
		//===============================================
		// SVG BUILD
		//===============================================
		// Build one SVG rect + label per segment
		VAR GeneratedTable =
		    GENERATE (
		        _RankedWithOther_Indexed,
		        VAR _Idx = [@Idx]
		        VAR _Sales = [@Sales]
		        VAR _Group = [@ProductGroup]
		
		        // Segment colors
		        VAR _Color =
		            MAXX ( FILTER ( _GreyTable, [@Idx] = _Idx ), [@Color] )
		
		        // Text color for the segment
		        VAR _ColorText =
		            MAXX ( FILTER ( _GreyTable, [@Idx] = _Idx ), [@ColorText] )
		
		        // Height already allocated below this segment
		        VAR _OffsetBelowPx =
		            SUMX (
		                FILTER ( _RankedWithOther_Indexed, [@Idx] < _Idx ),
		                INT ( DIVIDE ( [@Sales], _TotalValue ) * _BarHeight )
		            )
		
		        // Last segment absorbs rounding differences
		        VAR _LastIdx = MAXX ( _RankedWithOther_Indexed, [@Idx] )
		
		        // Height of this segment (in pixels)
		        VAR _HeightPx =
		            IF (
		                _Idx = _LastIdx,
		                _BarHeight - _OffsetBelowPx,
		                INT ( DIVIDE ( _Sales, _TotalValue ) * _BarHeight )
		            )
		
		        // Y position for this segment
		        VAR _Y = _BarBottom - _OffsetBelowPx - _HeightPx
		
		        // Adaptive font size for small segments
		        VAR _FontSize =
		            IF ( _HeightPx >= 10, MIN ( _HeightPx - 1, 12 ), 0 )
		
		        // Escape group label for safe SVG
		        VAR _GroupEscaped =
		            SUBSTITUTE (
		                SUBSTITUTE (
		                    SUBSTITUTE (
		                        SUBSTITUTE (
		                            SUBSTITUTE ( _Group, "&", "&amp;" ),
		                            "<",
		                            "&lt;"
		                        ),
		                        ">",
		                        "&gt;"
		                    ),
		                    """",
		                    "&quot;"
		                ),
		                "'",
		                "&apos;"
		            )
		        RETURN
		            ROW (
		                "RectSVG",
		                    IF (
		                        _HeightPx <= 0,
		                        "",
		                        "<rect x='" & _X & "' y='" & _Y & "' width='" & _ColumnWidth
		                            & "' height='"
		                            & _HeightPx
		                            & "' fill='"
		                            & _Color
		                            & "' stroke='white' />"
		                    ),
		                "TextSVG",
		                    IF (
		                        _HeightPx <= 0,
		                        "",
		                        IF (
		                            _IsFirstPeriod,
		                            "<text text-anchor='left' x='5' y='" & _Y + _FontSize * 0.8
		                                & "' font-size='"
		                                & _FontSize * 0.7
		                                & "'>"
		                                & _GroupEscaped
		                                & "</text>",
		                            ""
		                        )
		                            & "<text text-anchor='middle' x='"
		                            & _ColumnWidth / 2
		                            & "' y='"
		                            & _Y + _HeightPx / 2
		                            & "' fill='"
		                            & _ColorText
		                            & "' font-size='"
		                            & _FontSize
		                            & "'>"
		                            & FORMAT ( _Sales / 1E3, "#,0.0" )
		                            & "</text>"
		                    )
		            )
		    )
		
		// Assemble SVG fragments in rank order
		VAR _Rects =
		    CONCATENATEX ( GeneratedTable, [RectSVG], "", [@Idx], ASC )
		VAR _Texts =
		    CONCATENATEX ( GeneratedTable, [TextSVG], "", [@Idx], ASC )
		VAR _ProductRects = IF ( NOT _HasData, "", _Rects & _Texts )
		
		// SVG text styling (match other UDFs)
		VAR _SVG_Style =
		    "<style>text{font-family:'Segoe UI', sans-serif;}</style>"
		
		//===============================================
		// Final SVG
		//===============================================
		// Debug overlay to visualize available drawing area
		VAR _SVG_DebugBox =
		    IF (
		        _DEBUG,
		        "<rect id='rect-debug-box' x='0%' y='0%' width='100%' height='100%' fill='#FFFFAA' stroke-width='1' stroke='#FF0000' />",
		        ""
		    )
		VAR _SVG_Header = "data:image/svg+xml;utf8,"
		VAR _SVG_Open =
		    "<svg xmlns='http://www.w3.org/2000/svg' height='"
		        & _SVGHeight
		        & "' width='"
		        & _SVGWidth
		        & "'>"
		VAR _SVG_Close = "</svg>"
		
		// Final SVG: stacked bar + total label + period label
		VAR _SVG =
		    _SVG_Header & _SVG_Open & _SVG_DebugBox & _ProductRects
		        & "<text text-anchor='middle' x='"
		        & _ColumnWidth / 2
		        & "' y='"
		        & _BarTop - _Em * 0.3
		        & "' font-size='16' font-weight='bold'>"
		        & FORMAT ( _TotalValue / 1E3, "#,0.0" )
		        & "</text>"
		        & "<text text-anchor='middle' x='"
		        & _ColumnWidth / 2
		        & "' y='"
		        & _HeaderHeight + _SVG_Body + _Em * 0.8
		        & "'>"
		        & _PeriodLabel
		        & "</text>"
		        & _SVG_Style
		        & _SVG_Close
		RETURN
		    _SVG
	lineageTag: 93cc34fc-4d1a-41fa-8dc7-76c07e12831c

	annotation DAXLIB_PackageId = PowerofBI.IBCS

	annotation DAXLIB_PackageVersion = 0.11.0

/// Creates a waterfall chart showing monthly actual or forecast values vs previous year, including cumulative delta and variance pins for YTD or full-year comparisons.
/// Layout: 30% of image height for relative variance pins (clamped to -100..+100, outlier triangles beyond); 70% for columns + waterfall, scaled proportionally. Tier count controls which tiers are shown and how the remaining tiers scale.
/// When pTierCount = 1, includes colored variance bars between AC/FC and PY columns showing absolute difference (similar to WithAbsoluteVariance).
/// @param {string} pType
/// usage example: "AC" or "FC" (type of current column, actual or forecast)
/// @param {int64} pMonth
/// usage example: 5 (selected month number 1–12 for X-axis label)
/// @param {scalar} pValuePY
/// usage example: [PY] (monthly previous year value, e.g., 4500)
/// @param {scalar} pValueACFC
/// usage example: [AC] or [FC] (monthly actual or forecast value, e.g., 5000)
/// @param {scalar} pDeltaPYCumulative
/// usage example: CALCULATE ( SUM ( [DeltaPY] ), DATESBETWEEN ( ... ) ) (cumulative delta vs PY up to prior month for waterfall)
/// @param {scalar} pPYTotal
/// usage example: CALCULATE ( SUM ( [PY] ), ALLSELECTED ( 'Date'[Year] ) ) (total PY for full-year comparison)
/// @param {scalar} pACTotal
/// usage example: CALCULATE ( SUM ( [AC] ), ALLSELECTED ( 'Date'[Year] ) ) (total AC for full-year comparison)
/// @param {scalar} pFCTotal
/// usage example: CALCULATE ( SUM ( [FC] ), ALLSELECTED ( 'Date'[Year] ) ) (total FC for full-year comparison)
/// @param {scalar} pMaxValue
/// usage example: CALCULATE ( MAX ( MAX ( 'Fact'[PY] ), MAX ( 'Fact'[ACFC] ) ), ALLSELECTED ( 'Fact' ) ) (maximum monthly value across all months for column scaling)
/// @param {int64} pImageHeight
/// usage example: 0 (default height 620px; use >0 for custom height in px)
/// @param {int64} businessImpact
/// usage example: 1 (business impact of variance > 0: 1 = positive e.g. sales, -1 = negative e.g. cost; inverts color only, not bar position)
/// @param {int64} pTierCount
/// usage example: 0 (0 = responsive auto via CSS media queries, 3 = all tiers, 2 = columns+waterfall, 1 = columns+variance bars only)
function 'PowerofBI.IBCS.ColumnChart.WithWaterfall' = ```
		
		(
		    pType: STRING VAL,
		    pMonth: INT64 VAL,
		    pValuePY: SCALAR VAL,
		    pValueACFC: SCALAR VAL,
		    pDeltaPYCumulative: SCALAR VAL,
		    pPYTotal: SCALAR VAL,
		    pACTotal: SCALAR VAL,
		    pFCTotal: SCALAR VAL,
		    pMaxValue: SCALAR VAL,
		    pImageHeight: INT64 VAL,
		    businessImpact: INT64 VAL,
		    pTierCount: INT64 VAL
		)
		=>
		    //=================================================================================================
		    // Project: PowerofBI.IBCS: IBCS-guided data visualizations in your Power BI reports
		    // Project Description: https://www.powerofbi.org/ibcs
		    // DAX Lib package: https://daxlib.org/package/PowerofBI.IBCS/
		    // PowerofBI.IBCS support: https://github.com/avatorl/dax-udf-svg-ibcs/issues
		    // Author: Andrzej Leszkiewicz — IBCS® Certified Analyst
		    // LinkedIn: https://www.linkedin.com/in/avatorl/
		    // The visualization design adheres to IBCS recommendations: https://www.ibcs.com/ibcs-standards-1-2/
		    //      but is NOT produced, certified, authorized, or endorsed by IBCS®
		    //=================================================================================================
		    // License: MIT License (free and permissive)
		    // https://en.wikipedia.org/wiki/MIT_License
		    //=================================================================================================
		    //=================================================================================================
		    // PowerofBI.IBCS.ColumnChart.WithWaterfall function:
		    //   This UDF composes a multi-tier IBCS visual: monthly columns, an absolute-variance waterfall,
		    //   and relative-variance pins.
		    //
		    //   Tier modes (pTierCount):
		    //     • 3: all tiers — 30% relative variance + 70% columns/waterfall
		    //     • 2: columns + waterfall — 100% of height, no relative variance
		    //     • 1: columns + variance bars only — 100% of height, no waterfall or relative variance
		    //     • 0: responsive auto — draws at 3-tier proportions, CSS media queries
		    //       switch inner SVG viewports at 350px and 280px thresholds
		    //
		    //   Features include:
		    //     • X-axis line with month letter labels (J, F, M, etc.)
		    //     • Monthly columns: AC (solid black) or FC (hatched) with PY (grey) reference bars
		    //     • Value labels above each monthly column
		    //     • Waterfall bars for monthly ΔPY: green (positive) or red (negative), hatched for FC
		    //     • Cumulative connector lines between waterfall bars
		    //     • PY horizontal reference line spanning all months
		    //     • Year-total variance marker with value label
		    //     • Relative variance axis (grey baseline) with ΔPY% label
		    //     • Monthly variance pins with black/hatched pin heads (clamped ±100)
		    //     • Outlier triangles when ΔPY% exceeds ±100 range
		    //     • Total relative variance pin for year-end comparison
		    //     • businessImpact parameter: -1 inverts color semantics (cost KPIs)
		    //     • Variance bars in tier-1 mode: colored bars between AC/FC and PY columns
		    //=================================================================================================
		
		    //===============================================
		    // PARAM BINDINGS (no external refs)
		    //===============================================
		    VAR _Type                 = pType
		    VAR _Month                = pMonth
		    VAR _ValuePY              = pValuePY
		    VAR _ValueACFC            = pValueACFC
		    VAR _DeltaPYCumulative    = pDeltaPYCumulative
		    VAR _PY_Value             = pPYTotal
		    VAR _AC_Value             = pACTotal
		    VAR _FC_Value             = pFCTotal
		    VAR _MaxValue             = pMaxValue
		    VAR _SVG_Height           = IF ( pImageHeight = 0, 620, pImageHeight )
		    VAR _TierCount            = pTierCount
		
		    // Derived values
		    VAR _DeltaPY   = _ValueACFC - _ValuePY
		    VAR DeltaPYPct = ROUND ( DIVIDE ( _ValueACFC - _ValuePY, _ValuePY ) * 100, 0 )
		
		    //===============================================
		    // TYPOGRAPHY AND COLUMN WIDTHS
		    //===============================================
		    VAR _OutlineStrokeWith   = 1
		    VAR _ReferenceLineWidth  = 0.2
		    VAR _FontSizePt          = 16
		    VAR _Em                  = _FontSizePt * 4 / 3
		    VAR _CategoryWidth       = _Em * 3
		    VAR _ColumnWidth         = _CategoryWidth * 2 / 3
		    VAR _CategoryWidthYear   = _Em * 4
		    VAR _ColumnWidthYear     = _CategoryWidthYear * 2 / 3
		    VAR _SVG_Width           = _CategoryWidthYear
		    VAR _ColumnsLeftOffset   = ( _SVG_Width - _ColumnWidth ) / 2
		    VAR _TotalCategoryPosition = _ColumnsLeftOffset + _CategoryWidthYear + 12 * _CategoryWidth
		    VAR _PinWidth            = _Em * 0.3
		    VAR _PinHeadWidth        = _Em * 0.7
		    VAR _RelativeAxisLineWidth = _Em * 0.3
		    VAR _BaseColumnShift     = - _Em * 0.3
		
		    //===============================================
		    // TIER LAYOUT
		    //===============================================
		    VAR _EffectiveTiers  = IF ( _TierCount = 0, 3, _TierCount )
		    VAR _RelTierH        = IF ( _EffectiveTiers >= 3, _SVG_Height * 0.30, 0 )
		    VAR _RelAxisY        = _RelTierH / 2
		    VAR _RelPinMax       = 100
		    VAR _RelLabelMargin  = _Em * 1.5
		    VAR _RelScale        = IF ( _RelTierH > 0, ( _RelTierH / 2 - _RelLabelMargin ) / _RelPinMax, 0 )
		    VAR _SVG_Bottom_Pad  = _Em * 1.5
		    VAR _AxisY           = _SVG_Height - _SVG_Bottom_Pad
		    VAR _LabelSpace      = 3 * _Em
		    VAR _ColAvailableH   = _SVG_Height - _RelTierH - _SVG_Bottom_Pad - _LabelSpace
		    VAR _ShowRelative    = _EffectiveTiers >= 3
		    VAR _ShowWaterfall   = _EffectiveTiers >= 2
		    VAR _WaterfallMax    = MAX ( _PY_Value, _AC_Value + _FC_Value )
		    VAR _ScaleDriver     = IF ( _ShowWaterfall, MAX ( _MaxValue, _WaterfallMax ), _MaxValue )
		    VAR _SVG_Scale       = DIVIDE ( _ScaleDriver, _ColAvailableH )
		    VAR _ThresholdTwoTier = 350
		    VAR _ThresholdOneTier = 280
		
		    //===============================================
		    // COLORS
		    //===============================================
		    VAR _ColorBlack = "#404040"
		    VAR _ColorLightGrey = "#A6A6A6"
		    VAR _ColorRed   = "#E24B20"
		    VAR _ColorGreen = "#08787D"
		
		    //===============================================
		    // SVG DECLARATION
		    //===============================================
		    VAR _DEBUG = 0
		
		    VAR _SVG_Header = "data:image/svg+xml;utf8,"
		    VAR _SVG_Open = IF (
		        _TierCount = 0,
		        "<svg xmlns='http://www.w3.org/2000/svg' x='0px' y='0px' width='" & _SVG_Width & "' height='" & _SVG_Height & "' style='width: " & _SVG_Width & "px; height: 100%; overflow: hidden'>",
		        "<svg xmlns='http://www.w3.org/2000/svg' x='0px' y='0px' width='" & _SVG_Width & "' height='" & _SVG_Height & "' viewBox='0 0 " & _SVG_Width & " " & _SVG_Height & "' preserveAspectRatio='xMidYMid meet' style='overflow: hidden'>"
		    )
		    VAR _SVG_Close = "</svg>"
		    VAR _SVG_DebugBox =
		        IF (
		            _DEBUG,
		            "<rect id='rect-debug-box' x='0%' y='0%' width='100%' height='100%' fill='#FFFFAA' stroke-width='1' stroke='#FF0000' />",
		            ""
		        )
		
		    VAR _SVG_Style =
		        "<style>
		        <![CDATA[
		          text{
		            font-family: 'Segoe UI', sans-serif;
		            font-size: " & ROUND ( _Em, 1 ) & "px;
		            dominant-baseline: middle;
		            text-anchor: middle;
		          }
		        ]]>
		      </style>"
		
		    //===============================================
		    // STYLE AND PATTERNS
		    //===============================================
		    VAR SVG_HatchedPattern_Template = "
		        <defs >
		        <pattern id='<name>' patternUnits='userSpaceOnUse' width='8' height='8'>
		            <rect x='0' y='0' width='8' height='8' fill='#FFFFFF' stroke-width='0'/>
		            <path d='
		                M-2,2 l4,-4
		                M0,8 l8,-8
		                M6,10 l4,-4'
		            style='stroke:<color>; stroke-width:2' />
		        </pattern>
		        </defs>"
		
		    VAR SVG_HatchedPattern =
		        SUBSTITUTE ( SUBSTITUTE ( SVG_HatchedPattern_Template, "<name>", "diagonal-stripe" ), "<color>", _ColorBlack )
		
		    VAR SVG_HatchedPatternRed =
		        SUBSTITUTE ( SUBSTITUTE ( SVG_HatchedPattern_Template, "<name>", "diagonal-stripe-red" ), "<color>", _ColorRed )
		
		    VAR SVG_HatchedPatternGreen =
		        SUBSTITUTE ( SUBSTITUTE ( SVG_HatchedPattern_Template, "<name>", "diagonal-stripe-green" ), "<color>", _ColorGreen )
		
		    VAR _SVG_STYLE_AND_PATTERNS =
		        _SVG_Style & SVG_HatchedPattern & SVG_HatchedPatternRed & SVG_HatchedPatternGreen
		
		    //===============================================
		    // RESPONSIVE: foreignObject (only used when _TierCount = 0)
		    //===============================================
		    VAR _SVG_ForeignObject =
		        "<foreignObject x='-9999' y='-9999' width='1' height='1'><body xmlns='http://www.w3.org/1999/xhtml'><style>"
		        & ".tier3 { display: block; } .tier2, .tier1 { display: none; }"
		        & " @media (max-height: " & _ThresholdTwoTier & "px) { .tier3 { display: none; } .tier2 { display: block; } .tier1 { display: none; } }"
		        & " @media (max-height: " & _ThresholdOneTier & "px) { .tier3 { display: none; } .tier2 { display: none; } .tier1 { display: block; } }"
		        & "</style></body></foreignObject>"
		
		    //===============================================
		    // AXIS X
		    //===============================================
		    VAR _AxisX =
		        "<line x1='" & 0 & "' x2='" & _SVG_Width & "' y1='" & _AxisY & "' y2='" & _AxisY & "' stroke='#000000' stroke-width='1'></line>"
		
		    VAR _AxisX_Labels =
		        VAR _Value = LEFT ( FORMAT ( DATE ( 2023, _Month, 1 ), "mmm" ), 1 )
		        RETURN
		            "<text x='" & _ColumnsLeftOffset + _ColumnWidth / 2 & "' y='" & _AxisY + _Em & "' stroke='#000000' stroke-width='0'>" & _Value & "</text>"
		
		    VAR _SVG_AxisX = _AxisX & _AxisX_Labels
		
		    //===============================================
		    // COLUMN CHART: MONTHS
		    //===============================================
		    VAR _PY_Columns =
		        VAR _Height = DIVIDE ( _ValuePY, _SVG_Scale )
		        RETURN
		            "<rect x='" & _ColumnsLeftOffset + _BaseColumnShift & "' y='" & _AxisY - _Height & "' height='" & _Height & "' width='" & _ColumnWidth & "' fill='" & _ColorLightGrey & "' stroke-width='0'></rect>"
		
		    VAR _ACFC_Columns =
		        VAR _Height = DIVIDE ( _ValueACFC, _SVG_Scale )
		        VAR _Fill =
		            SWITCH ( _Type, "AC", _ColorBlack, "FC", "url(#diagonal-stripe)" )
		        RETURN
		            "<rect x='" & _ColumnsLeftOffset & "' y='" & _AxisY - _Height & "' height='" & _Height & "' width='" & _ColumnWidth & "' fill='" & _Fill & "' stroke='#000000' stroke-width='" & _OutlineStrokeWith & "'></rect>"
		
		    VAR _ACFC_Labels =
		        VAR _Height = DIVIDE ( _ValueACFC, _SVG_Scale )
		        RETURN
		            "<text x='" & _ColumnsLeftOffset + _ColumnWidth / 2 & "' y='" & _AxisY - _Height - 15 & "'>" & _ValueACFC & "</text>"
		
		    VAR _SVG_ColumnChart_Month =
		        _PY_Columns & _ACFC_Columns & _ACFC_Labels
		
		    //===============================================
		    // VARIANCE BAR (AC/FC vs PY, shown in tier-1 mode)
		    // Thin colored bar showing absolute difference, similar to WithAbsoluteVariance
		    // Green (AC>=PY): left gap at PY left edge
		    // Red (AC<PY): right gap from PY right edge to AC right edge
		    //===============================================
		    VAR _VarBarWidth = ABS ( _BaseColumnShift )
		    VAR _HeightACFC_Var = DIVIDE ( _ValueACFC, _SVG_Scale )
		    VAR _HeightPY_Var = DIVIDE ( _ValuePY, _SVG_Scale )
		    VAR _Y_ACFC_Var = _AxisY - _HeightACFC_Var
		    VAR _Y_PY_Var = _AxisY - _HeightPY_Var
		    VAR _VarianceBarColor =
		        IF ( ( _ValueACFC - _ValuePY ) * businessImpact >= 0, _ColorGreen, _ColorRed )
		    VAR _VarianceBarX =
		        IF ( _ValueACFC >= _ValuePY,
		            _ColumnsLeftOffset + _BaseColumnShift,
		            _ColumnsLeftOffset + _BaseColumnShift + _ColumnWidth
		        )
		    VAR _SVG_VarianceBar =
		        "<rect x='" & _VarianceBarX & "' width='" & _VarBarWidth & "' y='" & MIN ( _Y_ACFC_Var, _Y_PY_Var ) & "' height='" & ABS ( _Y_ACFC_Var - _Y_PY_Var ) & "' fill='" & _VarianceBarColor & "' stroke='" & _VarianceBarColor & "' stroke-width='1'></rect>"
		
		    //===============================================
		    // WATERFALL (absolute variance)
		    //===============================================
		    VAR ACFCminusPY_Columns =
		        VAR _Cumulative = DIVIDE ( _PY_Value + _DeltaPYCumulative, _SVG_Scale )
		        VAR _Height = ABS ( DIVIDE ( _DeltaPY, _SVG_Scale ) )
		        VAR _Fill =
		            SWITCH (
		                TRUE (),
		                _Type = "AC" && _DeltaPY * businessImpact > 0, _ColorGreen,
		                _Type = "AC" && _DeltaPY * businessImpact < 0, _ColorRed,
		                _Type = "FC" && _DeltaPY * businessImpact > 0, "url(#diagonal-stripe-green)",
		                _Type = "FC" && _DeltaPY * businessImpact < 0, "url(#diagonal-stripe-red)",
		                _Type = "AC", _ColorRed,
		                "url(#diagonal-stripe-red)"
		            )
		        VAR _Stroke = SWITCH ( TRUE (), _DeltaPY * businessImpact > 0, _ColorGreen, _ColorRed )
		        RETURN
		            "<rect x='" & _ColumnsLeftOffset & "' y='" & _AxisY - _Cumulative + IF ( _DeltaPY > 0, - DIVIDE ( _DeltaPY, _SVG_Scale ), 0 ) & "' height='" & _Height & "' width='" & _ColumnWidth & "' fill='" & _Fill & "' stroke='" & _Stroke & "' stroke-width='" & _OutlineStrokeWith & "'></rect>"
		
		    VAR ACFCminusPY_Labels =
		        VAR _Cumulative = DIVIDE ( _PY_Value + _DeltaPYCumulative, _SVG_Scale )
		        RETURN
		            "<text x='" & _ColumnsLeftOffset + _ColumnWidth / 2 & "' y='" & _AxisY - _Cumulative + IF ( _DeltaPY > 0, - DIVIDE ( _DeltaPY, _SVG_Scale ) - 15, - DIVIDE ( _DeltaPY, _SVG_Scale ) + 15 ) & "'>" & FORMAT ( _DeltaPY, "+0;-0;0" ) & "</text>"
		
		    VAR ACFCminusPY_Lines =
		        VAR _Cumulative = DIVIDE ( _PY_Value + _DeltaPYCumulative, _SVG_Scale )
		        RETURN
		            "<line x1='" & _ColumnsLeftOffset + _ColumnWidth & "' x2='" & _ColumnsLeftOffset + _CategoryWidth + _ColumnsLeftOffset & "' y1='" & _AxisY - _Cumulative + IF ( _DeltaPY < 0, - DIVIDE ( _DeltaPY, _SVG_Scale ), - DIVIDE ( _DeltaPY, _SVG_Scale ) ) & "'  y2='" & _AxisY - _Cumulative + IF ( _DeltaPY < 0, - DIVIDE ( _DeltaPY, _SVG_Scale ), - DIVIDE ( _DeltaPY, _SVG_Scale ) ) & "' stroke='#000000' stroke-width='" & _ReferenceLineWidth & "'></line>"
		
		    VAR _LinePY =
		        "<line x1='86' x2='" & _TotalCategoryPosition + _CategoryWidthYear & "' y1='" & _AxisY - DIVIDE ( _PY_Value, _SVG_Scale ) & "' y2='" & _AxisY - DIVIDE ( _PY_Value, _SVG_Scale ) & "' stroke='#000000' stroke-width='" & _ReferenceLineWidth & "'></line>"
		
		    VAR _LineACFC =
		        "<line x1='" & _ColumnsLeftOffset + 13 * _CategoryWidth & "' x2='" & _TotalCategoryPosition + _CategoryWidthYear & "' y1='" & _AxisY - DIVIDE ( _AC_Value + _FC_Value, _SVG_Scale ) & "' y2='" & _AxisY - DIVIDE ( _AC_Value + _FC_Value, _SVG_Scale ) & "' stroke='#000000' stroke-width='" & _ReferenceLineWidth & "'></line>"
		
		    VAR _TotalVarianceColor =
		        IF ( ( _FC_Value + _AC_Value - _PY_Value ) * businessImpact >= 0, _ColorGreen, _ColorRed )
		
		    VAR _TotalVariance =
		        VAR _Height = ABS ( DIVIDE ( _FC_Value + _AC_Value - _PY_Value, _SVG_Scale ) )
		        RETURN
		            "<rect x='" & _TotalCategoryPosition + _CategoryWidthYear & "' y='" & _AxisY - DIVIDE ( _PY_Value, _SVG_Scale ) & "' height='" & _Height & "' width='" & _PinWidth & "' fill='" & _TotalVarianceColor & "' stroke-width='0'></rect>"
		
		    VAR ACFC_Total_Label =
		        VAR _Value = _AC_Value + _FC_Value - _PY_Value
		        VAR _Height = DIVIDE ( _AC_Value + _FC_Value - _Value / 2, _SVG_Scale )
		        RETURN
		            "<text x='" & _TotalCategoryPosition + _CategoryWidthYear + _Em * 1.5 & "' y='" & _AxisY - _Height & "' stroke='#000000' stroke-width='0'>" & _Value & "</text>"
		
		    VAR _SVG_WATERFALL =
		        ACFCminusPY_Columns & ACFCminusPY_Labels & ACFCminusPY_Lines & _LinePY & _LineACFC & _TotalVariance & ACFC_Total_Label
		
		    //===============================================
		    // RELATIVE VARIANCE (monthly)
		    //===============================================
		    VAR _ClampedPct = MAX ( - _RelPinMax, MIN ( _RelPinMax, DeltaPYPct ) )
		    VAR _IsOutlier = ABS ( DeltaPYPct ) > _RelPinMax
		
		    VAR _AxisRelative =
		        "<line x1='0' x2='" & _SVG_Width & "' y1='" & _RelAxisY & "' y2='" & _RelAxisY & "' stroke='" & _ColorLightGrey & "' stroke-width='" & _RelativeAxisLineWidth & "'></line>"
		
		    VAR _Label_DeltaPYPct =
		        "<text x='" & _TotalCategoryPosition + _CategoryWidthYear + _Em & "' y='" & _RelAxisY & "' stroke='#000000' stroke-width='0'>ΔPY%</text>"
		
		    VAR ACFCminusPY_Relative =
		        VAR _Height = ABS ( _ClampedPct ) * _RelScale
		        VAR _Fill = IF ( DeltaPYPct * businessImpact > 0, _ColorGreen, _ColorRed )
		        RETURN
		            "<rect x='" & _ColumnsLeftOffset + 15 & "' y='" & _RelAxisY + IF ( _ClampedPct > 0, - _ClampedPct * _RelScale, 0 ) & "' height='" & _Height & "' width='" & _PinWidth & "' fill='" & _Fill & "' stroke-width='0'></rect>"
		
		    VAR _PinTipY = _RelAxisY - _ClampedPct * _RelScale
		    VAR ACFCminusPY_RelativeBlackBox =
		        VAR _Fill = SWITCH ( _Type, "AC", _ColorBlack, "FC", "url(#diagonal-stripe)" )
		        VAR _PinCenterX = _ColumnsLeftOffset + 17.5
		        RETURN
		            IF (
		                _IsOutlier,
		                VAR _TriH = _PinHeadWidth
		                VAR _TriW = _PinHeadWidth
		                VAR _Dir = IF ( DeltaPYPct > 0, -1, 1 )
		                VAR _TipY = _PinTipY + _Dir * _TriH / 2
		                VAR _BaseY = _PinTipY - _Dir * _TriH / 2
		                RETURN
		                    "<polygon points='" & _PinCenterX & "," & _TipY & " " & ( _PinCenterX - _TriW / 2 ) & "," & _BaseY & " " & ( _PinCenterX + _TriW / 2 ) & "," & _BaseY & "' fill='" & _Fill & "' stroke='" & _ColorBlack & "' stroke-width='" & _OutlineStrokeWith & "'/>",
		                "<rect x='" & _PinCenterX - _PinHeadWidth / 2 & "' y='" & _PinTipY - _PinHeadWidth / 2 & "' height='" & _PinHeadWidth & "' width='" & _PinHeadWidth & "' fill='" & _Fill & "' stroke='" & _ColorBlack & "' stroke-width='" & _OutlineStrokeWith & "'></rect>"
		            )
		
		    VAR RelativeVariation_Labels =
		        "<text x='" & _ColumnsLeftOffset + _ColumnWidth / 2 & "' y='" & _PinTipY + IF ( DeltaPYPct > 0, - _PinHeadWidth / 2 - _Em * 0.6, _PinHeadWidth / 2 + _Em * 0.6 ) & "'>" & FORMAT ( DeltaPYPct, "+0;-0;0" ) & "</text>"
		
		    VAR _SVG_RELATIVE_VARIANCE =
		        _AxisRelative & _Label_DeltaPYPct & ACFCminusPY_Relative & ACFCminusPY_RelativeBlackBox & RelativeVariation_Labels
		
		    //===============================================
		    // RELATIVE VARIANCE (year total)
		    //===============================================
		    VAR _TotalDeltaPYPct = DeltaPYPct
		    VAR _ClampedPctTotal = MAX ( - _RelPinMax, MIN ( _RelPinMax, _TotalDeltaPYPct ) )
		    VAR _IsOutlierTotal = ABS ( _TotalDeltaPYPct ) > _RelPinMax
		    VAR _PinTipYTotal = _RelAxisY - _ClampedPctTotal * _RelScale
		
		    VAR _AxisRelativeTotal =
		        "<line x1='" & _TotalCategoryPosition & "' x2='" & _TotalCategoryPosition + _CategoryWidth & "' y1='" & _RelAxisY & "' y2='" & _RelAxisY & "' stroke='" & _ColorLightGrey & "' stroke-width='" & _RelativeAxisLineWidth & "'></line>"
		
		    VAR ACFCminusPY_RelativeTotal =
		        VAR _Height = ABS ( _ClampedPctTotal ) * _RelScale
		        VAR _Fill = IF ( _TotalDeltaPYPct * businessImpact > 0, _ColorGreen, _ColorRed )
		        RETURN
		            "<rect x='" & _TotalCategoryPosition + _ColumnWidthYear / 2 & "' y='" & _RelAxisY + IF ( _ClampedPctTotal > 0, - _ClampedPctTotal * _RelScale, 0 ) & "' height='" & _Height & "' width='" & _PinWidth & "' fill='" & _Fill & "' stroke-width='0'></rect>"
		
		    VAR ACFCminusPY_RelativeBlackBoxTotal =
		        VAR _TypeTotal = "FC"
		        VAR _Fill = SWITCH ( _TypeTotal, "AC", _ColorBlack, "FC", "url(#diagonal-stripe)" )
		        VAR _PinCenterX = _TotalCategoryPosition + _ColumnWidthYear / 2 + 3
		        RETURN
		            IF (
		                _IsOutlierTotal,
		                VAR _TriH = _PinHeadWidth
		                VAR _TriW = _PinHeadWidth
		                VAR _Dir = IF ( _TotalDeltaPYPct > 0, -1, 1 )
		                VAR _TipY = _PinTipYTotal + _Dir * _TriH / 2
		                VAR _BaseY = _PinTipYTotal - _Dir * _TriH / 2
		                RETURN
		                    "<polygon points='" & _PinCenterX & "," & _TipY & " " & ( _PinCenterX - _TriW / 2 ) & "," & _BaseY & " " & ( _PinCenterX + _TriW / 2 ) & "," & _BaseY & "' fill='" & _Fill & "' stroke='" & _ColorBlack & "' stroke-width='" & _OutlineStrokeWith & "'/>",
		                "<rect x='" & _PinCenterX - _PinHeadWidth / 2 & "' y='" & _PinTipYTotal - _PinHeadWidth / 2 & "' height='" & _PinHeadWidth & "' width='" & _PinHeadWidth & "' fill='" & _Fill & "' stroke='" & _ColorBlack & "' stroke-width='" & _OutlineStrokeWith & "'></rect>"
		            )
		
		    VAR RelativeVariation_LabelsTotal =
		        "<text x='" & _TotalCategoryPosition + _ColumnWidthYear / 2 & "' y='" & _PinTipYTotal + IF ( _TotalDeltaPYPct > 0, - _PinHeadWidth / 2 - _Em * 0.6, _PinHeadWidth / 2 + _Em * 0.6 ) & "' stroke='#000000' stroke-width='0'>" & FORMAT ( _TotalDeltaPYPct, "+0;-0;0" ) & "</text>"
		
		    VAR _SVG_RELATIVEVARIANCE_TOTAL =
		        _AxisRelativeTotal & ACFCminusPY_RelativeBlackBoxTotal & ACFCminusPY_RelativeTotal & RelativeVariation_LabelsTotal
		
		    //===============================================
		    // CONTENT GROUPS (for responsive mode)
		    //===============================================
		    VAR _AllContent =
		        _SVG_AxisX & _SVG_ColumnChart_Month & _SVG_WATERFALL &
		        _SVG_RELATIVE_VARIANCE & _SVG_RELATIVEVARIANCE_TOTAL
		    VAR _TwoTierContent =
		        _SVG_AxisX & _SVG_ColumnChart_Month & _SVG_WATERFALL
		    VAR _OneTierContent = 
		        _SVG_AxisX & _SVG_VarianceBar & _SVG_ColumnChart_Month
		
		    //===============================================
		    // RESPONSIVE INNER SVGs (only used when _TierCount = 0)
		    //===============================================
		    VAR _VB_TwoTier_Y = _RelTierH
		    VAR _VB_TwoTier_H = _SVG_Height - _RelTierH
		    VAR _VB_OneTier_Y = _RelTierH
		    VAR _VB_OneTier_H = _SVG_Height - _RelTierH
		
		    VAR _InnerSVG_ThreeTier =
		        "<svg class='tier3' width='100%' height='100%' viewBox='0 0 " & _SVG_Width & " " & _SVG_Height & "' preserveAspectRatio='xMidYMax meet'>" &
		        _AllContent & "</svg>"
		
		    VAR _InnerSVG_TwoTier =
		        "<svg class='tier2' width='100%' height='100%' viewBox='0 " & _VB_TwoTier_Y & " " & _SVG_Width & " " & _VB_TwoTier_H & "' preserveAspectRatio='xMidYMax meet'>" &
		        _TwoTierContent & "</svg>"
		
		    VAR _InnerSVG_OneTier =
		        "<svg class='tier1' width='100%' height='100%' viewBox='0 " & _VB_OneTier_Y & " " & _SVG_Width & " " & _VB_OneTier_H & "' preserveAspectRatio='xMidYMax meet'>" &
		        _OneTierContent & "</svg>"
		
		    //===============================================
		    // COMBINE SVG
		    //===============================================
		    VAR SVGImageURL = IF (
		        _TierCount = 0,
		        _SVG_Header & _SVG_Open & _SVG_DebugBox & _SVG_ForeignObject &
		        _SVG_STYLE_AND_PATTERNS &
		        _InnerSVG_ThreeTier & _InnerSVG_TwoTier & _InnerSVG_OneTier &
		        _SVG_Close,
		        _SVG_Header & _SVG_Open & _SVG_DebugBox & _SVG_STYLE_AND_PATTERNS &
		        _SVG_AxisX & _SVG_ColumnChart_Month &
		        IF ( NOT _ShowWaterfall, _SVG_VarianceBar, "" ) &
		        IF ( _ShowWaterfall, _SVG_WATERFALL, "" ) &
		        IF ( _ShowRelative, _SVG_RELATIVE_VARIANCE & _SVG_RELATIVEVARIANCE_TOTAL, "" ) &
		        _SVG_Close
		    )
		RETURN SVGImageURL
		```
	lineageTag: e9e681e1-548b-487e-a009-16aee4c319df

	annotation DAXLIB_PackageId = PowerofBI.IBCS

	annotation DAXLIB_PackageVersion = 0.11.0

/// Creates small multiple column charts for absolute values, absolute variance, or relative variance.
/// When Select All is active (no single category selected), renders selectAllMeasure as Absolute Values chart.
/// @param {string} chartType
/// usage example: "Absolute" or "Relative" or "Absolute Values" (chart type)
/// @param {anyref} categoryColumn
/// usage example: 'Country'[Country] (column with a list of categories for individual cards)
/// @param {anyref} periodColumn
/// usage example: 'Year'[Year] (column with a list of periods for X-axis values)
/// @param {anyref} absoluteMeasure
/// usage example: [Average Sales] (absolute values measure, used when chartType is "Absolute Values")
/// @param {anyref} deltaAbsoluteMeasure
/// usage example: [Delta Average Sales] (absolute variance measure, e.g., 500)
/// @param {anyref} deltaPctMeasure
/// usage example: [Delta Average Sales %] (relative variance measure as whole number, e.g., 15 for +15%)
/// @param {scalar} endOfActual
/// usage example: [EndOfActualPeriod] (last period with actual data; periods after this are treated as planned)
/// @param {scalar} sortOrderExpr
/// usage example: [Sales Total] (measure used for card sort order; add to Tooltips field in visual)
/// @param {int64} imageWidth
/// usage example: 0 (default width 350px; use >0 for custom width in px)
/// @param {int64} imageHeight
/// usage example: 0 (default height 220px; use >0 for custom height in px)
/// @param {int64} businessImpact
/// usage example: 1 (1: positive delta is green, e.g., sales; -1: positive delta is red, e.g., cost)
/// @param {string} categoryLabel
/// usage example: "Average of all countries" (title text for Select All card; count appended as '(N)')
/// @param {scalar} selectAllMeasure
/// usage example: [Average Sales] (measure to display on Select All button; pass BLANK() to show nothing)
/// @returns SVG image (data:image/svg+xml URI for embedding in table cells)
function 'PowerofBI.IBCS.ColumnChart.SmallMultiple' =
		
		(
		    // chart type: "Absolute" or "Relative" or "Absolute Values"
		    chartType: STRING VAL,
		    // column with categories for individual cards: 'Country'[Country]
		    categoryColumn: ANYREF EXPR,
		    // column with periods for X-axis values: 'Year'[Year]
		    periodColumn: ANYREF EXPR,
		    // absolute values measure: [Average Sales]
		    absoluteMeasure: ANYREF EXPR,
		    // absolute variance measure: [Delta Average Sales]
		    deltaAbsoluteMeasure: ANYREF EXPR,
		    // relative variance measure (whole number): [Delta Average Sales %]
		    deltaPctMeasure: ANYREF EXPR,
		    // last period with actual data: [EndOfActualPeriod]
		    endOfActual: SCALAR VAL,
		    // measure for card sort order (add to Tooltips): [Sales Total]
		    sortOrderExpr: SCALAR EXPR,
		    // image width, 0 = default 350px: 0
		    imageWidth: INT64 VAL,
		    // image height, 0 = default 220px: 0
		    imageHeight: INT64 VAL,
		    // business impact: 1 (positive delta is green) or -1 (positive delta is red)
		    businessImpact: INT64 VAL,
		    // title text for Select All card: "Average of all countries"
		    categoryLabel: STRING VAL,
		    // measure to display on Select All button: [Average Sales]
		    selectAllMeasure: SCALAR EXPR
		) =>
		//=================================================================================================
		// Project: PowerofBI.IBCS: IBCS-guided data visualizations in your Power BI reports
		// Project Description: https://www.powerofbi.org/ibcs
		// DAX Lib package: https://daxlib.org/package/PowerofBI.IBCS/
		// PowerofBI.IBCS support: https://github.com/avatorl/dax-udf-svg-ibcs/issues
		// Author: Andrzej Leszkiewicz — IBCS® Certified Analyst
		// LinkedIn: https://www.linkedin.com/in/avatorl/
		// The visualization design adheres to IBCS recommendations: https://www.ibcs.com/ibcs-standards-1-2/
		//      but is NOT produced, certified, authorized, or endorsed by IBCS®
		//=================================================================================================
		// License: MIT License (free and permissive)
		// https://en.wikipedia.org/wiki/MIT_License
		//=================================================================================================
		//=================================================================================================
		// PowerofBI.IBCS.ColumnChart.SmallMultiple function:
		//   This UDF generates small multiple column charts for absolute values, absolute variance,
		//   or relative variance. When Select All is active (no single category selected), renders
		//   selectAllMeasure as an Absolute Values chart.
		//
		//   Features include:
		//     • Three chart modes: Absolute Values, Absolute Variance, Relative Variance
		//     • Select All card with bold title and category count
		//     • AC (solid) vs PL (outlined) column styling per period
		//     • Relative variance rendered as pin charts with colored bars
		//     • Period labels at start, middle, and end of axis
		//     • businessImpact parameter: -1 inverts color semantics (cost KPIs)
		//=================================================================================================
		//===============================================
		// CONTEXT AND MODE DETECTION
		//===============================================
		VAR _Country = SELECTEDVALUE ( categoryColumn )
		VAR _IsSelectAll = ISBLANK ( _Country )
		VAR _IsRelativeVariance =
		    NOT _IsSelectAll && ( UPPER ( chartType ) = "RELATIVE" )
		VAR _IsAbsoluteValues =
		    _IsSelectAll || UPPER ( chartType ) = "ABSOLUTE VALUES"
		VAR _CategoryCount =
		    IF (
		        _IsSelectAll,
		        COUNTROWS ( ALLSELECTED ( categoryColumn ) )
		    )
		VAR _TitleText =
		    IF (
		        _IsSelectAll,
		        categoryLabel & " (" & _CategoryCount & ")",
		        _Country
		    )
		VAR _CategoryRank =
		    IF (
		        _IsSelectAll,
		        1,
		        RANKX (
		            ALLSELECTED ( categoryColumn ),
		            CALCULATE ( sortOrderExpr ),
		            ,
		            DESC
		        )
		    )
		VAR _SelectAllCardHasData =
		    NOT ISBLANK (
		        CALCULATE (
		            selectAllMeasure,
		            ALL ( categoryColumn )
		        )
		    )
		VAR _ShowPeriodLabels =
		    IF (
		        _IsSelectAll,
		        TRUE ( ),
		        NOT _SelectAllCardHasData && _CategoryRank = 1
		    )
		
		//===============================================
		// DATA TABLE
		//===============================================
		VAR _DataTable =
		    ADDCOLUMNS (
		        VALUES ( periodColumn ),
		        "@Period", periodColumn,
		        "@IsActual", periodColumn <= endOfActual,
		        "@Value",
		            IF (
		                _IsSelectAll,
		                CALCULATE ( selectAllMeasure ),
		                IF (
		                    _IsAbsoluteValues,
		                    CALCULATE ( absoluteMeasure ),
		                    IF (
		                        _IsRelativeVariance,
		                        CALCULATE ( deltaPctMeasure ),
		                        CALCULATE ( deltaAbsoluteMeasure )
		                    )
		                )
		            )
		    )
		VAR _SelectAllHasData = NOT ISBLANK ( MAXX ( _DataTable, [@Value] ) )
		VAR _TableDataWithRowNum =
		    ADDCOLUMNS (
		        _DataTable,
		        "@rowNum",
		            ROWNUMBER ( _DataTable, ORDERBY ( [@Period], ASC ) )
		    )
		
		//===============================================
		// PERIOD HELPERS
		//===============================================
		VAR _PLPeriodStart = endOfActual + 1
		VAR _PeriodStart = MIN ( periodColumn )
		VAR _PeriodEnd = MAX ( periodColumn )
		VAR _PeriodMiddle = ROUND ( ( _PeriodStart + _PeriodEnd ) / 2, 0 )
		
		//===============================================
		// SCALING (cross-category max/min)
		//===============================================
		VAR _AllColumns =
		    CALCULATETABLE (
		        SUMMARIZECOLUMNS (
		            periodColumn,
		            categoryColumn,
		            "@Value",
		                IF (
		                    _IsAbsoluteValues,
		                    absoluteMeasure,
		                    IF (
		                        _IsRelativeVariance,
		                        deltaPctMeasure,
		                        deltaAbsoluteMeasure
		                    )
		                )
		        ),
		        ALL ( periodColumn ),
		        ALL ( categoryColumn )
		    )
		VAR _MaxValue = MAXX ( _AllColumns, [@Value] )
		VAR _MinValue = MINX ( _AllColumns, [@Value] )
		
		//===============================================
		// FORMATTING CONFIGURATION
		//===============================================
		// When = 1, draws a debug rectangle showing the SVG boundaries (useful during layout tuning)
		VAR _DEBUG = 0
		
		// Unfavorable business impact
		VAR _ColorRed = "#E24B20"
		// Favorable business impact
		VAR _ColorGreen = "#08787D"
		// AC (actuals): solid dark fill
		VAR _ColorBlack = "#404040"
		// BU/PL: white fill with dark outline
		VAR _ColorWhite = "#FFFFFF"
		// Axis line colour (softer grey for small multiples)
		VAR _ColorAxisLine = "#808080"
		// Period label colour
		VAR _ColorPeriodLabel = "#AAAAAA"
		VAR _SVGWidth = IF ( imageWidth > 0, imageWidth, 350 )
		VAR _SVGHeight = IF ( imageHeight > 0, imageHeight, 220 )
		VAR _HeaderHeight = 45
		VAR _FooterHeight = 45
		VAR _PinheadWidthMutiplier = 3
		VAR _DataLabelOffset = 5
		VAR _FontFamily = "Segoe UI, sans-serif"
		VAR _TitleFontSize = 18
		VAR _PeriodLabelFontSize = 14
		VAR _DataLabelFontSize = 16
		VAR _MaxColumnWidth = _DataLabelFontSize * 4 / 3
		VAR _LineWidth = 0.2
		VAR _AxisLineWidth = 0.5
		VAR _PlotHeight = _SVGHeight - _HeaderHeight - _FooterHeight
		VAR _ColumnWidth = _MaxColumnWidth
		VAR _SpaceBetweenColumns = _MaxColumnWidth * 2 / 3
		VAR _Range =
		    SWITCH (
		        TRUE ( ),
		        _MaxValue < 0, ABS ( _MinValue ),
		        _MinValue > 0, _MaxValue,
		        ( _MaxValue - _MinValue )
		    )
		VAR _ZeroY =
		    _HeaderHeight
		        + ROUND (
		            DIVIDE ( IF ( _MaxValue >= 0, _MaxValue, 0 ), _Range )
		                * _PlotHeight,
		            0
		        )
		
		//===============================================
		// DATA MARKS (one rect + label per period)
		//===============================================
		VAR _DataMarks =
		    CONCATENATEX (
		        _TableDataWithRowNum,
		        VAR _Value = [@Value]
		        VAR _RowNum = [@rowNum]
		        VAR _Period = [@Period]
		        VAR _IsActual = [@IsActual]
		        VAR _ColumnHeight =
		            ROUND ( DIVIDE ( ABS ( _Value ), _Range ) * _PlotHeight, 1 )
		        VAR _xPosition =
		            ( ( _RowNum - 1 ) * _ColumnWidth )
		                + ( _SpaceBetweenColumns * ( _RowNum - 1 ) )
		                + IF (
		                    _IsRelativeVariance,
		                    _SpaceBetweenColumns + _ColumnWidth * 0.5,
		                    0
		                )
		        VAR _xAxis =
		            ( ( _RowNum - 1 ) * _ColumnWidth )
		                + ( _SpaceBetweenColumns * ( _RowNum - 1 ) )
		                + IF ( _IsRelativeVariance, 0, 0 )
		        VAR _ColumnColorOutline =
		            IF (
		                _IsAbsoluteValues,
		                _ColorBlack,
		                IF ( _Value * businessImpact >= 0, _ColorGreen, _ColorRed )
		            )
		        VAR _ColumnColorFill =
		            IF (
		                _IsAbsoluteValues,
		                IF ( _IsActual, _ColorBlack, _ColorWhite ),
		                IF (
		                    _IsRelativeVariance,
		                    _ColumnColorOutline,
		                    IF ( _IsActual, _ColumnColorOutline, _ColorWhite )
		                )
		            )
		        VAR _PinheadColorFill =
		            IF ( _IsActual, _ColorBlack, _ColorWhite )
		        VAR _BarYPosition = _ZeroY + IF ( _Value >= 0, -_ColumnHeight, 0 )
		        VAR _PeriodLineYPosition =
		            _ZeroY
		                + IF ( _Value >= 0, 0, _ColumnHeight + _DataLabelFontSize )
		                + _DataLabelOffset * 2
		        VAR _TextYPosition =
		            _ZeroY
		                + IF (
		                    _Value >= 0,
		                    -ABS ( _ColumnHeight ) - _DataLabelOffset
		                        + IF ( _IsRelativeVariance, -5, -1 ),
		                    ABS ( _ColumnHeight ) + _DataLabelOffset + _DataLabelFontSize
		                        + IF ( _IsRelativeVariance, 2, 0 )
		                )
		        VAR _Baseline = IF ( _Value >= 0, "top", "bottom" )
		
		        // Pinhead for relative variance mode
		        VAR _PinheadRect =
		            "<rect x='" & _xPosition & "' y='"
		                & _BarYPosition + IF ( _Value >= 0, 0, _ColumnHeight )
		                - _ColumnWidth / 3
		                & "' width = '"
		                & _ColumnWidth * _PinheadWidthMutiplier
		                * IF ( _IsRelativeVariance, 0.2, 1 )
		                & "' height = '"
		                & _ColumnWidth * _PinheadWidthMutiplier
		                * IF ( _IsRelativeVariance, 0.2, 1 )
		                & "px' fill='"
		                & _PinheadColorFill
		                & "' stroke='"
		                & _ColorBlack
		                & "' opacity='1' style='outline: none;'></rect>"
		
		        // Data column rectangle
		        VAR _DataRect =
		            "<rect x='"
		                & _xPosition
		                + ( _ColumnWidth * _PinheadWidthMutiplier
		                * IF ( _IsRelativeVariance, 0.2, 1 ) )
		                / 3
		                & "' y='"
		                & _BarYPosition
		                & "' width = '"
		                & _ColumnWidth * IF ( _IsRelativeVariance, 0.2, 1 )
		                & "' height = '"
		                & _ColumnHeight
		                & "px' fill='"
		                & _ColumnColorFill
		                & "' stroke='"
		                & _ColumnColorOutline
		                & "' opacity='1' style='outline: none;'></rect>"
		
		        // Data label text
		        VAR _DataLabelText =
		            "<text x='"
		                & IF (
		                    _IsRelativeVariance,
		                    _xPosition + _ColumnWidth / 2 - 6,
		                    _xPosition + _ColumnWidth + 8
		                )
		                & "' y='"
		                & _TextYPosition - 2
		                & "' font-family='"
		                & _FontFamily
		                & "' font-size='"
		                & _DataLabelFontSize - 1
		                & "px' text-anchor='middle' alignment-baseline='"
		                & _Baseline
		                & "'   fill='"
		                & _ColorBlack
		                & "'>"
		                & IF (
		                    _IsAbsoluteValues,
		                    FORMAT ( ROUND ( [@Value], 0 ), "#,0" ),
		                    FORMAT ( ROUND ( [@Value], 0 ), "+#,0;-#,0;#,0" )
		                )
		                & "</text>"
		
		        // Period vertical guide line
		        VAR _PeriodVerticalLine =
		            IF (
		                _Period IN { _PeriodStart, _PeriodMiddle, _PeriodEnd }
		                    && _ShowPeriodLabels,
		                "<line x1='" & _xAxis + _ColumnWidth * 1.5 & "' x2='"
		                    & _xAxis + _ColumnWidth * 1.5
		                    & "' y1='"
		                    & _PeriodLineYPosition
		                    + IF (
		                        _IsRelativeVariance,
		                        _ColumnWidth * _PinheadWidthMutiplier / 2,
		                        0
		                    )
		                    & "' y2='"
		                    & _SVGHeight - _PeriodLabelFontSize - _DataLabelOffset * 2
		                    & "' stroke='"
		                    & _ColorBlack
		                    & "' stroke-width='"
		                    & _LineWidth
		                    & "'></line>",
		                ""
		            )
		
		        // Period label text
		        VAR _PeriodLabel =
		            IF (
		                _Period IN { _PeriodStart, _PeriodMiddle, _PeriodEnd }
		                    && _ShowPeriodLabels,
		                "<text x='" & _xAxis + _ColumnWidth * 1.5 & "' y='"
		                    & _SVGHeight - _PeriodLabelFontSize - _DataLabelOffset
		                    & "'  dx='-16' font-family='"
		                    & _FontFamily
		                    & "' font-size='"
		                    & _PeriodLabelFontSize
		                    & "px' dominant-baseline='hanging'  fill='"
		                    & _ColorPeriodLabel
		                    & "'>"
		                    & _Period
		                    & "</text>",
		                ""
		            )
		
		        // Plan/actual divider line
		        VAR _PLVerticalLine =
		            IF (
		                _Period = _PLPeriodStart,
		                "<line x1='"
		                    & _xAxis + _ColumnWidth - _SpaceBetweenColumns / 2
		                    & "' x2='"
		                    & _xAxis + _ColumnWidth - _SpaceBetweenColumns / 2
		                    & "' y1='"
		                    & _ZeroY - _DataLabelFontSize * 2
		                    & "' y2='"
		                    & _ZeroY + _DataLabelFontSize * 2
		                    & "' stroke='"
		                    & _ColorAxisLine
		                    & "' stroke-width='"
		                    & _AxisLineWidth
		                    & "'></line>",
		                ""
		            )
		        RETURN
		            IF ( _IsRelativeVariance, _PinheadRect, "" ) & _DataRect
		                & _DataLabelText
		                & _PeriodVerticalLine
		                & _PeriodLabel
		                & _PLVerticalLine
		    )
		
		//===============================================
		// SVG ASSEMBLY
		//===============================================
		VAR _SVG_Header = "data:image/svg+xml;utf8,"
		VAR _SVG_Open =
		    "<svg xmlns='http://www.w3.org/2000/svg' width='"
		        & _SVGWidth
		        & "' height='"
		        & _SVGHeight
		        & "'>"
		VAR _SVG_Close = "</svg>"
		VAR _TitleFontWeight =
		    IF ( _IsSelectAll, " font-weight='bold'", "" )
		VAR _TextTitle =
		    "<text x='10' y='10' font-size='" & _TitleFontSize
		        & "px' font-family='"
		        & _FontFamily
		        & "' dominant-baseline='middle' text-anchor='start' fill='"
		        & _ColorBlack
		        & "'"
		        & _TitleFontWeight
		        & ">"
		        & _TitleText
		        & "</text>"
		VAR _AxisXLine =
		    "<line x1='0' x2='" & _SVGWidth & "' y1='" & _ZeroY
		        & "' y2='"
		        & _ZeroY
		        & "' stroke='"
		        & _ColorAxisLine
		        & "' stroke-width='"
		        & _AxisLineWidth
		        & "'></line>"
		VAR _SVG_DebugBox =
		    IF (
		        _DEBUG,
		        "<rect id='rect-debug-box' x='0%' y='0%' width='100%' height='100%' fill='#FFFFAA' stroke-width='1' stroke='#FF0000' />",
		        ""
		    )
		VAR SVGImageURL =
		    _SVG_Header & _SVG_Open & _SVG_DebugBox & _TextTitle
		        & _DataMarks
		        & _AxisXLine
		        & _SVG_Close
		RETURN
		    IF (
		        _IsSelectAll && NOT _SelectAllHasData,
		        BLANK ( ),
		        SVGImageURL
		    )
	lineageTag: d954d962-9ee7-483e-ae8c-aad37e433545

	annotation DAXLIB_PackageId = PowerofBI.IBCS

	annotation DAXLIB_PackageVersion = 0.11.0

/// Creates vertical waterfall (e.g., for P&L)
/// @param {string} chartType
/// usage example: "AC", "PY", or "PL" (chart rendering type: black for AC, grey for PY, outlined for PL)
/// @param {table} tableBase
/// usage example: 'P&L Structure' (table that defines the P&L structure)
/// @param {anyref} mainValueMeasure
/// usage example: [Amount] (measure that returns monetary amount)
/// @param {string} dataLabel
/// usage example: FORMAT ( [Amount], "$#,0" ) (formatted data label string, e.g., "$1,500")
/// @param {anyref} rowSignColumn
/// usage example: 'P&L'[Sign] (column with "+", "-", or "=" indicating row behavior)
/// @param {anyref} indexColumn
/// usage example: 'P&L'[Row Index] (column with row index for proper ordering)
/// @param {scalar} scaleMax
/// usage example: MAXX ( ALLSELECTED ( 'P&L'[Line Item] ), ABS ( [Amount] ) ) (maximum absolute value for scaling)
/// @param {anyref} level1Column
/// usage example: 'P&L'[Category] (first hierarchical level, e.g., Income, Expenses)
/// @param {anyref} level2Column
/// usage example: 'P&L'[SubCategory] (second hierarchical level for nested hierarchy)
/// @param {int64} imageWidth
/// usage example: 400 (image width in px, same as on the Format pane)
/// @param {int64} imageHeight
/// usage example: 25 (image height in px, same as on the Format pane)
/// @returns SVG image (data:image/svg+xml URI for embedding in table cells)
function 'PowerofBI.IBCS.Waterfall.Vertical' =
		
		(
		    // chart rendering type: "AC" (black), "PY" (grey), or "PL" (outlined)
		    chartType: STRING VAL,
		    // table that defines the P&L structure: 'P&L Structure'
		    tableBase: TABLE VAL,
		    // measure that returns monetary amount: [Amount]
		    mainValueMeasure: ANYREF EXPR,
		    // formatted data label: FORMAT ( [Amount], "$#,0" )
		    dataLabel: STRING VAL,
		    // column with "+", "-", or "=" indicating row behavior: 'P&L'[Sign]
		    rowSignColumn: ANYREF EXPR,
		    // column with row index for ordering: 'P&L'[Row Index]
		    indexColumn: ANYREF EXPR,
		    // maximum absolute value for scaling: MAXX ( ALLSELECTED ( 'P&L'[Line Item] ), ABS ( [Amount] ) )
		    scaleMax: SCALAR VAL,
		    // first hierarchical level: 'P&L'[Category]
		    level1Column: ANYREF EXPR,
		    // second hierarchical level: 'P&L'[SubCategory]
		    level2Column: ANYREF EXPR,
		    // image width in px: 400
		    imageWidth: INT64 VAL,
		    // image height in px: 25
		    imageHeight: INT64 VAL
		) =>
		//=================================================================================================
		// Project: PowerofBI.IBCS: IBCS-guided data visualizations in your Power BI reports
		// Project Description: https://www.powerofbi.org/ibcs
		// DAX Lib package: https://daxlib.org/package/PowerofBI.IBCS/
		// PowerofBI.IBCS support: https://github.com/avatorl/dax-udf-svg-ibcs/issues
		// Author: Andrzej Leszkiewicz — IBCS® Certified Analyst
		// LinkedIn: https://www.linkedin.com/in/avatorl/
		// The visualization design adheres to IBCS recommendations: https://www.ibcs.com/ibcs-standards-1-2/
		//      but is NOT produced, certified, authorized, or endorsed by IBCS®
		//=================================================================================================
		// License: MIT License (free and permissive)
		// https://en.wikipedia.org/wiki/MIT_License
		//=================================================================================================
		//=================================================================================================
		// PowerofBI.IBCS.Waterfall.Vertical function:
		//   This UDF renders a vertical waterfall for hierarchical P&L structures (AC/PY/PL styling).
		//
		//   Features include:
		//     • Waterfall bars with running total positioning (level-2 detail rows)
		//     • ChartType styling: AC (solid black), PY (grey fill), PL (outlined white)
		//     • Vertical connector lines at top and bottom of each bar
		//     • Subtotal marker lines for level-1 group boundaries (grey vertical lines)
		//     • Data labels anchored relative to bar direction (start/end alignment)
		//     • Bold labels for subtotal rows (= sign)
		//     • Handles hierarchical P&L with level-1 subtotals and level-2 detail rows
		//     • Signed value logic: + rows add, - rows subtract from running total
		//=================================================================================================
		//-------------------------------------------------------------------------------------------------
		// SVG layout
		//-------------------------------------------------------------------------------------------------
		// When = 1, draws a debug rectangle showing the SVG boundaries (useful during layout tuning)
		VAR _DEBUG = 0
		
		// Font size in px (scales with row height, matching BarChart.AbsoluteValues)
		VAR _Em = imageHeight * 0.6
		
		// Outline width applied to bar borders
		VAR _OutlineWidth = 0.5
		
		// Horizontal offset between bar end and data label
		VAR _LabelOffset = _Em * 0.15
		
		// Space reserved for data labels to the right of the chart area
		VAR _RightPad = imageWidth * 0.44
		
		// Width available for bar drawing
		VAR _DrawableWidth = imageWidth - _RightPad
		
		// Vertical placement of bars (centered in row height)
		VAR _mainBarYPosition = ( imageHeight - _Em ) / 2
		
		// AC (actuals): solid dark fill
		VAR _ColorBlack = "#404040"
		// Outline color (same as AC)
		VAR _ColorOutline = _ColorBlack
		// PY (previous year): neutral grey reference fill
		VAR _ColorGrey = "#C6C6C6"
		// Secondary grey for markers and connectors
		VAR _ColorLightGrey = "#A6A6A6"
		VAR _SVG_Style =
		    "<style>text{font-family:'Segoe UI', sans-serif;font-size:"
		        & _Em
		        & "px;dominant-baseline:central;}</style>"
		
		//-------------------------------------------------------------------------------------------------
		// Row level detection
		//-------------------------------------------------------------------------------------------------
		VAR _IsLevel2 = ISINSCOPE ( level2Column )  // TRUE if in a detail row (level 2)
		
		VAR _IsLevel1Subtotal =
		    ISINSCOPE ( level1Column )  // TRUE if row is a level 1 subtotal
		    && NOT _IsLevel2
		        && rowSignColumn <> "="
		
		//-------------------------------------------------------------------------------------------------
		// Running total (ONLY level-2 rows, ordered by index)
		//-------------------------------------------------------------------------------------------------
		VAR _CurrentIndex = MIN ( indexColumn )    // Current row index (works for level-1 & level-2 rows)
		// Running total of all previous level-2 rows (before current row)
		VAR _RunningTotal =
		    CALCULATE (
		        SUMX (
		            FILTER (
		                tableBase,
		                indexColumn < _CurrentIndex  // Earlier rows
		                    && NOT ISBLANK ( level2Column )  // Only detail rows
		                    && rowSignColumn <> "="  // Exclude subtotal rows
		            ),
		            SWITCH (
		                rowSignColumn,
		                "+", 1,
		                "-", -1,
		                0
		            )
		                * CALCULATE ( mainValueMeasure )  // Signed amount
		        )
		    )
		
		// Rectangle starting position: 0 for subtotals (=), running total for detail rows
		VAR _Start =
		    IF ( rowSignColumn = "=", 0, _RunningTotal )
		
		//-------------------------------------------------------------------------------------------------
		// Marker logic (only for level-2 rows)
		//  + rows → Level-1 value
		//  - rows → cumulative at start of group
		//-------------------------------------------------------------------------------------------------
		VAR _GroupStartIndex =
		    CALCULATE (
		        MAX ( indexColumn ),
		        REMOVEFILTERS ( level2Column )  // Max index within the level-1 group
		    )
		
		// Running total of all previous level-2 rows up to the end of current level-1 group
		VAR _GroupStartCumulative =
		    CALCULATE (
		        SUMX (
		            FILTER (
		                tableBase,
		                indexColumn < _GroupStartIndex  // Earlier rows
		                    && NOT ISBLANK ( level2Column )  // Detail rows only
		                    && rowSignColumn <> "="  // Exclude subtotals
		            ),
		            SWITCH (
		                rowSignColumn,
		                "+", 1,
		                "-", -1,
		                0
		            )
		                * CALCULATE ( mainValueMeasure )  // Signed amount
		        )
		    )
		VAR _MarkerValue =
		    IF (
		        _IsLevel2,
		        IF (
		            rowSignColumn = "-",  // For minus rows, use cumulative at group start
		            _GroupStartCumulative,
		            CALCULATE (
		                mainValueMeasure,
		                REMOVEFILTERS ( level2Column )
		            )  // For plus rows, use level-1 total
		        )
		    )
		
		// X-coordinate of the vertical variance marker line
		VAR _MarkerX =
		    IF (
		        _IsLevel2 && NOT ISBLANK ( _MarkerValue ),
		        DIVIDE ( _MarkerValue, scaleMax ) * _DrawableWidth  // Scale to SVG width
		    )
		
		//-------------------------------------------------------------------------------------------------
		// Change (delta)
		//-------------------------------------------------------------------------------------------------
		VAR _Change =
		    IF (
		        _IsLevel1Subtotal,
		        SWITCH (
		            rowSignColumn,
		            "+", mainValueMeasure,
		            "-", -mainValueMeasure,
		            0
		        ),  // For subtotals
		        SWITCH (
		            rowSignColumn,
		            "+", mainValueMeasure,
		            "-", -mainValueMeasure,
		            "=", mainValueMeasure,
		            0
		        )  // For detail rows
		    )
		
		//-------------------------------------------------------------------------------------------------
		// Geometry
		//-------------------------------------------------------------------------------------------------
		VAR _X =
		    DIVIDE (
		        _Start + IF ( _Change < 0, _Change, 0 ),  // Adjust X for negative changes (downward bars)
		        scaleMax
		    )
		        * _DrawableWidth  // Scale to SVG width
		
		VAR _Width =
		    ROUND ( ABS ( _Change ) / scaleMax * _DrawableWidth, 1 )  // Absolute width, scaled to SVG
		//-------------------------------------------------------------------------------------------------
		// Colors
		//-------------------------------------------------------------------------------------------------
		VAR _BarFill =
		    SWITCH (
		        chartType,  // AC (solid black), PY (grey), PL (outline only)
		        "AC", _ColorBlack,
		        "PY", _ColorGrey,
		        "PL", "none"
		    )
		
		// Stroke: white for AC (invisible outline), light grey for PY, black for PL (visible outline)
		VAR _BarStroke =
		    SWITCH (
		        chartType,
		        "AC", "#FFFFFF",
		        "PY", _ColorGrey,
		        "PL", _ColorOutline
		    )
		
		
		//-------------------------------------------------------------------------------------------------
		// Label positioning
		//-------------------------------------------------------------------------------------------------
		VAR _Anchor = IF ( _Change >= 0, "start", "end" )  // Anchor position based on bar direction
		VAR _DX = IF ( _Change >= 0, _LabelOffset, -_LabelOffset )  // Horizontal offset for label
		//-------------------------------------------------------------------------------------------------
		// SVG assembly
		//-------------------------------------------------------------------------------------------------
		VAR _SVG_Header = "data:image/svg+xml;utf8,"
		VAR _SVG_Open =
		    "<svg xmlns='http://www.w3.org/2000/svg' width='"
		        & imageWidth
		        & "' height='"
		        & imageHeight
		        & "'>"
		VAR _SVG_Close = "</svg>"
		
		// Debug overlay to visualize available drawing area
		VAR _SVG_DebugBox =
		    IF (
		        _DEBUG,
		        "<rect id='rect-debug-box' x='0' y='0' width='" & imageWidth
		            & "' height='"
		            & imageHeight
		            & "' fill='#FFFFAA' stroke-width='1' stroke='#FF0000' />",
		        ""
		    )
		VAR _SVGMarker =
		    IF (
		        _IsLevel2,
		        "<line title='vertical subtotal line' x1='" & _MarkerX
		            & "' x2='"
		            & _MarkerX
		            & "' y1='0' y2='"
		            & imageHeight
		            & "' stroke='"
		            & _ColorLightGrey
		            & "' stroke-width='1'></line>",
		        ""
		    )
		VAR _SVGBody =
		    "<rect title='main rectangle' x='" & _X & "' y='"
		        & _mainBarYPosition
		        & "' width='"
		        & _Width
		        & "' height='"
		        & _Em
		        & "' fill='"
		        & _BarFill
		        & "' stroke='"
		        & _BarStroke
		        & "' stroke-width='"
		        & _OutlineWidth
		        & "'></rect>"
		        & "<line title='small vertical line on the top of the bar' x1='"
		        & _X
		        + IF (
		            _Change < 0 || rowSignColumn = "=",
		            _Width,
		            0
		        )
		        & "' x2='"
		        & _X
		        + IF (
		            _Change < 0 || rowSignColumn = "=",
		            _Width,
		            0
		        )
		        & "' y1='0' y2='"
		        & _mainBarYPosition
		        & "' stroke='"
		        & _ColorLightGrey
		        & "' stroke-width='0.5'></line>"
		        & "<line title='small vertical line on the bottom of the bar' x1='"
		        & _X + IF ( _Change > 0, _Width, 0 )
		        & "' x2='"
		        & _X + IF ( _Change > 0, _Width, 0 )
		        & "' y1='"
		        & ( _mainBarYPosition + _Em )
		        & "' y2='"
		        & imageHeight
		        & "' stroke='"
		        & _ColorLightGrey
		        & "' stroke-width='0.5'></line>"
		        & "<text title='data label' text-anchor='"
		        & _Anchor
		        & "' x='"
		        & IF ( _Change >= 0, _X + _Width, _X )
		        & "' dx='"
		        & _DX
		        & "' y='"
		        & ( imageHeight / 2 )
		        & "' font-weight='"
		        & IF ( rowSignColumn = "=", "bold", "normal" )
		        & "'>"
		        & dataLabel
		        & "</text>"
		VAR _SVG =
		    _SVG_Header & _SVG_Open & _SVG_DebugBox & _SVGMarker
		        & _SVGBody
		        & _SVG_Style
		        & _SVG_Close
		RETURN
		    IF ( rowSignColumn IN { "+", "-", "=" }, _SVG )
	lineageTag: 6b1e4f0c-33c6-4e98-a370-f0e86dd41cb6

	annotation DAXLIB_PackageId = PowerofBI.IBCS

	annotation DAXLIB_PackageVersion = 0.11.0

/// Creates wide column chart showing absolute values and variance
/// @param {scalar} valueAC
/// usage example: [AC] (actual value, solid black, e.g., 5000)
/// @param {scalar} valuePY
/// usage example: [PY] (previous year/base value, grey, e.g., 4500)
/// @param {scalar} valueMAX
/// usage example: MAXX ( ALLSELECTED ( 'Category' ), MAX ( [AC], [PY] ) ) (maximum value for scaling)
/// @param {string} axiXLabel
/// usage example: 'Date'[Month Name] (axis X label, e.g., "January")
/// @param {string} dataLabel
/// usage example: FORMAT ( [AC] - [PY], "+#,0;-#,0;=" ) (data label, e.g., "+500")
/// @param {int64} businessImpact
/// usage example: 1 (business impact of variance > 0: 1 = positive e.g. sales, -1 = negative e.g. cost; inverts color only, not bar position)
/// @returns SVG image (data:image/svg+xml URI for embedding in table cells)
function 'PowerofBI.IBCS.ColumnChart.AbsoluteVarianceWide' =
		
		(
		    // main value (solid black)
		    valueAC: SCALAR VAL,
		    // base value (grey)
		    valuePY: SCALAR VAL,
		    // max value (for scaling
		    valueMAX: SCALAR VAL,
		    // axis x label
		    axiXLabel: STRING VAL,
		    // data label
		    dataLabel: STRING VAL,
		    // business impact of variance > 0: 1 (positive, sales) or -1 (negative, cost)
		    businessImpact: INT64 VAL
		) =>
		//=================================================================================================
		// Project: PowerofBI.IBCS: IBCS-guided data visualizations in your Power BI reports
		// Project Description: https://www.powerofbi.org/ibcs
		// DAX Lib package: https://daxlib.org/package/PowerofBI.IBCS/
		// PowerofBI.IBCS support: https://github.com/avatorl/dax-udf-svg-ibcs/issues
		// Author: Andrzej Leszkiewicz \u2014 IBCS\u00ae Certified Analyst
		// LinkedIn: https://www.linkedin.com/in/avatorl/
		// The visualization design adheres to IBCS recommendations: https://www.ibcs.com/ibcs-standards-1-2/
		//      but is NOT produced, certified, authorized, or endorsed by IBCS\u00ae
		//=================================================================================================
		// License: MIT License (free and permissive)
		// https://en.wikipedia.org/wiki/MIT_License
		//=================================================================================================
		//=================================================================================================
		// PowerofBI.IBCS.ColumnChart.AbsoluteVarianceWide function:
		//   This UDF renders a wide single-column visual comparing AC vs PY with a variance bar.
		//
		//   Features include:
		//     \u2022 PY reference column (grey or outlined) with AC overlay
		//     \u2022 Optional forecast column hook with hatched fill (currently disabled by design)
		//     \u2022 Red/green variance indicator sized by AC+FC vs PY
		//     \u2022 Data and period labels sized for matrix/table cell embedding
		//     \u2022 businessImpact parameter: -1 inverts color semantics (cost KPIs)
		//=================================================================================================
		//=================================================================================================
		// Required business values
		//=================================================================================================
		// Actual value (main column)
		VAR _ValueMain = valueAC  -- Current period actual value
		// Prior Year value (reference / base)
		VAR _ValueBase = valuePY  -- Previous year reference value
		// Forecast value (second column, disabled for now)
		VAR _ValueSecond = BLANK ( )  -- Not used in current implementation
		// Total rows are excluded from SVG rendering
		VAR _IsTotalRow = FALSE ( )  -- Always FALSE for single-column rendering
		// Month label displayed under the column
		VAR _PeriodLabel = axiXLabel  -- X-axis label (e.g., "January")
		// Maximum value across visible months, used for vertical scaling
		VAR _MaxValue = valueMAX  -- Scale reference for all visible periods
		// Text shown above / inside the column
		VAR _DataLabel = dataLabel  -- Variance value label (e.g., "+500")
		//=================================================================================================
		// Colors & typography
		//=================================================================================================
		// When = 1, draws a debug rectangle showing the SVG boundaries (useful during layout tuning)
		VAR _DEBUG = 0
		
		// Base column style: "grey" (IBCS standard) or "outlined"
		VAR _BaseType = "grey"  -- IBCS standard: grey background for PY
		// AC (actuals): solid dark fill
		VAR _ColorBlack = "#404040"
		// Unfavorable business impact
		VAR _ColorRed = "#E24B20"
		// Favorable business impact
		VAR _ColorGreen = "#08787D"
		// PY (previous year): neutral grey reference fill
		VAR _ColorGrey = "#C6C6C6"
		
		// Base column fill and outline depend on base type
		VAR _ColorBase =
		    SWITCH (
		        _BaseType,
		        "grey", _ColorGrey,
		        "outlined", "#FFFFFF"
		    )
		VAR _ColorBaseOutline =
		    SWITCH (
		        _BaseType,
		        "grey", _ColorGrey,
		        "outlined", _ColorBlack
		    )
		
		// Font size in points (Power BI-friendly)
		VAR _FontSizePt = 16
		
		// Font size converted to pixels (SVG uses px)
		VAR _Em = _FontSizePt * 4 / 3
		
		
		//=================================================================================================
		// SVG canvas & layout
		//=================================================================================================
		// Canvas size (must match visual formatting in Power BI)
		VAR _SVGHeight = 280
		VAR _SVGWidth = 55
		
		// Extra margin added by Power BI matrix cells (kept explicit)
		VAR _Margin = 0
		
		// Logical category width (column + margin)
		VAR _CategoryWidth = _SVGWidth + _Margin
		
		// Reserved areas for labels
		VAR _HeaderHeight = _Em * 1.5      // data label
		VAR _FooterHeight = _Em * 1.5      // period label
		// Plotting area (available height for columns)
		VAR _SVG_Body = _SVGHeight - _HeaderHeight - _FooterHeight
		
		// Column width: 2/3 of category width (IBCS proportion)
		VAR _ColumnWidth = ROUND ( _CategoryWidth * 2 / 3, 0 )
		
		// Horizontal shift to offset AC/FC from base column
		VAR _ColumnShift = ROUND ( _CategoryWidth / 9, 0 )
		
		
		//=================================================================================================
		// Column heights & Y positions
		// (SVG Y=0 is at the top, so higher values mean lower on screen)
		//=================================================================================================
		// Actual column height (scaled)
		VAR _HeightAC =
		    ROUND ( DIVIDE ( _ValueMain, _MaxValue ) * _SVG_Body, 0 )
		
		// Forecast column height (currently zero)
		VAR _HeightFC =
		    ROUND ( DIVIDE ( _ValueSecond, _MaxValue ) * _SVG_Body, 0 )
		
		// Base (PY) column height
		VAR _HeightPL =
		    ROUND ( DIVIDE ( _ValueBase, _MaxValue ) * _SVG_Body, 0 )
		
		// Y coordinates for each column
		VAR _YAC = _SVG_Body - _HeightAC + _HeaderHeight
		VAR _YFC = _SVG_Body - _HeightFC + _HeaderHeight - _HeightAC
		VAR _YPL = _SVG_Body - _HeightPL + _HeaderHeight
		
		
		//=================================================================================================
		// SVG scaffolding
		//=================================================================================================
		VAR _SVG_Header = "data:image/svg+xml;utf8,"
		VAR _SVG_Open =
		    "<svg xmlns='http://www.w3.org/2000/svg' height='"
		        & _SVGHeight
		        & "' width='"
		        & _SVGWidth
		        & "'>"
		VAR _SVG_Close = "</svg>"
		
		// Shared SVG text styling
		VAR _SVG_Style =
		    "<style>text{font-family:'Segoe UI', sans-serif;font-size:"
		        & _Em
		        & "px;dominant-baseline:middle;}</style>"
		
		
		//=================================================================================================
		// Optional hatched pattern (Forecast column)
		//=================================================================================================
		VAR SVG_HatchedPattern =
		    "<defs><pattern id='diagonal-stripe' patternUnits='userSpaceOnUse' width='8' height='8'>"
		        & "<rect width='8' height='8' fill='#FFFFFF'/>"
		        & "<path d='M-2,2 l4,-4 M0,8 l8,-8 M6,10 l4,-4' style='stroke:black; stroke-width:2'/>"
		        & "</pattern></defs>"
		
		
		//=================================================================================================
		// Column shapes
		//=================================================================================================
		// Base (PY) column
		VAR _SVG_Base =
		    "<rect x='1' width='" & _ColumnWidth & "' y='" & _YPL
		        & "' height='"
		        & _HeightPL
		        & "' fill='"
		        & _ColorBase
		        & "' stroke='"
		        & _ColorBaseOutline
		        & "' stroke-width='1' />"
		
		// Actual (AC) column
		VAR _SVG_AC =
		    "<rect x='" & 1 + _ColumnShift & "' width='" & _ColumnWidth
		        & "' y='"
		        & _YAC
		        & "' height='"
		        & _HeightAC
		        & "' fill='"
		        & _ColorBlack
		        & "' stroke='#000000' stroke-width='1' />"
		
		// Forecast (FC) column \u2013 rendered only if value exists
		VAR _SVG_FC =
		    IF (
		        ISBLANK ( _ValueSecond ),
		        "",
		        "<rect x='" & 1 + _ColumnShift & "' width='" & _ColumnWidth
		            & "' y='"
		            & _YFC
		            & "' height='"
		            & _HeightFC
		            & "' fill='url(#diagonal-stripe)' stroke='#000000' stroke-width='1' />"
		    )
		
		
		//=================================================================================================
		// Variance bar (AC + FC vs PY)
		//=================================================================================================
		// Combined actual + forecast
		VAR _ACFC = _ValueMain + _ValueSecond
		
		// Variance color based on sign and businessImpact
		VAR _VarianceColor =
		    IF (
		        ( _ACFC - _ValueBase ) * businessImpact >= 0,
		        _ColorGreen,
		        _ColorRed
		    )
		
		// Thin vertical bar indicating variance magnitude
		VAR _SVG_Variance =
		    "<rect x='"
		        & IF (
		        _ACFC >= _ValueBase,
		        _ColumnShift,
		        _ColumnWidth - _ColumnShift * 4
		    )
		        + 1
		        & "' width='"
		        & _ColumnShift * 4
		        & "' y='"
		        & MIN ( _YFC, _YPL )
		        & "' height='"
		        & ABS ( _YFC - _YPL ) - 1
		        & "' fill='"
		        & _VarianceColor
		        & "' stroke='"
		        & _VarianceColor
		        & "' stroke-width='1' />"
		
		
		//=================================================================================================
		// Labels
		//=================================================================================================
		// Data label Y position (inside column if space allows)
		VAR _LabelY =
		    IF (
		        _ACFC < _ValueBase && _HeightAC + _HeightFC > _Em,
		        _YFC + _Em * 0.7,
		        MIN ( _YFC, _YPL ) - _Em * 0.5
		    )
		VAR _LabelColor =
		    IF (
		        _ACFC < _ValueBase && _HeightAC + _HeightFC > _Em,
		        "#FFFFFF",
		        "#000000"
		    )
		
		// Actual value label
		VAR _SVG_DataLabel =
		    "<text text-anchor='middle' x='" & _ColumnWidth / 2 + 7
		        & "' y='"
		        & _LabelY
		        & "' fill='"
		        & _LabelColor
		        & "'>"
		        & _DataLabel
		        & "</text>"
		
		// Period (month) label
		VAR _SVG_PeriodLabel =
		    "<text text-anchor='middle' x='"
		        & 1 + _ColumnShift + _ColumnWidth / 2
		        & "' y='"
		        & _HeaderHeight + _SVG_Body + _Em * 0.8
		        & "'>"
		        & _PeriodLabel
		        & "</text>"
		
		
		//=================================================================================================
		// Final SVG assembly
		//=================================================================================================
		// Debug overlay to visualize available drawing area
		VAR _SVG_DebugBox =
		    IF (
		        _DEBUG,
		        "<rect id='rect-debug-box' x='0%' y='0%' width='100%' height='100%' fill='#FFFFAA' stroke-width='1' stroke='#FF0000' />",
		        ""
		    )
		VAR _SVG =
		    _SVG_Header & _SVG_Open & _SVG_DebugBox
		        & IF (
		            _IsTotalRow,
		            "",
		            _SVG_Base & _SVG_AC & _SVG_FC & _SVG_Variance
		        )
		        & _SVG_DataLabel
		        & _SVG_PeriodLabel
		        & _SVG_Style
		        & SVG_HatchedPattern
		        & _SVG_Close
		RETURN
		    _SVG
	lineageTag: 747374f3-4693-49ce-8fb5-6c3cca96fb27

	annotation DAXLIB_PackageId = PowerofBI.IBCS

	annotation DAXLIB_PackageVersion = 0.11.0

/// Creates a bar chart with absolute and relative variance visualization
/// @param {scalar} mainValueExpr
/// usage example: [AC] (actual value, solid black bar, e.g., 5000)
/// @param {scalar} baseValueExpr
/// usage example: [PY] (previous period/base value, grey bar, e.g., 4500)
/// @param {anyref} dimensionColumn
/// usage example: 'Category'[Category] (dimension column used to evaluate visible maximum for scaling)
/// @param {int64} imageWidth
/// usage example: 0 (default width 300px; use >0 for custom width in px)
/// @param {int64} businessImpact
/// usage example: 1 (business impact of variance > 0: 1 = positive e.g. sales, -1 = negative e.g. cost; inverts color only, not bar position)
/// @returns SVG image (data:image/svg+xml URI for embedding in table cells, includes PY bar, AC bar, and red/green variance bar)
function 'PowerofBI.IBCS.BarChart.WithAbsoluteVariance' =
		
		(
		    // actual value, solid black bar: [AC]
		    mainValueExpr: SCALAR EXPR,
		    // previous period/base value, grey bar: [PY]
		    baseValueExpr: SCALAR EXPR,
		    // dimension column for visible maximum scaling: 'Category'[Category]
		    dimensionColumn: ANYREF EXPR,
		    // image width, 0 = default 300px: 0
		    imageWidth: INT64 VAL,
		    // business impact of variance > 0: 1 (positive, sales) or -1 (negative, cost)
		    businessImpact: INT64 VAL
		) =>
		//=================================================================================================
		// Project: PowerofBI.IBCS: IBCS-guided data visualizations in your Power BI reports
		// Project Description: https://www.powerofbi.org/ibcs
		// DAX Lib package: https://daxlib.org/package/PowerofBI.IBCS/
		// PowerofBI.IBCS support: https://github.com/avatorl/dax-udf-svg-ibcs/issues
		// Author: Andrzej Leszkiewicz — IBCS® Certified Analyst
		// LinkedIn: https://www.linkedin.com/in/avatorl/
		// The visualization design adheres to IBCS recommendations: https://www.ibcs.com/ibcs-standards-1-2/
		//      but is NOT produced, certified, authorized, or endorsed by IBCS®
		//=================================================================================================
		// License: MIT License (free and permissive)
		// https://en.wikipedia.org/wiki/MIT_License
		//=================================================================================================
		//=================================================================================================
		// PowerofBI.IBCS.BarChart.WithAbsoluteVariance function:
		//   This UDF outputs a compact horizontal bar chart with AC vs PY and a variance marker.
		//
		//   Features include:
		//     - PY baseline bar (grey) positioned at top
		//     - AC main bar (dark) overlaid and offset below PY bar
		//     - Red/green variance bar showing difference between AC and PY
		//     - AC value label positioned at end of AC bar (direction-aware alignment)
		//     - Auto-scaling based on ALLSELECTED maximum across the dimension
		//     - Adjustable width for tight table cells
		//     - businessImpact parameter: -1 inverts color semantics (cost KPIs)
		//=================================================================================================
		// When = 1, draws a debug rectangle showing the SVG boundaries (useful during layout tuning)
		VAR _DEBUG = 0
		
		// AC (actuals): solid dark fill
		VAR _ColorBlack = "#404040"
		
		// PY (previous year): neutral grey reference fill
		VAR _ColorGrey = "#C6C6C6"
		
		// Unfavorable business impact
		VAR _ColorRed = "#E24B20"
		
		// Favorable business impact
		VAR _ColorGreen = "#08787D"
		
		// Font size in points
		VAR _FontSizePt = 18
		
		// SVG width (default 300px)
		VAR _SVG_Width = IF ( imageWidth = 0, 300, imageWidth )
		
		// Right padding
		VAR _RightPad = 5
		
		// Label padding
		VAR _LabelPad = 5
		
		// Font size in pixels (SVG uses px, not pt)
		VAR _Em = ROUND ( _FontSizePt * 4 / 3, 0 )
		
		//=================================================================================================
		// VALUES
		//=================================================================================================
		// Actual value (main bar)
		VAR _ValueAC = mainValueExpr
		
		// Previous year value (baseline bar)
		VAR _ValuePY = baseValueExpr
		
		// Variance: AC - PY
		VAR _DeltaPY =
		    IF ( ISBLANK ( _ValuePY ), BLANK ( ), _ValueAC - _ValuePY )
		
		// Max visible value (AC or PY) used for horizontal scaling
		VAR _MaxValue =
		    MAX (
		        MAXX (
		            ALLSELECTED ( dimensionColumn ),
		            CALCULATE ( mainValueExpr )
		        ),
		        MAXX (
		            ALLSELECTED ( dimensionColumn ),
		            CALCULATE ( baseValueExpr )
		        )
		    )
		
		//=================================================================================================
		// BAR DIMENSIONS
		//=================================================================================================
		// Available width for bars
		VAR _SVG_ColumnWidth = _SVG_Width - _RightPad
		
		// PY bar width in pixels
		VAR _WidthPY =
		    ROUND ( DIVIDE ( _ValuePY, _MaxValue ) * _SVG_ColumnWidth, 0 )
		
		// AC bar width in pixels
		VAR _WidthAC =
		    ROUND ( DIVIDE ( _ValueAC, _MaxValue ) * _SVG_ColumnWidth, 0 )
		
		// Variance bar width (difference between AC and PY)
		VAR _WidthDeltaPY =
		    IF ( ISBLANK ( _ValuePY ), 0, ABS ( _WidthAC - _WidthPY ) - 1 )
		
		//=================================================================================================
		// VARIANCE BAR POSITION & STYLING
		//=================================================================================================
		// Variance bar X position
		VAR _X =
		    SWITCH (
		        TRUE ( ),
		        _DeltaPY >= 0, _WidthPY,
		        _WidthAC
		    ) + 1
		
		// Variance bar Y position
		VAR _Y =
		    SWITCH (
		        TRUE ( ),
		        _DeltaPY >= 0, ROUNDUP ( _Em * 0.25, 0 ),
		        ROUNDUP ( _Em * 0.75, 0 )
		    )
		
		// Variance bar color (flipped by businessImpact)
		VAR _BarColor =
		    IF ( _DeltaPY * businessImpact > 0, _ColorGreen, _ColorRed )
		
		// Label positioning
		VAR _LabelOffsetX =
		    IF ( _DeltaPY = 0, _LabelPad, SIGN ( _DeltaPY ) * _LabelPad )
		VAR _TextAnchor = IF ( _DeltaPY >= 0, "start", "end" )
		VAR _TextColor = IF ( _DeltaPY >= 0, "black", "white" )
		
		//=================================================================================================
		// SVG ASSEMBLY
		//=================================================================================================
		// Debug overlay to visualize available drawing area
		VAR _SVG_DebugBox =
		    IF (
		        _DEBUG,
		        "<rect id='rect-debug-box' x='0%' y='0%' width='100%' height='100%' fill='#FFFFAA' stroke-width='1' stroke='#FF0000' />",
		        ""
		    )
		VAR _SVG =
		    "data:image/svg+xml;utf8,"
		        & "<svg xmlns='http://www.w3.org/2000/svg'>"
		        & _SVG_DebugBox
		        & "<rect x='0' y='0' width='"
		        & _WidthPY
		        & "' height='"
		        & _Em
		        & "' fill='"
		        & _ColorGrey
		        & "' stroke='"
		        & _ColorGrey
		        & "' />"
		        & "<rect x='0' y='"
		        & ROUND ( _Em * 0.25, 0 )
		        & "' width='"
		        & _WidthAC
		        & "' height='"
		        & _Em
		        & "' fill='"
		        & _ColorBlack
		        & "' stroke='"
		        & _ColorBlack
		        & "' />"
		        & "<rect x='"
		        & _X
		        & "' y='"
		        & _Y
		        & "' width='"
		        & _WidthDeltaPY
		        & "' height='"
		        & ROUND ( _Em * 0.25, 0 )
		        & "' fill='"
		        & _BarColor
		        & "' stroke='"
		        & _BarColor
		        & "' />"
		        & "<text x='"
		        & _WidthAC
		        & "' dx='"
		        & _LabelOffsetX
		        & "' y='"
		        & _Em * 0.75 - 2
		        & "' text-anchor='"
		        & _TextAnchor
		        & "' fill='"
		        & _TextColor
		        & "'>"
		        & _ValueAC
		        & "</text>"
		        & "<style>text{font-family:'Segoe UI',sans-serif;font-size:"
		        & _Em
		        & "px;dominant-baseline:central;}</style>"
		        & "</svg>"
		RETURN
		    _SVG
	lineageTag: b7e2e643-f482-4154-9546-187a9e4f8024

	annotation DAXLIB_PackageId = PowerofBI.IBCS

	annotation DAXLIB_PackageVersion = 0.11.0

/// Builds a 3-line IBCS-guided title string separated by line breaks.
/// Empty lines are omitted (no trailing blank lines).
/// @param {string} line1
/// usage example: "Net profit in mUSD" (first line: what and unit)
/// @param {string} line2
/// usage example: "variance from location average" (second line: how/context)
/// @param {string} line3
/// usage example: "2016.2022 AC, 2023..2024 PL" (third line: time range and scenario)
/// @returns String with lines separated by UNICHAR(10) for multi-line display
function 'PowerofBI.IBCS.Helpers.Title' =
		
		(
		    // first line (what and unit): "Net profit in mUSD"
		    line1: STRING VAL,
		    // second line (how/context): "variance from location average"
		    line2: STRING VAL,
		    // third line (time range and scenario): "2016.2022 AC, 2023..2024 PL"
		    line3: STRING VAL
		) =>
		//=================================================================================================
		// Project: PowerofBI.IBCS: IBCS-guided data visualizations in your Power BI reports
		// Project Description: https://www.powerofbi.org/ibcs
		// DAX Lib package: https://daxlib.org/package/PowerofBI.IBCS/
		// PowerofBI.IBCS support: https://github.com/avatorl/dax-udf-svg-ibcs/issues
		// Author: Andrzej Leszkiewicz
		// LinkedIn: https://www.linkedin.com/in/avatorl/
		// The visualization design adheres to IBCS recommendations: https://www.ibcs.com/ibcs-standards-1-2/
		//      but is NOT produced, certified, authorized, or endorsed by IBCS
		//=================================================================================================
		// License: MIT License (free and permissive)
		// https://en.wikipedia.org/wiki/MIT_License
		//=================================================================================================
		VAR _Newline = UNICHAR ( 10 )
		VAR _Result =
		    line1 & IF ( LEN ( line2 ) > 0, _Newline & line2 )
		        & IF ( LEN ( line3 ) > 0, _Newline & line3 )
		RETURN
		    _Result
	lineageTag: fdedb15d-748d-4b16-affe-d670bae763a1

	annotation DAXLIB_PackageId = PowerofBI.IBCS

	annotation DAXLIB_PackageVersion = 0.11.0

