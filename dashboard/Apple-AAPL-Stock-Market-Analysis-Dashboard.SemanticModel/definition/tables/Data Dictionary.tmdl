				        { "_Measures", "Trend State", "Measure", "02 - Trend & Momentum", "Identifies whether the asset is in a Golden Cross (50 SMA > 200 SMA) or Death Cross (50 SMA < 200 SMA)." },
				        { "_Measures", "Daily Drawdown %", "Measure", "03 - Risk & Volatility", "The continuous percentage drop from the highest historical peak within the currently selected time window." },
				        { "_Measures", "Max Drawdown", "Measure", "03 - Risk & Volatility", "Iterates over the selected context to find the absolute worst 'peak-to-trough' decline. The ultimate metric for downside pain tolerance." },
