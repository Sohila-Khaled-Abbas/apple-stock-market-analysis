			        100% { box-shadow: 0 0 0 0 rgba(41, 151, 255, 0); }
			    }
			    
			    /* Interactive Hover States */
			    .metric-card {
			        background: #1d1d1f; 
			        border: 1px solid #424245; 
			        border-radius: 12px; 
			        padding: 15px 25px; 
