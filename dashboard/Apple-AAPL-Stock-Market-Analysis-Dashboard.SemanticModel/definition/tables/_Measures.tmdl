	/// Binary flag (1/0) — returns 1 only when the current Calendar date has real AAPL trading data. Used as a visual-level filter in Deneb charts to suppress weekend and holiday rows that cause flat-step artifacts in RSI/SMA lines and gaps in candlestick/volume charts.
	measure 'Is Trading Day' = ```
			
			// Returns 1 only for dates that have actual AAPL trading data
			// Used as a filter in Deneb visuals to eliminate weekend/holiday gaps
			IF(
			    NOT(ISBLANK(CALCULATE(MAX(aapl_daily[Close_Price])))),
			    1,
			    0
			)
			
			```
		formatString: 0
		displayFolder: 06 - Deneb (Chart Data)
		lineageTag: be6afa99-ca86-4a96-a945-e19fcec6bd39

	/// 
	/// Supplies the Candlestick Deneb visual with a pre-formatted date string (YYYY-MM-DD) for the x-axis. Returns BLANK() on non-trading days so Deneb's transform/filter can exclude those rows cleanly.
	/// 
	measure 'Trade Date Key' = ```
			
			// Returns formatted trade date only for actual trading days
			// Deneb visuals should add a filter transform: {"filter": {"field": "Trade Date Key", "valid": true}}
			VAR HasData = NOT(ISBLANK(CALCULATE(MAX(aapl_daily[Close_Price]))))
			RETURN
			    IF(HasData, FORMAT(MAX('Calendar'[Date]), "YYYY-MM-DD"), BLANK())
			
			```
		displayFolder: 06 - Deneb (Chart Data)
		lineageTag: 5cbde6c4-d437-4e4e-a589-28f031f7ded2

	/// RSI (14-Day) restricted to trading days only. Returns BLANK on weekends/holidays to prevent flat-step artifacts in Deneb line charts.
	measure 'RSI (14-Day) Deneb' = ```
			
			// RSI variant that returns BLANK on non-trading days.
			// Prevents the flat "step" artifact in Deneb line charts
			// where RSI holds its last value across weekends/holidays.
			VAR HasData = NOT(ISBLANK(CALCULATE(MAX(aapl_daily[Close_Price]))))
			RETURN IF(HasData, [RSI (14-Day)], BLANK())
			
			```
		formatString: 0.00
		displayFolder: 06 - Deneb (Chart Data)
		lineageTag: 8490a567-d6bf-4d9b-acfe-b27976170c23

