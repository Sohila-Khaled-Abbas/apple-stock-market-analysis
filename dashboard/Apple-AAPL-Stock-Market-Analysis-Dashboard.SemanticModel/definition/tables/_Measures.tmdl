			    .kpi-card-trend { 
			        width: 100%; 
			        height: 100%; 
			        background: linear-gradient(145deg, #1d1d1f 0%, #151516 100%); 
			        border: 1px solid #424245; 
			        border-radius: 16px; 
			        padding: 20px; 
