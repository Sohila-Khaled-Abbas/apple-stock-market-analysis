			</style>
			<div class='kpi-card-trend'>
			    <div style='width: 54px; height: 54px; border-radius: 14px; background: " & RgbaBg & "; display: flex; align-items: center; justify-content: center; flex-shrink: 0;'>" & IconSVG & "</div>
			    <div style='display: flex; flex-direction: column;'>
			        <div style='color: #86868b; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2px;'>Momentum Trend</div>
			        <div style='color: " & HexColor & "; font-size: 30px; font-weight: 700; letter-spacing: -0.02em;'>" & State & "</div>
			        
			        <div style='color: transparent; font-size: 12px; font-weight: 500; margin-top: 2px; user-select: none;'>&nbsp;</div>
			    </div>
			</div>"
			```
		displayFolder: 07 - KPI Cards
		lineageTag: dfe94c7a-d3fc-43e8-8c25-425f729de6d0

	measure 'KPI - RSI' =
			
			VAR RawRSI = [RSI (14-Day)]
			VAR FormatRSI = FORMAT(RawRSI, "0.0")
			VAR StatusText = IF(RawRSI >= 70, "OVERBOUGHT", IF(RawRSI <= 30, "OVERSOLD", "NEUTRAL"))
			VAR HexColor = IF(RawRSI >= 70, "#ff453a", IF(RawRSI <= 30, "#30d158", "#64d2ff"))
			VAR RgbaBg = IF(RawRSI >= 70, "rgba(255, 69, 58, 0.12)", IF(RawRSI <= 30, "rgba(48, 209, 88, 0.12)", "rgba(100, 210, 255, 0.12)"))
			VAR IconSVG = "<svg viewBox='0 0 24 24' fill='none' stroke='" & HexColor & "' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='width: 26px; height: 26px;'><path d='M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0'></path><path d='M12 7v5l3 3'></path></svg>"
			
			RETURN
			"<style>
			    .kpi-card-rsi { width: 100%; background: linear-gradient(145deg, #1d1d1f 0%, #151516 100%); border: 1px solid #424245; border-radius: 16px; padding: 20px; display: flex; align-items: center; gap: 18px; height: 100%; box-sizing: border-box; font-family: -apple-system, BlinkMacSystemFont, sans-serif; transition: all 0.2s ease; }
			    .kpi-card-rsi:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.4); border-color: " & HexColor & "; }
			</style>
			<div class='kpi-card-rsi'>
			    <div style='width: 54px; height: 54px; border-radius: 14px; background: " & RgbaBg & "; display: flex; align-items: center; justify-content: center; flex-shrink: 0;'>" & IconSVG & "</div>
			    <div style='display: flex; flex-direction: column;'>
			        <div style='color: #86868b; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2px;'>Relative Strength (14D)</div>
			        <div style='display: flex; align-items: center; gap: 12px;'>
			            <span style='color: #f5f5f7; font-size: 30px; font-weight: 700; letter-spacing: -0.02em;'>" & FormatRSI & "</span>
			            <span style='font-size: 11px; font-weight: 700; letter-spacing: 0.05em; padding: 4px 8px; border-radius: 6px; background-color: " & RgbaBg & "; color: " & HexColor & ";'>" & StatusText & "</span>
			        </div>
			        <div style='color: transparent; font-size: 12px; font-weight: 500; margin-top: 2px; user-select: none;'>&nbsp;</div>
			    </div>
			</div>"
		displayFolder: 07 - KPI Cards
		lineageTag: a21c9185-5155-4d7b-a904-331dbbb0836a

	measure 'Dynamic Business Recommendation' = ```
			
			// 1. Fetch Current States
			VAR CurrentRSI = [RSI (14-Day)]
			VAR CurrentTrend = [Trend State]
			VAR CurrentDrawdown = [Daily Drawdown %]
			VAR CurrentBeta = [Beta (AAPL to Market)]
			
			// 2. Define the Analytical Logic Engine (Internal Momentum)
			VAR MarketStance = 
			    SWITCH(
			        TRUE(),
			        // Scenario 1: Severe Capitulation
			        SEARCH("Bearish", CurrentTrend, 1, 0) > 0 && CurrentRSI <= 30, 
			        "SEVERE OVERSOLD CONDITIONS: AAPL is currently in a macro Death Cross but has reached technical exhaustion (RSI < 30). Capital preservation is prioritized, but monitor for volume surges indicating institutional accumulation at these discounted levels.",
			        
			        // Scenario 2: Macro Downtrend
			        SEARCH("Bearish", CurrentTrend, 1, 0) > 0 && CurrentRSI > 30,
			        "MACRO DOWNTREND: The 50-day SMA remains below the 200-day SMA, indicating sustained institutional distribution. Avoid heavy accumulation until a confirmed trend reversal (Golden Cross) is established.",
			        
			        // Scenario 3: Overextended Bull Market
			        SEARCH("Bullish", CurrentTrend, 1, 0) > 0 && CurrentRSI >= 70,
			        "OVERBOUGHT CONDITIONS: While the macro trend is highly favorable (Golden Cross), short-term momentum is overextended (RSI > 70). Risk of a short-term pullback is high. Hold current positions, but delay new capital deployment.",
			        
			        // Scenario 4: Healthy Bull Market (Default)
			        SEARCH("Bullish", CurrentTrend, 1, 0) > 0 && CurrentRSI < 70,
			        "FAVORABLE ACCUMULATION: The asset remains in a confirmed macro uptrend without triggering short-term overbought warnings. Risk-adjusted momentum supports continued holding or systematic accumulation.",
			        
			        "INSUFFICIENT DATA: Awaiting further price action to determine trend state."
			    )
			
			// 3. Define the Macro Volatility Context (Beta & Drawdown)
			VAR DrawdownContext = 
			    IF(
			        CurrentDrawdown < -0.15, 
			        " The portfolio is actively facing a severe drawdown of " & FORMAT(CurrentDrawdown, "0.0%") & " from all-time highs. ", 
			        ""
			    )
			
			VAR BetaContext = 
			    SWITCH(
			        TRUE(),
			        ISBLANK(CurrentBeta), "",
			        
			        CurrentBeta > 1.2, 
			        "<br><br><span style='color: #ff9f0a; font-weight: 600;'>Volatility Alert:</span> The asset exhibits a High Beta (" & FORMAT(CurrentBeta, "0.00") & "), meaning it is amplifying S&P 500 movements. Expect accelerated gains during market rallies, but severe exposure during macro corrections.",
			        
			        CurrentBeta < 0.8, 
			        "<br><br><span style='color: #30d158; font-weight: 600;'>Defensive Posture:</span> The asset exhibits a Low Beta (" & FORMAT(CurrentBeta, "0.00") & "), moving somewhat independently of the S&P 500. This provides excellent portfolio stabilization against broader market shocks.",
			        
			        "<br><br><span style='color: #64d2ff; font-weight: 600;'>Market Neutral:</span> The asset's Beta (" & FORMAT(CurrentBeta, "0.00") & ") indicates it is tracking closely with the broader S&P 500, offering baseline market exposure without outsized systemic risk."
			    )
			
			// 4. Construct the HTML UI
			RETURN
			"
			<div style='
			    background: linear-gradient(145deg, rgba(41, 151, 255, 0.05) 0%, rgba(29, 29, 31, 0.8) 100%);
			    border-left: 4px solid #2997ff;
			    border-radius: 0 12px 12px 0;
			    padding: 24px;
			    font-family: -apple-system, BlinkMacSystemFont, sans-serif;
			    box-sizing: border-box;
			    width: 100%;
			'>
			    <div style='display: flex; align-items: center; gap: 12px; margin-bottom: 12px;'>
			        <svg viewBox='0 0 24 24' fill='none' stroke='#2997ff' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='width: 20px; height: 20px;'>
			            <circle cx='12' cy='12' r='10'></circle>
			            <line x1='12' y1='16' x2='12' y2='12'></line>
			            <line x1='12' y1='8' x2='12.01' y2='8'></line>
			        </svg>
			        <span style='color: #f5f5f7; font-size: 16px; font-weight: 600; letter-spacing: 0.02em;'>Quantitative Advisory</span>
			    </div>
			    <div style='color: #86868b; font-size: 14px; line-height: 1.6; letter-spacing: 0.01em;'>
			        <strong style='color: #ffffff;'>" & MarketStance & "</strong>" & DrawdownContext & BetaContext & "
			    </div>
			</div>
			"
			```
		displayFolder: 07 - KPI Cards
		lineageTag: 2ee8c6dd-ac12-4e78-afce-7948d4ad5118

