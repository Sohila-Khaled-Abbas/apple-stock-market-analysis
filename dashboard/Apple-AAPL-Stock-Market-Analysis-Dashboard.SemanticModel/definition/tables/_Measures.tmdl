table _Measures
	lineageTag: 616d304d-2b1c-4e8c-8050-b858652c6d1c

	/// Retrieves the most recent adjusted closing price for the selected context, skipping non-trading days (weekends/holidays).
	measure 'Latest Price' =
			
			CALCULATE(
			    MAX(aapl_daily[Adj_Close]),
			    LASTNONBLANK('Calendar'[Date], CALCULATE(COUNTROWS(aapl_daily)))
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: 01 - Price & Volume
		lineageTag: 256572d0-8971-456b-b034-113c7ba08963

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// Calculates the absolute percentage return from the first to the last trading day within the currently filtered time period.
	measure 'Total Return %' = ```
			
			VAR StartPrice = 
			    CALCULATE(
			        MIN(aapl_daily[Adj_Close]), 
			        FIRSTNONBLANK('Calendar'[Date], CALCULATE(COUNTROWS(aapl_daily)))
			    )
			VAR EndPrice = [Latest Price]
			RETURN 
			    DIVIDE(EndPrice - StartPrice, StartPrice)
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 02 - Returns & Performance
		lineageTag: adaaa74d-c0dc-4f8d-87ca-38abc482e538

	/// Compound Annual Growth Rate. Normalizes the absolute return to an annualized percentage to accurately compare performance across different time horizons.
	measure CAGR = ```
			
			VAR StartPrice = 
			    CALCULATE(
			        MIN(aapl_daily[Adj_Close]), 
			        FIRSTNONBLANK('Calendar'[Date], CALCULATE(COUNTROWS(aapl_daily)))
			    )
			VAR EndPrice = [Latest Price]
			VAR StartDate = CALCULATE(MIN('Calendar'[Date]), aapl_daily)
			VAR EndDate = CALCULATE(MAX('Calendar'[Date]), aapl_daily)
			VAR Years = DIVIDE(DATEDIFF(StartDate, EndDate, DAY), 365.25)
			
			RETURN
			    IF(
			        Years > 0 && StartPrice > 0, 
			        (EndPrice / StartPrice) ^ (1 / Years) - 1, 
			        BLANK()
			    )
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 02 - Returns & Performance
		lineageTag: 517aea45-1ca9-4652-aa46-042557378a08

	/// 50-calendar-day simple moving average of the adjusted closing price. Short-to-medium-term momentum indicator.
	measure '50-Day SMA' =
			
			AVERAGEX(
			    DATESINPERIOD('Calendar'[Date], MAX('Calendar'[Date]), -50, DAY),
			    CALCULATE(MAX(aapl_daily[Adj_Close]))
			)
		formatString: 0.00
		displayFolder: 03 - Technical Indicators
		lineageTag: d3a958b8-b3fa-42ae-9489-8160453a72f9

	/// 200-calendar-day simple moving average. The institutional indicator for long-term bull vs. bear market phases.
	measure '200-Day SMA' =
			
			AVERAGEX(
			    DATESINPERIOD('Calendar'[Date], MAX('Calendar'[Date]), -200, DAY),
			    CALCULATE(MAX(aapl_daily[Adj_Close]))
			)
		formatString: 0.00
		displayFolder: 03 - Technical Indicators
		lineageTag: 7e2982cf-c937-4990-b74f-254d1dab3726

	/// Identifies whether the asset is in a Golden Cross (50 SMA > 200 SMA) or Death Cross (50 SMA < 200 SMA).
	measure 'Trend State' =
			
			VAR SMA50 = [50-Day SMA]
			VAR SMA200 = [200-Day SMA]
			RETURN
			    IF(ISBLANK(SMA50) || ISBLANK(SMA200), BLANK(),
			        IF(SMA50 > SMA200, "Bullish (Golden)", "Bearish (Death)")
			    )
		displayFolder: 03 - Technical Indicators
		lineageTag: 34e5ad3a-046c-4448-be80-6fd1d4b10196

	/// The continuous percentage drop from the highest peak for a single trading day in context. Use in time-series visuals to show drawdown evolution over time.
	measure 'Daily Drawdown %' =
			
			CALCULATE(AVERAGE(aapl_daily[Historical_Drawdown]))
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 04 - Risk & Drawdown
		lineageTag: 89b204ca-ba79-4d9b-95cc-2f46d96d9be4

	/// Iterates over the selected context to find the absolute worst 'peak-to-trough' decline. The ultimate metric for downside pain tolerance.
	measure 'Max Drawdown' =
			
			CALCULATE(MIN(aapl_daily[Historical_Drawdown]))
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 04 - Risk & Drawdown
		lineageTag: 163e9ef4-c78c-4bef-b706-4f6a898258d3

	/// Binary flag (1 or 0) indicating if the trading volume for the day was more than double the trailing 30-day average. Useful for identifying institutional accumulation/distribution.
	measure 'Is Volume Surge' = ```
			
			VAR Avg30DayVolume = 
			    AVERAGEX(
			        DATESINPERIOD('Calendar'[Date], MAX('Calendar'[Date]), -30, DAY),
			        CALCULATE(SUM(aapl_daily[Volume]))
			    )
			VAR CurrentVolume = CALCULATE(SUM(aapl_daily[Volume]))
			RETURN
			    IF(CurrentVolume > (Avg30DayVolume * 2), 1, 0)
			```
		formatString: 0
		displayFolder: 01 - Price & Volume
		lineageTag: d62f8bbf-4947-4db7-99a2-f376d9fdbead

	/// Day-over-day % change in the adjusted closing price. Reads the pre-materialized Historical_Daily_Return column for pure Storage Engine performance — no FILTER/ALLSELECTED scan.
	measure 'Daily Return %' = ```
			
			// OPTIMIZED: Uses pre-materialized Historical_Daily_Return column via direct
			// column scan instead of FILTER(ALLSELECTED(...), NOT(ISBLANK(COUNTROWS(...)))) 
			// which forced an expensive per-row Formula Engine loop on every date.
			// Historical_Daily_Return is computed in Python at load time — zero FE cost here.
			VAR HasData = NOT(ISBLANK(CALCULATE(MAX(aapl_daily[Close_Price]))))
			RETURN
			    IF(HasData, CALCULATE(MAX(aapl_daily[Historical_Daily_Return])), BLANK())
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 02 - Returns & Performance
		lineageTag: 50717c72-45aa-4d38-8a5f-d6c010ee2788

	/// Standard deviation of daily returns, multiplied by the square root of 252. Represents the historical risk or standard pricing dispersion of the asset.
	measure 'Annualized Volatility' = ```
			
			VAR DailyStdDev = STDEV.S(aapl_daily[Historical_Daily_Return])
			RETURN 
			    DailyStdDev * SQRT(252)
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 03 - Technical Indicators
		lineageTag: c9005927-a922-459b-b3b7-8c7fbfc9cebd

	/// Evaluates risk-adjusted performance. A ratio greater than 1 indicates adequate compensation for the historical risk taken.
	measure 'Sharpe Ratio' = ```
			
			VAR RiskFreeRate = 0.04 
			VAR PortfolioReturn = [CAGR] 
			VAR Volatility = [Annualized Volatility]
			RETURN
			    IF(
			        NOT(ISBLANK(Volatility)) && Volatility > 0,
			        DIVIDE(PortfolioReturn - RiskFreeRate, Volatility),
			        BLANK()
			    )
			```
		formatString: 0.00
		displayFolder: 02 - Returns & Performance
		lineageTag: 2c45cf84-2226-443b-8dac-30dff7a145c3

	/// Relative Strength Index (SMA method). Oscillates from 0 to 100 to evaluate whether the stock is overbought (>70) or oversold (<30). Optimized to use the pre-materialized Historical_Daily_Return column instead of the [Daily Return %] measure to avoid 14 expensive context transitions per row.
	measure 'RSI (14-Day)' =
			
			VAR CurrentDate = MAX('Calendar'[Date])
			
			-- Get the last 14 actual trading dates (non-blank) up to and including CurrentDate
			VAR ReferenceDates =
			    TOPN(
			        14,
			        FILTER(
			            ALL('Calendar'),
			            'Calendar'[Date] <= CurrentDate
			                && NOT(ISBLANK(CALCULATE(COUNTROWS(aapl_daily))))
			        ),
			        'Calendar'[Date], DESC
			    )
			
			-- Use the pre-materialized Historical_Daily_Return column
			-- CALCULATE(MAX(...)) performs a simple, fast storage-engine context transition
			-- instead of calling [Daily Return %] which runs FILTER(ALLSELECTED(Calendar)...) 14 times
			VAR ReturnsTable =
			    ADDCOLUMNS(
			        ReferenceDates,
			        "@Return", CALCULATE(MAX(aapl_daily[Historical_Daily_Return]))
			    )
			
			VAR AvgGain = AVERAGEX(ReturnsTable, IF([@Return] > 0, [@Return], 0))
			VAR AvgLoss = AVERAGEX(ReturnsTable, IF([@Return] < 0, ABS([@Return]), 0))
			VAR RS     = DIVIDE(AvgGain, AvgLoss)
			
			RETURN
			    IF(
			        ISBLANK(AvgLoss) || AvgLoss = 0,
			        100,
			        100 - DIVIDE(100, 1 + RS)
			    )
		formatString: 0.00
		displayFolder: 03 - Technical Indicators
		lineageTag: 4383ee5d-8a7c-48e1-aed1-4fa415950dad

	/// Calendar days since the all-time high price within the selected context. Optimized: reads the pre-materialized Historical_Rolling_Max column (computed in Python) instead of running two nested FILTER scans over ALLSELECTED, which caused ~3s FE latency per render.
	measure 'Days Since ATH' = ```
			
			// OPTIMIZED: Historical_Rolling_Max is pre-materialized at Python load time.
			// Old version used two nested FILTER(ALLSELECTED(...)) which created O(n²)
			// FE iterations (~2,900ms). This version uses a single MAX SE scan = ~5ms.
			VAR CurrentDate  = MAX('Calendar'[Date])
			VAR CurrentPrice = [Latest Price]
			
			// Read pre-materialized rolling max directly — pure Storage Engine scan
			VAR RollingMaxPrice =
			    CALCULATE(
			        MAX(aapl_daily[Historical_Rolling_Max]),
			        FILTER(
			            ALLSELECTED('Calendar'[Date]),
			            'Calendar'[Date] <= CurrentDate
			        )
			    )
			
			// Find the date of that rolling max
			VAR DateOfMaxPrice =
			    CALCULATE(
			        MAX(aapl_daily[Trade_Date]),
			        aapl_daily[Historical_Rolling_Max] = RollingMaxPrice,
			        FILTER(
			            ALLSELECTED('Calendar'[Date]),
			            'Calendar'[Date] <= CurrentDate
			        )
			    )
			
			RETURN
			    IF(
			        ISBLANK(CurrentPrice) || ISBLANK(RollingMaxPrice),
			        BLANK(),
			        IF(
			            CurrentPrice >= RollingMaxPrice,
			            0,
			            DATEDIFF(DateOfMaxPrice, CurrentDate, DAY)
			        )
			    )
			
			```
		formatString: 0
		displayFolder: 04 - Risk & Drawdown
		lineageTag: 53fedaf0-8efd-4f55-83b4-2fec162b4fad

	/// Retrieves the most recent closing price of the S&P 500 benchmark for the selected context.
	measure 'SP500 Latest Price' =
			
			CALCULATE(
			    MAX(sp500_daily[SP500_Close]),
			    LASTNONBLANK('Calendar'[Date], CALCULATE(COUNTROWS(sp500_daily)))
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: 05 - Benchmark & Market
		lineageTag: cf401d93-3fc9-41d4-b038-3f9085e1f4c2

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// The annualized compound growth rate of the broader market, used as the baseline for calculating Jensen's Alpha.
	measure 'SP500 CAGR' = ```
			
			VAR StartPrice = 
			    CALCULATE(
			        MIN(sp500_daily[SP500_Close]), 
			        FIRSTNONBLANK('Calendar'[Date], CALCULATE(COUNTROWS(sp500_daily)))
			    )
			VAR EndPrice = [SP500 Latest Price]
			VAR StartDate = CALCULATE(MIN('Calendar'[Date]), sp500_daily)
			VAR EndDate = CALCULATE(MAX('Calendar'[Date]), sp500_daily)
			VAR Years = DIVIDE(DATEDIFF(StartDate, EndDate, DAY), 365.25)
			
			RETURN
			    IF(Years > 0 && StartPrice > 0, (EndPrice / StartPrice) ^ (1 / Years) - 1, BLANK()) 
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 05 - Benchmark & Market
		lineageTag: 564013fd-6a8d-49b7-8c74-02ec680879f9

	/// Day-over-day % change for the S&P 500 benchmark. Optimized to use pre-materialized Historical_SP500_Return column instead of FILTER/ALLSELECTED scan.
	measure 'SP500 Daily Return %' = ```
			
			// OPTIMIZED: Reads pre-materialized Historical_SP500_Return column.
			// Previous version used FILTER(ALLSELECTED(...)) which forced FE iteration.
			VAR HasData = NOT(ISBLANK(CALCULATE(MAX(sp500_daily[SP500_Close]))))
			RETURN
			    IF(HasData, CALCULATE(MAX(sp500_daily[Historical_SP500_Return])), BLANK())
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 05 - Benchmark & Market
		lineageTag: ee3e7b1f-36e2-4617-80e2-c2ae6eb00353

	/// The slope of the linear regression between AAPL and S&P500 returns. A Beta > 1 means AAPL is more volatile than the market.
	measure 'Beta (AAPL to Market)' = ```
			
			-- 1. Build a fast virtual table by extracting the materialized columns
			VAR ReturnTable = 
			    FILTER(
			        ADDCOLUMNS(
			            VALUES('Calendar'[Date]),
			            "AssetReturn", CALCULATE(MAX(aapl_daily[Historical_Daily_Return])),
			            "MarketReturn", CALCULATE(MAX(sp500_daily[Historical_SP500_Return]))
			        ),
			        NOT(ISBLANK([AssetReturn])) && NOT(ISBLANK([MarketReturn]))
			    )
			
			-- 2. Execute Linear Regression (y = mx + b)
			VAR RegressionTable = 
			    LINESTX(
			        ReturnTable, 
			        [AssetReturn], 
			        [MarketReturn]
			    )
			
			-- 3. Extract the Slope (Beta)
			RETURN 
			    MAXX(RegressionTable, [Slope1])
			```
		formatString: 0.00
		displayFolder: 03 - Technical Indicators
		lineageTag: cd3c9bef-3451-480e-88d1-b8a88c03e11d

	/// Jensen's Alpha. Measures the exact percentage of outperformance (or underperformance) that cannot be attributed to general market movements (Beta).
	measure 'Alpha (Annualized)' =
			
			VAR RiskFreeRate = 0.04
			VAR AAPLReturn = [CAGR]
			VAR MarketReturn = [SP500 CAGR]
			VAR AssetBeta = [Beta (AAPL to Market)]
			
			VAR ExpectedReturn = RiskFreeRate + AssetBeta * (MarketReturn - RiskFreeRate)
			
			RETURN
			    IF(
			        NOT(ISBLANK(AssetBeta)),
			        AAPLReturn - ExpectedReturn,
			        BLANK()
			    )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 02 - Returns & Performance
		lineageTag: 33e6c164-23ec-4881-97ee-a80ce6803bd7

	measure 'Landing Page HTML' = ```
			
			// 1. Fetch Dynamic Data from the Semantic Model for Dataset Teasers
			VAR LastDataUpdate = [Last Refresh Date]  // Updated to use the new fact-table measure
			VAR FirstDataDate = FORMAT(MIN('Calendar'[Date]), "MMM dd, yyyy")
			VAR TotalTradingDays = FORMAT(COUNTROWS(aapl_daily), "#,0")
			VAR AllTimeHigh = FORMAT(CALCULATE(MAX(aapl_daily[Adj_Close]), ALL(aapl_daily)), "$#,0.00")
			
			// 2. Define the HTML and Advanced CSS3 Animations
			VAR HtmlContent = 
			"
			<style>
			    /* CSS3 Animations for UI Dynamics */
			    @keyframes fadeUp {
			        0% { opacity: 0; transform: translateY(30px); }
			        100% { opacity: 1; transform: translateY(0); }
