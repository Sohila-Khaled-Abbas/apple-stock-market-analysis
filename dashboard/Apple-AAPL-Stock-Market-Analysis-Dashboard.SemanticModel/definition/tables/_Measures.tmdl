	measure 'SVG Tooltip - Drawdown Recovery' = ```
			
			VAR CurrentPrice = [Latest Price]
			VAR AllTimeHigh = 
			    CALCULATE(
			        MAX(aapl_daily[Adj_Close]),
			        ALLSELECTED('Calendar'),
			        'Calendar'[Date] <= MAX('Calendar'[Date])
			    )
			VAR RecoveryRatio = DIVIDE(CurrentPrice, AllTimeHigh, 0)
			
			RETURN
			    XU.SVG.Progress.LabeledBar(
			        RecoveryRatio, 
			        "#424245",    // Background: Dark Grey
			        IF(RecoveryRatio >= 0.95, "#30d158", "#ff9f0a"), // Green if near ATH, Orange otherwise
			        4,            // Corner Radius
			        TRUE(), 
			        "Recovery: " & FORMAT(RecoveryRatio, "0.0%"), 
			        "#f5f5f7"     // Text Color
			    )
			```
		displayFolder: 08 - SVG & Tooltips
		lineageTag: 08308c5e-cc64-4867-96a9-c5ef2b3ae6d7

	measure 'SVG Tooltip - Volatility Donut' = ```
			
			VAR AAPLVol = [Annualized Volatility]
			VAR SP500Vol = 
			    VAR SP_DailyStdDev = STDEV.S(sp500_daily[Historical_SP500_Return])
			    RETURN SP_DailyStdDev * SQRT(252)
			
			// Ratio of AAPL Volatility relative to a "Highly Volatile" threshold (e.g., 2x the market)
			VAR VolatilityRatio = MIN(1, DIVIDE(AAPLVol, SP500Vol * 1.5, 1))
			
			RETURN
			    XU.SVG.Progress.Donut(
			        VolatilityRatio,
			        "#424245",    // Background 
			        "#1d1d1f",    // Inner hole background (matches dark theme)
			        0.65,         // Hole size
			        "#ff453a",    // Fill: System Red (indicating risk)
			        "#1d1d1f",    // Stroke color
			        TRUE(), 
			        "#ffffff"     // Text color
			    )
			```
		displayFolder: 08 - SVG & Tooltips
		lineageTag: 678f7e80-2655-4d0d-99d3-1dfabf039d48

	measure 'SVG Tooltip - RSI Capsule' = ```
			
			VAR RSIRatio = DIVIDE([RSI (14-Day)], 100, 0)
			VAR BarColor = 
			    SWITCH(
			        TRUE(),
			        RSIRatio >= 0.70, "#ff453a", // Overbought (Red)
			        RSIRatio <= 0.30, "#30d158", // Oversold (Green)
			        "#64d2ff"                    // Neutral (Blue)
			    )
			
			RETURN
			    XU.SVG.Progress.Capsule(
			        RSIRatio,
			        "#424245",
			        BarColor,
			        TRUE(),
			        "RSI Heat",
			        "#ffffff"
			    )
			```
		displayFolder: 08 - SVG & Tooltips
		lineageTag: 8b2999e0-60a5-437a-8f87-fd69429a6e11

	measure 'HTML - Decade Summary Table' = ```
			
			// 1. Generate the Dynamic Title
			VAR DynamicTitle = "Decadal Risk & Return Profile | " & [Filter Text - CEO Era]
			
			// 2. Generate the Aggregated Virtual Table
			VAR TableData = 
			    ADDCOLUMNS(
			        VALUES('Calendar'[Decade]),
			        "@CAGR", [CAGR],
			        "@Sparkline", [SVG Sparkline - Price Trend],
			        "@Vol", [Annualized Volatility],
			        "@Boxplot", [SVG Boxplot - Daily Returns]
			    )
			
			// 3. Iterate through the Virtual Table to build HTML Rows (<tr>)
			VAR TableRows = 
			    CONCATENATEX(
			        TableData,
			        // STRIP THE PREFIX TO CREATE CLEAN INLINE SVG
			        VAR CleanSparkline = SUBSTITUTE([@Sparkline], "data:image/svg+xml;utf8,", "")
			        VAR CleanBoxplot = SUBSTITUTE([@Boxplot], "data:image/svg+xml;utf8,", "")
			        
			        RETURN
			        "<tr class='data-row'>
			            <td class='cell-text' style='font-weight: 600; color: #ffffff;'>" & 'Calendar'[Decade] & "</td>
			            <td class='cell-text' style='color: #30d158;'>" & FORMAT([@CAGR], "0.0%") & "</td>
			            <td class='cell-svg'>" & CleanSparkline & "</td>
			            <td class='cell-text' style='color: #ff9f0a;'>" & FORMAT([@Vol], "0.0%") & "</td>
			            <td class='cell-svg'>" & CleanBoxplot & "</td>
			        </tr>",
			        "", 
			        'Calendar'[Decade], 
			        ASC
			    )
			
			// 4. Define the CSS Architecture and Container Shell
			VAR HtmlContent = 
			"
			<style>
			    .card-container {
			        width: 100%;
			        height: 100%;
			        display: flex;
			        flex-direction: column;
			        font-family: -apple-system, BlinkMacSystemFont, ""Segoe UI"", Roboto, sans-serif;
			        background: linear-gradient(145deg, #1d1d1f 0%, #151516 100%);
			        border: 1px solid #424245;
			        border-radius: 12px;
			        box-sizing: border-box;
			        padding: 16px 20px;
			    }
			    .dynamic-title {
			        color: #f5f5f7;
			        font-size: 16px;
			        font-weight: 700;
			        letter-spacing: -0.01em;
			        margin-bottom: 16px;
			    }
			    .custom-matrix {
			        width: 100%;
			        border-collapse: collapse;
			        border-radius: 8px;
			        overflow: hidden;
			        border: 1px solid #424245;
			    }
			    .custom-matrix th {
			        text-align: left;
			        padding: 10px 16px;
			        background-color: rgba(255, 255, 255, 0.03);
			        border-bottom: 1px solid #424245;
			        color: #86868b;
			        text-transform: uppercase;
			        font-size: 10px;
			        font-weight: 700;
			        letter-spacing: 0.05em;
			    }
			    .data-row {
			        border-bottom: 1px solid rgba(66, 66, 69, 0.4);
			        transition: background-color 0.2s ease;
			    }
			    .data-row:last-child {
			        border-bottom: none;
			    }
			    .data-row:hover {
			        background-color: rgba(41, 151, 255, 0.08); 
			    }
			    .cell-text {
			        padding: 8px 16px; /* Reduced vertical padding */
			        font-size: 13px;
			        vertical-align: middle;
			    }
			    .cell-svg {
			        padding: 4px 16px; /* Extremely tight vertical padding for SVGs */
			        vertical-align: middle;
			    }
			    /* Strictly constrain the inline SVG rendering */
			    .cell-svg svg {
			        display: block; 
			        max-width: 140px !important;
			        max-height: 36px !important;
			        width: 100%;
			        height: auto;
			    }
			</style>
			
			<div class='card-container'>
			    <div class='dynamic-title'>" & DynamicTitle & "</div>
			    <table class='custom-matrix'>
			        <thead>
			            <tr>
			                <th>Decade</th>
			                <th>CAGR</th>
			                <th>Price Trend</th>
			                <th>Volatility</th>
			                <th>Daily Returns Distribution</th>
			            </tr>
			        </thead>
			        <tbody>
			            " & TableRows & "
			        </tbody>
			    </table>
			</div>
			"
			
			RETURN HtmlContent
			```
		displayFolder: 09 - Page HTML & Navigation
