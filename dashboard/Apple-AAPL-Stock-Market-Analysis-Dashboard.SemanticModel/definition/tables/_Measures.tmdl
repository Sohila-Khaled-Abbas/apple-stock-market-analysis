	measure 'Header - Macro View HTML' = ```
			
			// 1. Fetch Presentation Context via PiotrBartela
			VAR RawDateContext = PiotrBartela.TitleContext.Period("", 'Calendar'[Date])
			VAR DateContext = TRIM(RawDateContext) // Cleans leading space if prefix is blank
			
			VAR RawEraFilter = PiotrBartela.TitleContext.Filtered(60, FALSE(), "Era", 'Calendar'[CEO Era], "", 'Calendar'[Date], "", 'Calendar'[Date], "", 'Calendar'[Date], "", 'Calendar'[Date])
			VAR EraContext = IF(RawEraFilter = "All Sales, Globally", "All Historical Eras", RawEraFilter)
			
			VAR CurrentPrice = FORMAT([Latest Price], "$#,0.00")
			
			// 2. Define SVG Icon (Global/Macro Grid)
			VAR IconSVG = "<svg viewBox='0 0 24 24' fill='none' stroke='#2997ff' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='width: 32px; height: 32px; margin-right: 16px;'><circle cx='12' cy='12' r='10'></circle><line x1='2' y1='12' x2='22' y2='12'></line><path d='M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z'></path></svg>"
			
			// 3. Build the HTML UI
			RETURN
			"
			<div style='
			    font-family: -apple-system, BlinkMacSystemFont, ""Segoe UI"", Roboto, sans-serif;
			    width: 100%;
			    display: flex;
			    justify-content: space-between;
			    align-items: center;
			    padding: 16px 24px;
			    background: linear-gradient(90deg, #151516 0%, #1d1d1f 100%);
			    border-bottom: 1px solid #424245;
			    border-radius: 12px 12px 0 0;
			    box-sizing: border-box;
			'>
			    <div style='display: flex; align-items: center;'>
			        " & IconSVG & "
			        <div>
			            <div style='font-size: 11px; color: #86868b; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; margin-bottom: 2px;'>AAPL Portfolio Analytics</div>
			            <div style='font-size: 26px; font-weight: 700; color: #ffffff; letter-spacing: -0.02em;'>Executive Macro View</div>
			        </div>
			    </div>
			
			    <div style='display: flex; align-items: center; gap: 16px;'>
			        
			        <div style='background: rgba(134, 134, 139, 0.1); border: 1px solid #424245; border-radius: 8px; padding: 6px 12px; text-align: left;'>
			            <div style='font-size: 10px; color: #86868b; text-transform: uppercase; letter-spacing: 0.05em;'>Active Segment</div>
			            <div style='font-size: 13px; font-weight: 600; color: #f5f5f7; margin-top: 2px;'>" & EraContext & "</div>
			        </div>
			
			        <div style='background: rgba(134, 134, 139, 0.1); border: 1px solid #424245; border-radius: 8px; padding: 6px 12px; text-align: left;'>
			            <div style='font-size: 10px; color: #86868b; text-transform: uppercase; letter-spacing: 0.05em;'>Market Horizon</div>
			            <div style='font-size: 13px; font-weight: 600; color: #64d2ff; margin-top: 2px;'>" & DateContext & "</div>
			        </div>
			
			        <div style='background: rgba(41, 151, 255, 0.1); border: 1px solid rgba(41, 151, 255, 0.3); border-radius: 8px; padding: 6px 16px; text-align: right; margin-left: 8px;'>
			            <div style='font-size: 10px; color: #2997ff; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 700;'>Latest Close</div>
			            <div style='font-size: 16px; font-weight: 700; color: #ffffff; margin-top: 1px;'>" & CurrentPrice & "</div>
			        </div>
			
			    </div>
			</div>
			"
			```
		displayFolder: 09 - Page HTML & Navigation
		lineageTag: 8f5fa826-7701-4d2e-9e35-6cdd59342cbf

	measure 'Header - Technical View HTML' = ```
			
			// 1. Fetch Presentation Context via PiotrBartela
			VAR RawDateContext = PiotrBartela.TitleContext.Period("", 'Calendar'[Date])
			VAR DateContext = TRIM(RawDateContext)
			VAR Volatility = FORMAT([Annualized Volatility], "0.00%")
			
			// 2. Define SVG Icon (Technical Chart)
			VAR IconSVG = "<svg viewBox='0 0 24 24' fill='none' stroke='#ff9f0a' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='width: 32px; height: 32px; margin-right: 16px;'><rect x='3' y='3' width='18' height='18' rx='2' ry='2'></rect><line x1='3' y1='9' x2='21' y2='9'></line><line x1='9' y1='21' x2='9' y2='9'></line><path d='M13 16l2-2 2 2'></path></svg>"
			
			// 3. Build the HTML UI
			RETURN
			"
			<div style='
			    font-family: -apple-system, BlinkMacSystemFont, ""Segoe UI"", Roboto, sans-serif;
			    width: 100%;
			    display: flex;
			    justify-content: space-between;
			    align-items: center;
			    padding: 16px 24px;
			    background: linear-gradient(90deg, #151516 0%, #1d1d1f 100%);
			    border-bottom: 1px solid #424245;
			    border-radius: 12px 12px 0 0;
			    box-sizing: border-box;
			'>
			    <div style='display: flex; align-items: center;'>
			        " & IconSVG & "
			        <div>
			            <div style='font-size: 11px; color: #86868b; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; margin-bottom: 2px;'>AAPL Portfolio Analytics</div>
			            <div style='font-size: 26px; font-weight: 700; color: #ffffff; letter-spacing: -0.02em;'>Technical & Momentum Deep Dive</div>
			        </div>
			    </div>
			
			    <div style='display: flex; align-items: center; gap: 16px;'>
			        
			        <div style='background: rgba(134, 134, 139, 0.1); border: 1px solid #424245; border-radius: 8px; padding: 6px 12px; text-align: left;'>
			            <div style='font-size: 10px; color: #86868b; text-transform: uppercase; letter-spacing: 0.05em;'>Active Trading Window</div>
			            <div style='font-size: 13px; font-weight: 600; color: #64d2ff; margin-top: 2px;'>" & DateContext & "</div>
			        </div>
			
			        <div style='background: rgba(255, 159, 10, 0.1); border: 1px solid rgba(255, 159, 10, 0.3); border-radius: 8px; padding: 6px 16px; text-align: right; margin-left: 8px;'>
			            <div style='font-size: 10px; color: #ff9f0a; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 700;'>Period Volatility</div>
			            <div style='font-size: 16px; font-weight: 700; color: #ffffff; margin-top: 1px;'>" & Volatility & "</div>
			        </div>
			
			    </div>
			</div>
			"
			```
		displayFolder: 09 - Page HTML & Navigation
		lineageTag: 2cf8193e-048e-4e0e-a802-b6638179df5d

	measure 'Sidebar Navigation HTML' = ```
			
			// 1. Define the Active Page (Change this to "Home" or "Technical" for the other pages)
			VAR ActivePage = "Macro"
			
			// 2. Fetch Dynamic Data Context
			VAR LastRefresh = FORMAT(LASTDATE('Calendar'[Date]), "MMM dd, yyyy")
			VAR TotalRows = FORMAT(COUNTROWS(aapl_daily), "#,0")
			
			// 3. Define the SVG Icons (Navigation & Brand)
			VAR IconHome = "<svg viewBox='0 0 24 24' style='width: 22px; height: 22px; fill: currentColor;'><path d='M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z'/></svg>"
			VAR IconMacro = "<svg viewBox='0 0 24 24' style='width: 22px; height: 22px; fill: currentColor;'><path d='M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z'/></svg>"
			VAR IconTech = "<svg viewBox='0 0 24 24' style='width: 22px; height: 22px; fill: currentColor;'><path d='M16 11.78L20.24 4.45 21.97 5.45 17.74 12.78 16 11.78zM7.97 5.45L9.7 4.45 13.94 11.78 12.21 12.78 7.97 5.45zM12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm0-14c-3.31 0-6 2.69-6 6s2.69 6 6 6 6-2.69 6-6-2.69-6-6-6zm0 10c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4z'/></svg>"
			VAR IconApple = "<svg viewBox='0 0 384 512' style='width: 35px; height: 35px; fill: #f5f5f7;'><path d='M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z'></path></svg>"
			
			// Custom API Logos
			VAR IconYF = "<svg viewBox='0 0 24 24' style='width: 14px; height: 14px;'><circle cx='12' cy='12' r='12' fill='#720e9e'/><text x='12' y='16.5' fill='#ffffff' font-size='13' font-weight='800' font-family='Arial, sans-serif' text-anchor='middle'>Y!</text></svg>"
			VAR IconStooq = "<svg viewBox='0 0 24 24' style='width: 14px; height: 14px;'><rect width='24' height='24' rx='4' fill='#005b9f'/><path d='M6 16l4-4 4 2 4-6' stroke='#ffffff' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' fill='none'/></svg>"
			
			// 4. Logic to inject the 'active' CSS class
			VAR HomeClass = IF(ActivePage = "Home", "nav-item active", "nav-item")
			VAR MacroClass = IF(ActivePage = "Macro", "nav-item active", "nav-item")
			VAR TechClass = IF(ActivePage = "Technical", "nav-item active", "nav-item")
			
			// 5. Build the HTML and CSS
			VAR HtmlContent = 
			"
			<style>
			    body { margin: 0; padding: 0; overflow: hidden; }
			    
			    .sidebar {
			        font-family: -apple-system, BlinkMacSystemFont, ""Segoe UI"", Roboto, Helvetica, Arial, sans-serif;
			        background-color: #1d1d1f;
			        border-right: 1px solid #424245;
			        width: 100%;
			        height: 100vh;
			        display: flex;
			        flex-direction: column;
			        justify-content: space-between;
			        box-sizing: border-box;
			        padding-top: 30px;
			        padding-bottom: 20px;
			    }
			
			    .top-section {
			        display: flex;
			        flex-direction: column;
			        align-items: center;
			        width: 100%;
			    }
			
			    .brand-container {
			        margin-bottom: 40px;
			        display: flex;
			        flex-direction: column;
			        align-items: center;
			    }
			
			    .brand-title {
			        color: #f5f5f7;
			        font-size: 14px;
			        font-weight: 700;
			        letter-spacing: -0.01em;
			        margin-top: 12px;
			        text-align: center;
			    }
			
			    .brand-subtitle {
			        color: #86868b;
			        font-size: 10px;
			        text-transform: uppercase;
			        letter-spacing: 0.1em;
			        margin-top: 4px;
			    }
			
			    .nav-container {
			        width: 100%;
			        display: flex;
			        flex-direction: column;
			        gap: 10px;
			        padding: 0 15px;
			        box-sizing: border-box;
			    }
			
			    .nav-item {
			        display: flex;
			        align-items: center;
			        gap: 15px;
			        padding: 12px 20px;
			        border-radius: 10px;
			        color: #86868b;
			        background-color: transparent;
			        font-size: 14px;
			        font-weight: 500;
			        letter-spacing: 0.02em;
			        transition: all 0.2s ease;
			        box-sizing: border-box;
			        width: 100%;
			    }
			
			    .nav-item:hover { background-color: #2c2c2e; color: #f5f5f7; }
			    .nav-item.active { background-color: rgba(41, 151, 255, 0.15); color: #2997ff; border-left: 3px solid #2997ff; }
			
			    .context-panel {
			        width: 85%;
			        margin: 0 auto;
			        padding: 16px;
			        background: rgba(255, 255, 255, 0.03);
			        border: 1px solid #424245;
			        border-radius: 12px;
			        box-sizing: border-box;
			        display: flex;
			        flex-direction: column;
			        gap: 14px;
			    }
			
			    .context-row {
			        display: flex;
			        flex-direction: column;
			        gap: 6px;
			    }
			
			    .context-label {
			        font-size: 10px;
			        color: #86868b;
			        text-transform: uppercase;
			        letter-spacing: 0.05em;
			    }
			
			    .context-value {
			        font-size: 13px;
			        font-weight: 600;
			        color: #f5f5f7;
			    }
			
			    /* API Badge Grid */
			    .source-grid {
			        display: flex;
			        flex-wrap: wrap;
			        gap: 8px;
			    }
			
			    .source-badge {
			        display: flex;
			        align-items: center;
			        gap: 6px;
			        background: rgba(255, 255, 255, 0.06);
			        border: 1px solid rgba(255, 255, 255, 0.1);
			        border-radius: 6px;
			        padding: 5px 8px;
			        font-size: 11px;
			        font-weight: 600;
			        color: #f5f5f7;
			        box-sizing: border-box;
			    }
			</style>
			
			<div class='sidebar'>
			    
			    <div class='top-section'>
			        <div class='brand-container'>
			            " & IconApple & "
			            <div class='brand-title'>AAPL Analytics</div>
			            <div class='brand-subtitle'>v2.4.1</div>
			        </div>
			
			        <div class='nav-container'>
			            <div class='" & HomeClass & "'>
			                " & IconHome & "
			                <span>Landing Page</span>
			            </div>
			            <div class='" & MacroClass & "'>
			                " & IconMacro & "
			                <span>Macro View</span>
			            </div>
			            <div class='" & TechClass & "'>
			                " & IconTech & "
			                <span>Technical View</span>
			            </div>
			        </div>
			    </div>
			
			    <div class='context-panel'>
			        <div class='context-row'>
			            <div class='context-label'>Live Data Sources</div>
			            <div class='source-grid'>
			                <div class='source-badge'>
			                    " & IconYF & " <span>yFinance</span>
			                </div>
			                <div class='source-badge'>
			                    " & IconStooq & " <span>Stooq</span>
			                </div>
			            </div>
			        </div>
			        <div class='context-row'>
			            <div class='context-label'>Latest Refresh</div>
			            <div class='context-value'>" & LastRefresh & "</div>
			        </div>
			        <div class='context-row'>
			            <div class='context-label'>Total Records</div>
			            <div class='context-value'>" & TotalRows & " Days</div>
			        </div>
			    </div>
			
			</div>
			"
			RETURN HtmlContent
			```
		displayFolder: 09 - Page HTML & Navigation
		lineageTag: f421e6fe-d45f-4a29-b3e7-9862e6dd0bda

