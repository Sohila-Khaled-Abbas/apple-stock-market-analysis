	measure 'Title - Macro Price Chart' = ```
			
			// 1. Extract the active temporal bounds
			VAR MinYear = MIN('Calendar'[Year])
			VAR MaxYear = MAX('Calendar'[Year])
			VAR YearDiff = MaxYear - MinYear
			VAR CurrentYear = YEAR(TODAY())
			
			// 2. Define the narrative logic (ignoring exact day matching)
			VAR PeriodText = 
			    SWITCH(
			        TRUE(),
			        // Scenario 1: User filtered to the current year
			        YearDiff = 0 && MaxYear = CurrentYear, 
			        "YTD (" & MaxYear & ")",
			        
			        // Scenario 2: User filtered to a single historical year
			        YearDiff = 0, 
			        "(" & MaxYear & ")",
			        
			        // Scenario 3: User filtered to a multi-year span ending this year
			        MaxYear = CurrentYear || MaxYear = CurrentYear - 1, 
			        "Last " & YearDiff & " Years (" & MinYear & " - " & MaxYear & ")",
			        
			        // Scenario 4: User filtered to a historical multi-year span (e.g., Jobs Era)
			        "(" & MinYear & " - " & MaxYear & " | " & YearDiff & " Years)"
			    )
			    
			// 3. Output the final presentation string
			RETURN 
			    "Historical Price Action " & PeriodText
			```
		displayFolder: 10 - Filters & Titles
		lineageTag: f3e497c8-c1b5-49a4-8527-e2fdc5798980

