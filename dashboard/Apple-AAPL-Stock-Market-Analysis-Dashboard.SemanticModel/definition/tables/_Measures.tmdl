	/// Average adjusted closing price over the selected period (Actual).
	measure 'Avg Price AC' =
			
			AVERAGE(aapl_daily[Adj_Close])
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: 01 - Price & Volume
		lineageTag: 092bab6b-059b-4310-829e-6887561383cb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Average adjusted closing price for the equivalent prior-year period.
	measure 'Avg Price PY' =
			
			CALCULATE(
			    [Avg Price AC],
			    DATEADD('Calendar'[Date], -1, YEAR)
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: 01 - Price & Volume
		lineageTag: e7f3780b-f52e-40e7-a2f9-df75b52c7039

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'IBCS YoY Variance Chart' =
			
			PowerofBI.IBCS.BarChart.AbsoluteVariance(
			    'Calendar'[Year],                                           // dimensionColumn: The row context
			    [Avg Price AC],                                             // mainValueExpr: Actuals (AC)
			    BLANK(),                                                    // secondValueExpr: Forecast (Not used here)
			    [Avg Price PY],                                             // baseValueExpr: Comparison (PY)
			    CALCULATE([Avg Price AC], ALLSELECTED('Calendar'[Year])),   // scaleValueExpr: For max scaling width
			    "grey",                                                     // baseType: IBCS standard for PY
			    NOT(ISINSCOPE('Calendar'[Year])),                           // totalRow: Detects the grand total line
			    FORMAT([Avg Price AC] - [Avg Price PY], "+$#,0.00;-$#,0.00;$0.00"), // dataLabel: The text to display
			    250,                                                        // imageWidth: Width in pixels
			    35,                                                         // imageHeight: Height in pixels
			    1                                                           // businessImpact: 1 means Positive = Green
			)
		displayFolder: 02 - Returns & Performance
		lineageTag: 6d07781c-8d49-4bc6-8a6a-1ddbe470cdd3
		dataCategory: ImageUrl

	measure 'KPI - Latest Price' =
			
			VAR FormatPrice = FORMAT([Latest Price], "$#,0.00")
			VAR IconSVG = "<svg viewBox='0 0 24 24' fill='none' stroke='#2997ff' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='width: 26px; height: 26px;'><line x1='12' y1='1' x2='12' y2='23'></line><path d='M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6'></path></svg>"
			
			RETURN
			"<style>
			    .kpi-card { background: linear-gradient(145deg, #1d1d1f 0%, #151516 100%); border: 1px solid #424245; border-radius: 16px; padding: 20px; display: flex; align-items: center; gap: 18px; height: 100%; box-sizing: border-box; font-family: -apple-system, BlinkMacSystemFont, sans-serif; transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease; }
			    .kpi-card:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.4); border-color: #2997ff; }
			    .icon-box { width: 54px; height: 54px; border-radius: 14px; background: rgba(41, 151, 255, 0.12); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
			</style>
			<div class='kpi-card'>
			    <div class='icon-box'>" & IconSVG & "</div>
			    <div style='display: flex; flex-direction: column;'>
			        <div style='color: #86868b; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2px;'>Latest Close</div>
			        <div style='color: #f5f5f7; font-size: 30px; font-weight: 700; letter-spacing: -0.02em;'>" & FormatPrice & "</div>
			        <div style='color: transparent; font-size: 12px; font-weight: 500; margin-top: 2px; user-select: none;'>&nbsp;</div>
			    </div>
			</div>"
		displayFolder: 07 - KPI Cards
		lineageTag: e1adad08-3d9a-4e2c-84ce-a3bba8651f14

	measure 'KPI - CAGR' =
			
			VAR FormatAAPL = FORMAT([CAGR], "0.00%")
			VAR FormatSP500 = FORMAT([SP500 CAGR], "0.00%")
			VAR IconSVG = "<svg viewBox='0 0 24 24' fill='none' stroke='#30d158' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='width: 26px; height: 26px;'><polyline points='23 6 13.5 15.5 8.5 10.5 1 18'></polyline><polyline points='17 6 23 6 23 12'></polyline></svg>"
			
			RETURN
			"<style>
			    .kpi-card { background: linear-gradient(145deg, #1d1d1f 0%, #151516 100%); border: 1px solid #424245; border-radius: 16px; padding: 20px; display: flex; align-items: center; gap: 18px; height: 100%; box-sizing: border-box; font-family: -apple-system, BlinkMacSystemFont, sans-serif; transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease; }
			    .kpi-card:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.4); border-color: #30d158; }
			    .icon-box { width: 54px; height: 54px; border-radius: 14px; background: rgba(48, 209, 88, 0.12); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
			</style>
			<div class='kpi-card'>
			    <div class='icon-box'>" & IconSVG & "</div>
			    <div style='display: flex; flex-direction: column;'>
